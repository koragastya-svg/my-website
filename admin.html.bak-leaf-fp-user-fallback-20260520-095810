            <td style="font-size:0.78rem;line-height:1.8;">
              ${s.apply_type === 'external'
                ? `<span style="color:#3a5bd9;font-weight:600;">🔗 외부폼</span>`
                : `<span style="color:#2e7d32;">🏠 내장폼</span>`}
              <br>
              ${s.member_only === 'member'
                ? `<span style="font-size:0.7rem;background:#fff3e0;color:#e65100;padding:1px 6px;border-radius:8px;font-weight:600;">🔒 회원전용</span>`
                : `<span style="font-size:0.7rem;background:#e8f5e9;color:#2e7d32;padding:1px 6px;border-radius:8px;">🌐 누구나</span>`}
            </td>
            <td>${formatPrice(s.price)}</td>
            <td>${s.current_applicants||0} / ${s.capacity||0}</td>
            <td>${statusBadge}</td>
            <td><div class="action-btns">
              <button class="btn btn--outline btn--sm" onclick="editSeminar('${s.id}')">편집</button>
              <button class="btn btn--sm" style="border:1px solid #e53e3e;color:#e53e3e;" onclick="deleteSeminar('${s.id}')">삭제</button>
            </div></td>
          </tr>`;
        }).join('')
      : '<tr class="empty-row"><td colspan="9">등록된 세미나가 없습니다.</td></tr>';
