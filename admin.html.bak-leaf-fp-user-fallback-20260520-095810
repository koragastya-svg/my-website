  let allCategories = []; // {id, content} from site_content key='seminar_cat_*'

  async function loadCategories() {
    try {
      if (!Object.keys(siteContentMap).length) {
        const rawMap = await SB.loadContentMap(500);
        Object.entries(rawMap).forEach(([key, row]) => { siteContentMap[key] = { id: row.id, content: row.content }; });
      }
      allCategories = Object.entries(siteContentMap)
        .filter(([k]) => k.startsWith('seminar_cat_'))
        .map(([k, v]) => ({ key: k, id: v.id, name: v.content }))
        .sort((a,b) => a.name.localeCompare(b.name));
      renderCatList();
    } catch(e) { Toast.show('카테고리를 불러오지 못했습니다.', 'error'); }
  }

  function renderCatList() {
    const el = document.getElementById('cat-list');
    if (!el) return;
    if (!allCategories.length) {
      el.innerHTML = '<span style="color:var(--text-light);font-size:0.85rem;">등록된 카테고리가 없습니다. 기본값(아가스티아, 리트리트, 인도여행, 필로소피)이 사용됩니다.</span>';
      syncCategorySelect();
      return;
    }
    el.innerHTML = allCategories.map(c => `
      <div style="display:flex;align-items:center;gap:6px;background:white;border:1px solid var(--border);border-radius:20px;padding:5px 12px;">
        <span id="cat-label-${c.id}" style="font-size:0.85rem;color:var(--text-dark);cursor:pointer;padding:2px 4px;border-radius:4px;"
              onclick="startRenameCat('${c.id}','${c.key}','${c.name}')" title="클릭하여 이름 변경">${c.name}</span>
        <button onclick="deleteCategory('${c.id}','${c.key}','${c.name}')" style="background:none;border:none;cursor:pointer;color:#c53030;font-size:1rem;line-height:1;padding:0;" title="삭제">×</button>
      </div>`).join('');
    syncCategorySelect();
  }

  function startRenameCat(id, key, currentName) {
    const span = document.getElementById(`cat-label-${id}`);
    if (!span) return;
    const inp = document.createElement('input');
    inp.type = 'text';
    inp.value = currentName;
    inp.style.cssText = 'font-size:0.85rem;border:1px solid var(--gold);border-radius:4px;padding:2px 6px;outline:none;width:80px;';
    inp.onblur = () => renameCategory(id, key, inp.value.trim(), currentName);
    inp.onkeydown = (e) => {
      if (e.key === 'Enter') inp.blur();
      if (e.key === 'Escape') { span.textContent = currentName; inp.replaceWith(span); }
    };
    span.replaceWith(inp);
    inp.focus(); inp.select();
  }

  async function renameCategory(id, key, newName, oldName) {
    if (!newName || newName === oldName) { renderCatList(); return; }
    if (allCategories.find(c => c.name === newName && c.id !== id)) {
      Toast.show('이미 존재하는 카테고리 이름입니다.', 'error'); renderCatList(); return;
    }
    await SB.update('site_content', id, { content: newName });
    siteContentMap[key].content = newName;
    Toast.show(`'${oldName}' → '${newName}' 변경되었습니다.`, 'success');
    allCategories = allCategories.map(c => c.id === id ? {...c, name: newName} : c);
    renderCatList();
  }

  function syncCategorySelect() {
    const sel = document.getElementById('sm-category');
    if (!sel) return;
    const defaults = ['아가스티아','리트리트','인도여행','필로소피'];
    const cats = allCategories.length ? allCategories.map(c=>c.name) : defaults;
    const cur = sel.value;
    sel.innerHTML = cats.map(c => `<option${c===cur?' selected':''}>${c}</option>`).join('');
  }

