  /* ── 대시보드 잎 리딩 최근 내역 (묶음 표시) ── */
  async function loadDashLeafReadings() {
    const tbody = document.getElementById('dash-leaf-tbody');
    if (!tbody) return;
    try {
      const raw = await SB.getAll('leaf_readings', { limit: 300 });
      const allRows = raw.filter(r => !r.deleted);

      // ── 2분 gap 클러스터링 (user_id + created_at 기준) ──
      const GROUP_GAP_MS = 2 * 60 * 1000;
      const chOrder = { '1':1,'13':2,'14':3,'ritual_13':4,'ritual_14':5,'other':6 };
      const chapterLabel = { '1':'1장','13':'13장','14':'14장','ritual_13':'의식대행','ritual_14':'부적대행','other':'기타' };

      const _byUser = new Map();
      const _noUser = [];
      allRows.forEach(r => {
        if (r.user_id && r.created_at) {
          if (!_byUser.has(r.user_id)) _byUser.set(r.user_id, []);
          _byUser.get(r.user_id).push(r);
        } else { _noUser.push(r); }
      });

      const _clusters = [];
      _byUser.forEach((userRows) => {
        const sorted = [...userRows].sort((a,b) => (Number(a.created_at)||0) - (Number(b.created_at)||0));
        let curCluster = null, curMaxTs = 0;
        sorted.forEach(r => {
          const ts = Number(r.created_at) || 0;
          if (!curCluster || ts - curMaxTs > GROUP_GAP_MS) {
            curCluster = { rows: [] };
            _clusters.push(curCluster);
          }
          curCluster.rows.push(r);
          curMaxTs = Math.max(curMaxTs, ts);
        });
      });
      _noUser.forEach(r => _clusters.push({ rows: [r] }));

      // 최신순 정렬 후 최대 10클러스터
      _clusters.sort((a,b) => {
        const tA = Math.max(...a.rows.map(r => Number(r.created_at)||0));
        const tB = Math.max(...b.rows.map(r => Number(r.created_at)||0));
        return tB - tA;
      });
      const top10 = _clusters.slice(0, 10);

      const statusColor = (s) => ({ '결제완료':'#1a7a3a','실행완료':'#1a7a3a','접수중':'#b45309','결제대기':'#1d4ed8','취소':'#9ca3af' })[s] || '#6b7280';
