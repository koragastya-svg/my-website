  async function loadUsers() {
    loadRegistrationStatus();
    try {
      const raw = await SB.getAll('users', { limit: 500 });
      // 소프트딜리트(deleted=true) 제외
      allUsers = raw.filter(u => !u.deleted);
      // created_at 기준 최신순 정렬 (밀리초 숫자 또는 ISO 문자열 모두 처리)
      allUsers.sort((a, b) => {
        const ta = isNaN(Number(a.created_at)) ? new Date(a.created_at).getTime() : Number(a.created_at);
        const tb = isNaN(Number(b.created_at)) ? new Date(b.created_at).getTime() : Number(b.created_at);
        return tb - ta;
      });
    } catch(e) { allUsers = []; }
    renderUsersTable(allUsers);
  }

  function renderUsersTable(users) {
    const rows = users.map(u => {
      const gv = u.gender || '';
      const gDisplay = gv === '남성' ? '👨 남성' : gv === '여성' ? '👩 여성' : '<span style="color:#bbb;">-</span>';
      const emailEsc = (u.email||'').replace(/\\/g,'\\\\').replace(/'/g,"\\'");
      const phoneEsc = (u.phone||'').replace(/\\/g,'\\\\').replace(/'/g,"\\'");
      const memoEsc  = (u.memo ||'').replace(/\\/g,'\\\\').replace(/'/g,"\\'");
      const memoCell = u.memo
        ? `<span style="display:inline-block;max-width:130px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${u.memo}</span>`
        : '<span style="color:#bbb;">비고</span>';
      const roleBadge = (u.role==='admin'||u.role==='superadmin')
        ? '<span class="badge badge--gold">관리자</span>'
        : '<span class="badge badge--navy">회원</span>';
      const delBtn = (u.role !== 'admin' && u.role !== 'superadmin')
        ? `<button class="btn btn--sm" style="border:1px solid #c53030;color:#c53030;font-size:0.7rem;" onclick="deleteUser('${u.id}','${u.username}')">삭제</button>`
        : '<span style="font-size:0.75rem;color:var(--text-light);">보호됨</span>';
      return `<tr>
        <td><strong>${u.name||'-'}</strong></td>
        <td style="font-size:0.82rem;color:var(--text-mid);">${u.username||'-'}</td>
        <td id="user-email-${u.id}" style="font-size:0.78rem;cursor:pointer;color:var(--gold);" title="클릭하여 이메일 수정"
            onclick="editUserField('${u.id}','email','${emailEsc}')">
          ${u.email||'-'}</td>
        <td id="user-phone-${u.id}" style="font-size:0.78rem;cursor:pointer;color:var(--gold);" title="클릭하여 전화번호 수정"
            onclick="editUserField('${u.id}','phone','${phoneEsc}')">
          ${u.phone||'-'}</td>
        <td id="user-gender-${u.id}" style="font-size:0.8rem;cursor:pointer;color:var(--gold);" title="클릭하여 성별 수정"
            onclick="editUserGender('${u.id}','${gv}')">
          ${gDisplay}</td>
        <td id="user-memo-${u.id}" style="font-size:0.78rem;cursor:pointer;max-width:140px;color:${u.memo?'var(--text-mid)':'var(--text-light)'};" title="클릭하여 비고 수정"
            onclick="editUserField('${u.id}','memo','${memoEsc}')">
          ${memoCell}</td>
        <td>${roleBadge}</td>
        <td style="font-size:0.78rem;">${u.created_at ? new Date(u.created_at).toLocaleDateString('ko-KR') : '-'}</td>
        <td><div class="action-btns">${delBtn}</div></td>
      </tr>`;
    });
    document.getElementById('users-tbody').innerHTML = rows.length
      ? rows.join('')
      : '<tr class="empty-row"><td colspan="9">회원이 없습니다.</td></tr>';
  }

  function filterUsers(q) {
    const f = allUsers.filter(u => (u.name||'').includes(q) || (u.username||'').includes(q) || (u.email||'').includes(q));
    renderUsersTable(f);
  }

