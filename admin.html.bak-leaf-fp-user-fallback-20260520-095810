  /* ── API 연결 상태 자가 진단 ── */
  (async function diagnoseSB() {
    try {
      const res = await fetch('tables/site_content?limit=1');
      if (!res.ok) {
        console.warn('[진단] tables/ API 응답 이상:', res.status, res.statusText);
        Toast.show('⚠️ DB 연결 확인 필요 (F12→Console 확인)', 'error');
        return;
      }
      const d = await res.json();
      const rows = Array.isArray(d) ? d : (d.data || []);
      console.info('[진단] tables/ API 정상. 응답 행 수:', rows.length, '응답 형태:', Array.isArray(d) ? '배열' : 'data:{...}');

      // ── HTTP 메서드 지원 여부 진단 ──
      if (rows.length > 0) {
        const testId = rows[0].id || rows[0].gs_id || rows[0]._id;
        if (testId) {
          // PATCH 테스트
          const patchRes = await fetch(`tables/site_content/${testId}`, {
            method: 'PATCH', headers: {'Content-Type':'application/json'},
            body: JSON.stringify({ _test: 1 })
          });
          console.info(`[진단] PATCH 지원: ${patchRes.status !== 405 ? '✅ ' + patchRes.status : '❌ 405 Not Allowed'}`);

          // PUT 테스트
          const putRes = await fetch(`tables/site_content/${testId}`, {
            method: 'PUT', headers: {'Content-Type':'application/json'},
            body: JSON.stringify({ _test: 1 })
          });
          console.info(`[진단] PUT 지원: ${putRes.status !== 405 ? '✅ ' + putRes.status : '❌ 405 Not Allowed'}`);

          // DELETE 테스트 (실제 삭제하지 않고 404/405 확인용 dummy id)
          const delRes = await fetch(`tables/site_content/__test_method_check__`, {
            method: 'DELETE'
          });
          console.info(`[진단] DELETE 지원: ${delRes.status !== 405 ? '✅ ' + delRes.status : '❌ 405 Not Allowed'}`);
        }
      }
    } catch(e) {
      console.error('[진단] tables/ API fetch 실패:', e.message);
      Toast.show('⚠️ API 연결 실패: ' + e.message, 'error');
    }
  })();
</script>

<script>
/* ════════════════════════════════════════════════════
   관리자 페이지 모바일 사이드바 토글
   - toggleAdminSidebar() : 열기/닫기 토글
   - openAdminSidebar()   : 열기
   - closeAdminSidebar()  : 닫기
   - ESC 키로 닫기
   - showPanel() 호출 후 자동 닫기 (admin.html 내부에서 처리)
════════════════════════════════════════════════════ */
function openAdminSidebar() {
  const sidebar  = document.getElementById('admin-sidebar');
  const overlay  = document.getElementById('admin-sidebar-overlay');
  const toggle   = document.getElementById('admin-sidebar-toggle');
  if (sidebar)  sidebar.classList.add('open');
  if (overlay)  overlay.classList.add('open');
  if (toggle)   toggle.classList.add('open');
  toggle && toggle.setAttribute('aria-label', '메뉴 닫기');
  document.body.style.overflow = 'hidden';
}
function closeAdminSidebar() {
  const sidebar  = document.getElementById('admin-sidebar');
  const overlay  = document.getElementById('admin-sidebar-overlay');
  const toggle   = document.getElementById('admin-sidebar-toggle');
  if (sidebar)  sidebar.classList.remove('open');
  if (overlay)  overlay.classList.remove('open');
  if (toggle)   toggle.classList.remove('open');
  toggle && toggle.setAttribute('aria-label', '메뉴 열기');
  document.body.style.overflow = '';
}
function toggleAdminSidebar() {
  const sidebar = document.getElementById('admin-sidebar');
  if (sidebar && sidebar.classList.contains('open')) {
    closeAdminSidebar();
  } else {
    openAdminSidebar();
  }
}
/* ESC 키로 사이드바 닫기 */
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeAdminSidebar();
});
/* 화면 크기가 900px 초과로 커지면 오버레이/overflow 초기화 */
window.addEventListener('resize', function() {
  if (window.innerWidth > 900) {
    closeAdminSidebar();
  }
});
</script>
