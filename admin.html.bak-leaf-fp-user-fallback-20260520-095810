  function editUserGender(id, currentVal) {
    const cell = document.getElementById('user-gender-' + id);
    if (!cell || cell.querySelector('select')) return;
    const sel = document.createElement('select');
    sel.style.cssText = 'font-size:0.78rem;border:1px solid var(--gold);border-radius:4px;padding:3px 6px;outline:none;cursor:pointer;';
    [['', '선택'], ['남성', '👨 남성'], ['여성', '👩 여성']].forEach(([v, t]) => {
      const opt = document.createElement('option');
      opt.value = v; opt.textContent = t;
      if (v === currentVal) opt.selected = true;
      sel.appendChild(opt);
    });
    const save = async () => {
      const newVal = sel.value;
      if (newVal && newVal !== currentVal) {
        try {
          await SB.update('users', id, { gender: newVal });
          const u = allUsers.find(x => x.id === id);
          if (u) u.gender = newVal;
          Toast.show('성별이 수정되었습니다.', 'success');
        } catch(e) { Toast.show('수정 중 오류: ' + e.message, 'error'); }
      }
      const gv = allUsers.find(x => x.id === id)?.gender || '';
      const gDisplay = gv === '남성' ? '👨 남성' : gv === '여성' ? '👩 여성' : '<span style="color:#bbb;">-</span>';
      cell.innerHTML = gDisplay;
      cell.onclick = () => editUserGender(id, gv);
    };
    sel.onblur = save;
    sel.onchange = () => setTimeout(save, 80);
    cell.innerHTML = '';
    cell.appendChild(sel);
    sel.focus();
  }

