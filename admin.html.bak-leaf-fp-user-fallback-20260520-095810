  /* ── 패키지 드롭다운 직접입력 토글 ── */
  function _onChapterSelChange(selId, customId) {
    const sel    = document.getElementById(selId);
    const custom = document.getElementById(customId);
    if (!sel || !custom) return;
    if (sel.value === '__custom__') {
      custom.style.display = 'block';
      custom.focus();
    } else {
      custom.style.display = 'none';
      custom.value = '';
    }
  }

  /** 드롭다운 + 직접입력 인풋에서 최종 chapter 값 추출 */
  function _resolveChapterValue(selId, customId) {
    const sel    = document.getElementById(selId);
    const custom = document.getElementById(customId);
    if (!sel) return '';
    if (sel.value === '__custom__') {
      return (custom && custom.value.trim()) ? custom.value.trim() : '';
    }
    return sel.value;
  }

  /* ── 그룹 상세모달 전용 헬퍼 ── */

  /** 그룹 카드 내 확정일 저장 또는 취소 */
  async function applyGrpAppt(id, isCancelling) {
    if (isCancelling) {
      if (!confirm('이 건의 확정일을 취소하면 회원이 마이페이지에서 다시 날짜를 선택해야 합니다.\n계속하시겠습니까?')) return;
      try {
        const row = _allLeafReadings.find(r => r.id === id);
        const prevSlotId = row?.slot_id || '';
        // appointment_date + slot_id + 상태 초기화
        await SB.update('leaf_readings', id, { appointment_date: null, slot_id: null, payment_status: '접수중' });
        if (row) { row.appointment_date = ''; row.slot_id = ''; row.payment_status = '접수중'; }
        // 이전 슬롯 current_bookings -1, 재개방
        if (prevSlotId) {
          try {
            const prevSlot = await SB.getOne('reading_slots', prevSlotId);
            if (prevSlot) {
              const prevCnt = Math.max(0, (parseInt(prevSlot.current_bookings) || 1) - 1);
              await SB.update('reading_slots', prevSlotId, { current_bookings: prevCnt, is_open: true });
            }
          } catch(_) {}
        }
        // 카드 내 인풋 초기화
        const input = document.getElementById(`grp-appt-input-${id}`);
        if (input) input.value = '';
        // 카드 헤더 날짜 배지 갱신
        _updateGrpCardApptBadge(id, '');
        Toast.show('확정일이 취소되었습니다. 회원이 재선택할 수 있습니다.', 'success');
        renderLeafReadingsTable(window._filteredLeafRows || _allLeafReadings);
      } catch(e) {
        Toast.show('취소 실패: ' + e.message, 'error');
      }
    } else {
      const input = document.getElementById(`grp-appt-input-${id}`);
      const newDate = input ? input.value : '';
      if (!newDate) { Toast.show('날짜를 선택해주세요.', 'error'); return; }
      try {
        await SB.update('leaf_readings', id, { appointment_date: newDate });
        const row = _allLeafReadings.find(r => r.id === id);
        if (row) row.appointment_date = newDate;
        _updateGrpCardApptBadge(id, newDate);
        Toast.show(`확정일 [${newDate}] 저장됨.`, 'success');
        renderLeafReadingsTable(window._filteredLeafRows || _allLeafReadings);
      } catch(e) {
        Toast.show('저장 실패: ' + e.message, 'error');
      }
    }
  }

  /** 그룹 카드 헤더의 날짜 배지 즉시 갱신 */
  function _updateGrpCardApptBadge(id, dateStr) {
    const card = document.getElementById(`grp-card-${id}`);
    if (!card) return;
    const header = card.querySelector('div[style*="linear-gradient"]');
    if (!header) return;
    // 날짜 배지: background:#fef3c7 또는 #d1fae5 또는 #e2e8f0 인 span
    const dateBadge = [...header.querySelectorAll('span')].find(s =>
      s.style.cssText.includes('#fef3c7') || s.style.cssText.includes('#d1fae5') || s.style.cssText.includes('#e2e8f0')
    );
    // 날짜 텍스트 span (날짜 값)
    const dateValSpan = [...header.querySelectorAll('span')].find(s =>
      s.style.cssText.includes('color:#334155')
    );
    if (!dateBadge) return;
    if (!dateStr) {
      dateBadge.textContent = '⏳ 미확정';
      dateBadge.style.cssText = 'font-size:0.7rem;padding:2px 8px;border-radius:12px;font-weight:700;background:#fef3c7;color:#92400e;';
      if (dateValSpan) dateValSpan.remove();
    } else {
      const todayD = new Date(); todayD.setHours(0,0,0,0);
      const apptD  = new Date(dateStr); apptD.setHours(0,0,0,0);
      if (apptD > todayD) {
        dateBadge.textContent = '✅ 확정';
        dateBadge.style.cssText = 'font-size:0.7rem;padding:2px 8px;border-radius:12px;font-weight:700;background:#d1fae5;color:#065f46;';
