  function filterDashApps() {
    const statusFilter = document.getElementById('dash-status-filter').value;
    let list = statusFilter ? dashAppsRaw.filter(a => a.payment_status === statusFilter) : [...dashAppsRaw];
    // 정렬 — created_at 기준일 때 original_created_at 우선 사용, 타입 혼용(문자열/숫자) 안전 비교
    const _toMs = (v) => {
      if (!v) return 0;
      if (typeof v === 'number') return v;
      if (typeof v === 'string') {
        if (v.includes('-') || v.includes('T')) return new Date(v).getTime() || 0;
        return Number(v) || 0;
      }
      return 0;
    };
    list.sort((a,b) => {
      const av = _toMs(dashSortKey === 'created_at' ? appCreatedAt(a) : a[dashSortKey]);
      const bv = _toMs(dashSortKey === 'created_at' ? appCreatedAt(b) : b[dashSortKey]);
      return (av > bv ? 1 : av < bv ? -1 : 0) * dashSortDir;
    });
    renderDashApps(list);
  }

  function sortDashApps(key) {
    if (dashSortKey === key) dashSortDir *= -1; else { dashSortKey = key; dashSortDir = -1; }
    filterDashApps();
  }

