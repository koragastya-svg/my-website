  function filterSeminars(q) {
    const f = allSeminars.filter(s => s.title.includes(q) || (s.category||'').includes(q));
    renderSeminarsTable(f);
  }

  function openSeminarModal(seminar) {
    document.getElementById('sm-id').value = seminar ? seminar.id : '';
    document.getElementById('sm-title').value = seminar ? seminar.title : '';
    document.getElementById('sm-subtitle').value = seminar ? (seminar.subtitle || '') : '';
    document.getElementById('sm-category').value = seminar ? (seminar.category || '') : '';
    // 날짜 타입 복원 (기간 or 하루)
    const hasDateEnd = seminar && seminar.date_end && seminar.date_end.trim();
    document.querySelector('input[name="sm-date-type"][value="single"]').checked = !hasDateEnd;
    document.querySelector('input[name="sm-date-type"][value="range"]').checked = !!hasDateEnd;
    if (hasDateEnd) {
      document.getElementById('sm-date-single').style.display = 'none';
      document.getElementById('sm-date-range').style.display = 'block';
