  function updateSurveyFieldLabel(id, val) { const f = smSurveyFields.find(x=>x.id===id); if(f) f.label=val; }
  function updateSurveyFieldSublabel(id, val) { const f = smSurveyFields.find(x=>x.id===id); if(f) f.sublabel=val; }
  function updateSurveyFieldRequired(id, val) { const f = smSurveyFields.find(x=>x.id===id); if(f) f.required=val; }
  function updateSurveyOption(fid, oi, prop, val) {
    const f = smSurveyFields.find(x=>x.id===fid);
    if (!f || !f.options) return;
    // 구버전 string → object 정규화
    if (typeof f.options[oi] === 'string') f.options[oi] = {label: f.options[oi], extraPrice: 0};
    f.options[oi][prop] = val;
  }
  function toggleExtraPrice(fid, checked) {
    const f = smSurveyFields.find(x=>x.id===fid);
    if (!f) return;
    f.hasExtraPrice = checked;
    // 옵션 정규화
    f.options = (f.options||[]).map(o => typeof o === 'string' ? {label:o, extraPrice:0} : o);
    renderSurveyFields(smSurveyFields);
  }

  function addSurveyOption(fid) {
    const f = smSurveyFields.find(x=>x.id===fid);
    if (!f) return;
    f.options.push(f.hasExtraPrice ? {label:`옵션 ${f.options.length+1}`, extraPrice:0} : {label:`옵션 ${f.options.length+1}`, extraPrice:0});
    renderSurveyFields(smSurveyFields);
  }
  function removeSurveyOption(fid, oi) {
    const f = smSurveyFields.find(x=>x.id===fid);
    if (!f) return;
    f.options.splice(oi,1);
    renderSurveyFields(smSurveyFields);
  }
  function removeSurveyField(id) {
    smSurveyFields = smSurveyFields.filter(x=>x.id!==id);
    renderSurveyFields(smSurveyFields);
  }
  function moveSurveyField(id, dir) {
    const idx = smSurveyFields.findIndex(x=>x.id===id);
    if (idx < 0) return;
    const newIdx = idx+dir;
    if (newIdx < 0 || newIdx >= smSurveyFields.length) return;
    [smSurveyFields[idx], smSurveyFields[newIdx]] = [smSurveyFields[newIdx], smSurveyFields[idx]];
    renderSurveyFields(smSurveyFields);
  }

  function collectSurveyFields() {
    // smSurveyFields 메모리 값 기준으로 DOM에서 최신 값 동기화
    smSurveyFields.forEach(f => {
      // 라벨: oninput으로 이미 동기화되어 있으나, 저장 시점에 한번 더 수집
      const card = document.querySelector(`.survey-field-card[data-field-id="${f.id}"]`);
      if (!card) return;
      const labelInputs = card.querySelectorAll('.form-group input[type=text]');
      if (labelInputs[0]) f.label = labelInputs[0].value.trim();
      if (labelInputs[1]) f.sublabel = labelInputs[1].value.trim();
      // 필수 여부
      card.querySelectorAll('.survey-field-toggle input[type=checkbox]').forEach(cb => {
        if (cb.closest('label')?.textContent?.includes('필수')) f.required = cb.checked;
      });
      // 옵션 수집 (선택형)
      if (['radio','checkbox','select'].includes(f.type)) {
        const rows = card.querySelectorAll(`#survey-opts-${f.id} .survey-option-row`);
        if (rows.length) {
          f.options = Array.from(rows).map(row => {
            const textIn = row.querySelector('input[type=text]');
            const numIn = row.querySelector('input[type=number]');
            return { label: textIn ? textIn.value.trim() : '', extraPrice: numIn ? (parseInt(numIn.value)||0) : 0 };
          }).filter(o => o.label);
        }
      }
    });
    const json = smSurveyFields.length ? JSON.stringify(smSurveyFields) : '';
    console.log('[collectSurveyFields] 저장 값:', json);
    return json;
  }

