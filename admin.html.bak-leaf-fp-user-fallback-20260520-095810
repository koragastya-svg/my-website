    const rawStatus = r.payment_status || '접수중';
    const status    = leafDisplayStatus(rawStatus);
    const statusBg  = leafStatusStyle(status);
    // chapter_label 우선 사용 (짧은 이름), 없으면 기본 매핑
    const _chLabelFallback = { '1':'1장','13':'13장','14':'14장','ritual_13':'의식 대행','ritual_14':'부적 대행','other':'기타' };
    // chapter_label 파싱: 원형숫자 직후 공백 기준으로 짧은이름/풀이름 분리
    const _CIRCLED_STR2 = '①②③④⑤⑥⑦⑧⑨⑩⑪⑫⑬⑭⑮⑯⑰⑱⑲⑳㉑㉒㉓㉔㉕㉖㉗㉘㉙㉚㉛㉜㉝㉞㉟㊱㊲㊳㊴㊵㊶㊷㊸㊹㊺㊻㊼㊽㊾㊿';
    const _splitLabel2 = (lbl) => {
      if (!lbl) return { short: '', full: '' };
      for (let i = 0; i < lbl.length; i++) {
        if (_CIRCLED_STR2.includes(lbl[i])) {
          const afterCirc = lbl.slice(i + 1);
          const spIdx = afterCirc.indexOf(' ');
          if (spIdx === 0) {
            return { short: lbl.slice(0, i + 1).trim(), full: afterCirc.slice(1).trim() };
          }
          break;
        }
      }
      return { short: lbl.trim(), full: '' };
    };
    const _rawLabel2 = r.chapter_label || _chLabelFallback[r.chapter] || r.chapter || '-';
    const _parsed2   = _splitLabel2(_rawLabel2);
    const chName     = _parsed2.short || _rawLabel2;
    // chapter_title: 풀 이름 (예: 나바그라하 칸담 / 산티 / 딕샤)
