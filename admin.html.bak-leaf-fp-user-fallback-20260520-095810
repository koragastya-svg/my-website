            <input type="checkbox" ${f.required?'checked':''} onchange="updateSurveyFieldRequired('${f.id}',this.checked)">
            필수 항목
          </label>
          <div style="display:flex;gap:6px;margin-left:auto;">
            ${i>0?`<button class="btn btn--sm btn--outline" style="font-size:0.7rem;padding:3px 8px;" onclick="moveSurveyField('${f.id}',-1)">▲</button>`:''}
            ${i<smSurveyFields.length-1?`<button class="btn btn--sm btn--outline" style="font-size:0.7rem;padding:3px 8px;" onclick="moveSurveyField('${f.id}',1)">▼</button>`:''}
