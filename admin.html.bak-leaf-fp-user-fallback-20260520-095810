  let _leaderCandidates = [];
  let _currentLeaders   = [];

  async function loadLeaderCandidates() {
    document.getElementById('leader-candidates-tbody').innerHTML = '<tr class="empty-row"><td colspan="7">로딩 중...</td></tr>';
    document.getElementById('leaders-tbody').innerHTML = '<tr class="empty-row"><td colspan="6">로딩 중...</td></tr>';
    try {
      const [allApps, allUsers] = await Promise.all([
        SB.getAll('leaf_readings', { limit: 500 }),
        SB.getAll('users', { limit: 500 })
      ]);

      // 각 user별 완료 여부 계산
      const userMap = {};
      allUsers.filter(u => !u.deleted).forEach(u => { userMap[u.id] = u; });

      // 1+13+14 모두 결제완료인 userId 목록
      const completedByUser = {};
      allApps.filter(a => a.payment_status === '결제완료').forEach(a => {
        if (!a.user_id) return;
        if (!completedByUser[a.user_id]) completedByUser[a.user_id] = new Set();
        completedByUser[a.user_id].add(a.chapter);
      });

      _leaderCandidates = [];
      Object.entries(completedByUser).forEach(([uid, chapters]) => {
        if (chapters.has('1') && chapters.has('13') && chapters.has('14')) {
          const user = userMap[uid];
          if (user) _leaderCandidates.push(user);
        }
      });

      // 현재 리더 목록
      _currentLeaders = allUsers.filter(u => u.role === 'leader' && !u.deleted);
      document.getElementById('leader-count').textContent = `(${_currentLeaders.length}명)`;
      document.getElementById('leader-candidate-count').textContent = `(${_leaderCandidates.length}명)`;

      // 승급 대상 테이블
      document.getElementById('leader-candidates-tbody').innerHTML = _leaderCandidates.length
        ? _leaderCandidates.map(u => {
            const isLeader = (u.role === 'leader' || u.role === 'admin' || u.role === 'superadmin');
            return `<tr>
              <td><strong>${u.name||'-'}</strong></td>
              <td style="font-size:0.82rem;">${u.username||'-'}</td>
              <td style="font-size:0.78rem;">${u.email||'-'}</td>
              <td><span class="badge ${isLeader?'badge--gold':'badge--navy'}">${isLeader?'리더':'일반회원'}</span></td>
              <td style="font-size:0.8rem;">1장 ✅ &nbsp; 13장 ✅ &nbsp; 14장 ✅</td>
              <td style="font-size:0.78rem;">${u.created_at ? new Date(Number(u.created_at)).toLocaleDateString('ko-KR') : '-'}</td>
              <td>
                ${isLeader
                  ? `<button class="btn btn--sm" style="background:#c53030;color:white;border:none;font-size:0.72rem;" onclick="downgradeLeader('${u.id}','${u.name}')">등급 해제</button>`
                  : `<button class="btn btn--sm" style="background:#1a7a4a;color:white;border:none;font-size:0.72rem;" onclick="upgradeToLeader('${u.id}','${u.name}')">리더 승급</button>`
                }
              </td>
            </tr>`;
          }).join('')
        : '<tr class="empty-row"><td colspan="7">승급 대상 회원이 없습니다.</td></tr>';

      // 현재 리더 테이블
      document.getElementById('leaders-tbody').innerHTML = _currentLeaders.length
        ? _currentLeaders.map(u => `<tr>
            <td><strong>${u.name||'-'}</strong></td>
            <td style="font-size:0.82rem;">${u.username||'-'}</td>
            <td style="font-size:0.78rem;">${u.email||'-'}</td>
            <td style="font-size:0.78rem;">${u.phone||'-'}</td>
            <td style="font-size:0.78rem;">${u.leader_upgraded_at ? new Date(Number(u.leader_upgraded_at)).toLocaleDateString('ko-KR') : '-'}</td>
            <td>
              <button class="btn btn--sm" style="border:1px solid #c53030;color:#c53030;font-size:0.72rem;" onclick="downgradeLeader('${u.id}','${u.name}')">등급 해제</button>
            </td>
          </tr>`).join('')
        : '<tr class="empty-row"><td colspan="6">리더 회원이 없습니다.</td></tr>';

    } catch(e) {
      document.getElementById('leader-candidates-tbody').innerHTML = '<tr class="empty-row"><td colspan="7">불러오기 실패</td></tr>';
      console.error('[loadLeaderCandidates]', e);
    }
  }

