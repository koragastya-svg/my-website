          return `<tr style="${rowStyle}">
            <td>
              ${isDone ? '<span style="font-size:0.65rem;background:#bbb;color:white;border-radius:3px;padding:1px 5px;margin-right:4px;">완료</span>' : ''}
              <strong style="${isDone?'color:#999;':''}">${s.title}</strong>
