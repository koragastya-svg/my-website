  async function fetchAllPages(table) {
    // page 기반 전체 페이징: total 확인 후 필요한 페이지 수만큼 순회
    const limit = 200;
    let all = [];
    let page = 1;
    while (true) {
      const res = await fetch(`tables/${table}?limit=${limit}&page=${page}`);
      if (!res.ok) break;
      const json = await res.json();
      const rows = Array.isArray(json) ? json
        : Array.isArray(json?.data) ? json.data
        : Array.isArray(json?.rows) ? json.rows : [];
      const validRows = rows.filter(r => r && !r.deleted);
      all = all.concat(validRows);
      const total = json?.total ?? json?.count ?? null;
      if (total !== null && all.length >= total) break;
      if (rows.length < limit) break;
      page++;
    }
    return all;
  }

