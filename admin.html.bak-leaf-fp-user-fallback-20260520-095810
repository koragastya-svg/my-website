  /* ════ 리더 블록 순서 조정 (드래그 & 화살표) ════ */
  (function initLeaderSortable() {
    const container = document.getElementById('leader-block-order-container');
    if (!container) return;

    let dragSrc = null;

    function getDraggables() {
      return [...container.querySelectorAll('.leader-sortable-block')];
    }

    // ── 화살표 이동 ──
    window.moveLeaderBlock = function(btn, dir) {
      const block = btn.closest('.leader-sortable-block');
      if (!block) return;
      const blocks = getDraggables();
      const idx = blocks.indexOf(block);
      if (dir === 'up' && idx > 0) {
        container.insertBefore(block, blocks[idx - 1]);
      } else if (dir === 'down' && idx < blocks.length - 1) {
        container.insertBefore(blocks[idx + 1], block);
      }
      updateArrowStates();
    };

    function updateArrowStates() {
      const blocks = getDraggables();
      blocks.forEach((b, i) => {
        const [up, down] = b.querySelectorAll('.leader-block-handle__arrows button');
        if (up)   up.disabled   = (i === 0);
        if (down) down.disabled = (i === blocks.length - 1);
        if (up)   up.style.opacity   = (i === 0) ? '0.3' : '1';
        if (down) down.style.opacity = (i === blocks.length - 1) ? '0.3' : '1';
      });
    }

    // ── 드래그&드롭 ──
    function addDragListeners(block) {
      const handle = block.querySelector('.leader-block-handle');
      block.draggable = true;

      block.addEventListener('dragstart', e => {
        dragSrc = block;
        block.classList.add('dragging');
        e.dataTransfer.effectAllowed = 'move';
      });
      block.addEventListener('dragend', () => {
        block.classList.remove('dragging');
        getDraggables().forEach(b => b.classList.remove('drag-over'));
        updateArrowStates();
      });
      block.addEventListener('dragover', e => {
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        if (dragSrc && dragSrc !== block) {
          getDraggables().forEach(b => b.classList.remove('drag-over'));
          block.classList.add('drag-over');
        }
      });
      block.addEventListener('dragleave', () => {
        block.classList.remove('drag-over');
      });
      block.addEventListener('drop', e => {
        e.preventDefault();
        if (dragSrc && dragSrc !== block) {
          const blocks = getDraggables();
          const srcIdx  = blocks.indexOf(dragSrc);
          const destIdx = blocks.indexOf(block);
          if (srcIdx < destIdx) container.insertBefore(dragSrc, block.nextSibling);
          else container.insertBefore(dragSrc, block);
        }
        block.classList.remove('drag-over');
        updateArrowStates();
      });
    }

    getDraggables().forEach(addDragListeners);
    updateArrowStates();
  })();

