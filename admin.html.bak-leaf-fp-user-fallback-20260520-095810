        dateBadge.textContent = '🏁 종료';
        dateBadge.style.cssText = 'font-size:0.7rem;padding:2px 8px;border-radius:12px;font-weight:700;background:#e2e8f0;color:#334155;';
      }
      if (dateValSpan) dateValSpan.textContent = dateStr;
    }
  }

  /** 묶음 전체 확정일 일괄 저장 */
  async function applyGrpApptAll(allIdsStr) {
    const input = document.getElementById('grp-bulk-appt-input');
    const newDate = input ? input.value : '';
    if (!newDate) { Toast.show('날짜를 선택해주세요.', 'error'); return; }
    const ids = allIdsStr.split(',').filter(Boolean);
    if (!confirm(`${ids.length}건 모두에 확정일 [${newDate}]을 저장하시겠습니까?`)) return;
    try {
      for (const id of ids) {
        await SB.update('leaf_readings', id, { appointment_date: newDate });
        const row = _allLeafReadings.find(r => r.id === id);
        if (row) row.appointment_date = newDate;
        const inp = document.getElementById(`grp-appt-input-${id}`);
        if (inp) inp.value = newDate;
        _updateGrpCardApptBadge(id, newDate);
      }
      Toast.show(`${ids.length}건에 확정일 [${newDate}]이 저장되었습니다.`, 'success');
      renderLeafReadingsTable(window._filteredLeafRows || _allLeafReadings);
    } catch(e) {
      Toast.show('일괄 저장 실패: ' + e.message, 'error');
    }
  }

  /** 묶음 전체 확정일 일괄 취소 */
  async function cancelGrpApptAll(allIdsStr) {
    const ids = allIdsStr.split(',').filter(Boolean);
    if (!confirm(`${ids.length}건 모두의 확정일을 취소하시겠습니까?\n회원이 마이페이지에서 날짜를 다시 선택할 수 있습니다.`)) return;
    try {
      // 이전 슬론 id 수집 (중복 제거)
      const prevSlotIds = new Set(
        ids.map(id => _allLeafReadings.find(r => r.id === id)?.slot_id).filter(Boolean)
      );
      for (const id of ids) {
        await SB.update('leaf_readings', id, { appointment_date: null, slot_id: null, payment_status: '접수중' });
        const row = _allLeafReadings.find(r => r.id === id);
        if (row) { row.appointment_date = ''; row.slot_id = ''; row.payment_status = '접수중'; }
        const inp = document.getElementById(`grp-appt-input-${id}`);
        if (inp) inp.value = '';
        _updateGrpCardApptBadge(id, '');
      }
      // 이전 슬론 current_bookings -1 심파 (slot에 연결된 확정 건수만큼 차감)
      for (const slotId of prevSlotIds) {
        try {
          const slotRow = await SB.getOne('reading_slots', slotId);
          if (slotRow) {
            // 이 슬론에 연결된 이전 건수 = ids 중 prevSlotId가 slotId인 것의 수
            const cnt = ids.filter(id => {
              const r = _allLeafReadings.find(x => x.id === id);
              return r?.slot_id === slotId || (prevSlotIds.has(slotId));
            }).length;
            const newCnt = Math.max(0, (parseInt(slotRow.current_bookings) || 1) - cnt);
            await SB.update('reading_slots', slotId, { current_bookings: newCnt, is_open: true });
          }
        } catch(_) {}
      }
      Toast.show(`${ids.length}건의 확정일이 모두 취소되었습니다.`, 'success');
      renderLeafReadingsTable(window._filteredLeafRows || _allLeafReadings);
    } catch(e) {
      Toast.show('일괄 취소 실패: ' + e.message, 'error');
    }
  }

