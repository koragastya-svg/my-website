          ${f.hasExtraPrice ? '<span style="font-size:0.68rem;background:#fffbf0;border:1px solid #f6c94a;color:#d69e2e;padding:1px 6px;border-radius:10px;margin-left:4px;">💰 추가금 있음</span>' : ''}
          <button class="survey-field-card__del" onclick="removeSurveyField('${f.id}')" title="삭제">🗑</button>
