  async function bulkDeleteSlots() {
    const checks = [...document.querySelectorAll('.slot-row-check:checked')];
    if (!checks.length) return;
    if (!confirm(`선택한 날짜 ${checks.length}개를 삭제하시겠습니까?\n\n이 작업은 되돌릴 수 없습니다.`)) return;
    const btn = document.getElementById('slot-bulk-delete-btn');
    if (btn) { btn.disabled = true; btn.textContent = '⏳ 삭제 중...'; }
    let ok = 0, fail = 0;
    for (const cb of checks) {
      try { await SB.remove('reading_slots', cb.value); ok++; }
      catch(_) { fail++; }
    }
    if (btn) { btn.disabled = false; btn.textContent = '🗑 선택 삭제'; }
    Toast.show(`${ok}개 삭제 완료${fail ? ` (실패 ${fail}개)` : ''}`, ok > 0 ? 'success' : 'error');
    await loadReadingSlots();
  }

