  /* ── 카카오톡 채널 알림 발송 ── */
  async function sendKakaoNotification(recordId) {
    const rec = _allLeafReadings.find(r => r.id === recordId);
    if (!rec) return;
    // 슈퍼어드바이저에서 저장한 API 키 로드
    let kakaoKey = '', senderKey = '', templateCode = '';
    try {
      const cfg = await SB.getAll('settings', { limit: 50 });
      const find = (k) => (cfg.find(c => c.key === k) || {}).value || '';
      kakaoKey     = find('kakao_rest_key');
      senderKey    = find('kakao_sender_key');
      templateCode = find('kakao_template_code');
    } catch(e) {}

    if (!kakaoKey || !senderKey) {
      alert('❌ 카카오톡 API 키가 설정되지 않았습니다.\n슈퍼어드바이저 → API 연동 설정에서 먼저 등록하세요.');
      return;
    }
    const chapterLabel = { '1':'1장','13':'13장','14':'14장','ritual_13':'의식 대행','ritual_14':'부적 대행','other':'기타' };
    const phone = (rec.user_phone || '').replace(/[^0-9]/g,'');
    if (!phone) { alert('전화번호가 없어 알림을 발송할 수 없습니다.'); return; }

    const confirmed = confirm(
      `📲 카카오톡 알림을 발송합니다.\n\n` +
      `신청자: ${rec.user_name||'-'}\n` +
      `패키지: ${chapterLabel[rec.chapter]||rec.chapter||'-'}\n` +
      `상태: ${rec.payment_status}\n` +
      `전화: ${rec.user_phone}\n\n발송하시겠습니까?`
    );
    if (!confirmed) return;

    // 카카오 알림톡 발송 (카카오 비즈메시지 REST API)
    try {
      const body = {
        sender_key: senderKey,
        template_code: templateCode || 'leaf_approved',
        receiver_1: phone,
        var1: rec.user_name || '고객',
        var2: chapterLabel[rec.chapter] || rec.chapter || '',
        var3: rec.payment_status
      };
      // 실제 카카오 API는 CORS 제한으로 서버 프록시 필요 — 현재 UI만 구현
      // 설정값 확인 후 안내
      Toast.show(
        `📲 ${rec.user_name} 님께 알림톡 발송 요청 완료 (카카오 채널 연동 필요)`,
        'success'
      );
      console.log('[카카오 알림] 발송 대상:', body);
    } catch(e) {
      Toast.show('알림 발송 실패: ' + e.message, 'error');
    }
  }

