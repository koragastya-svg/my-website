  /* CSV 생성 헬퍼 (필터용) */
  function _downloadAppsCSV(list, filename) {
    const header = ['신청일시','이름','이메일','전화번호','세미나','결제방법','금액','상태','메모'];
    const rows = list.map(a => [
      formatDateTime(appCreatedAt(a)),
      a.applicant_name||'-', a.applicant_email||'-', a.applicant_phone||'-',
      a.seminar_title||'-', a.payment_method||'-', a.payment_amount||0,
      a.payment_status||'-', (a.memo||'').replace(/\n/g,' | ')
    ]);
    _downloadAppsCSV2(header, rows, filename);
  }
  function _downloadAppsCSV2(header, rows, filename) {
    const BOM = '\uFEFF';
    const csv = BOM + [header, ...rows].map(r => r.map(c => `"${String(c).replace(/"/g,'""')}"`).join(',')).join('\n');
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = filename; a.click();
    URL.revokeObjectURL(url);
  }

  /* ── CSV 업로드로 신청내역 복구 ── */
  /* ══════════════════════════════════════════════════════
     공통 유틸: RFC-4180 CSV 파서 (필드 내 개행 완전 처리)
  ══════════════════════════════════════════════════════ */
  function _parseCSV(raw) {
    raw = raw.replace(/^\uFEFF/, ''); // BOM 제거
    const records = [];
    let fields = [], cur = '', inQ = false, i = 0;
    const pushF = () => { fields.push(cur); cur = ''; };
    const pushR = () => { pushF(); if (fields.length > 1 || fields[0] !== '') records.push([...fields]); fields = []; };
    while (i < raw.length) {
      const ch = raw[i];
      if (ch === '"') {
        if (!inQ) { inQ = true; i++; continue; }
        if (raw[i+1] === '"') { cur += '"'; i += 2; continue; }
        inQ = false; i++; continue;
      }
      if (!inQ) {
        if (ch === ',') { pushF(); i++; continue; }
        if (ch === '\r' && raw[i+1] === '\n') { pushR(); i += 2; continue; }
        if (ch === '\n') { pushR(); i++; continue; }
      }
      cur += ch; i++;
    }
    if (fields.length || cur) pushR();
    return records;
  }

  /* 공통 유틸: 한국어 날짜/ms → ms 타임스탬프 */
  function _parseKoDate(s) {
    if (!s) return null;
    s = s.trim();
    if (/^\d{12,}$/.test(s)) return Number(s);
    const m = s.match(/(\d{4})[.\-/\s]+(\d{1,2})[.\-/\s]+(\d{1,2})[.\s]*(?:(\d{1,2}):(\d{2}))?/);
    if (m) {
      const iso = `${m[1]}-${m[2].padStart(2,'0')}-${m[3].padStart(2,'0')}T${(m[4]||'00').padStart(2,'0')}:${(m[5]||'00')}:00+09:00`;
      const d = new Date(iso);
      return isNaN(d) ? null : d.getTime();
    }
    const d = new Date(s);
    return isNaN(d) ? null : d.getTime();
  }

  /* 공통 유틸: fetch 직접 POST (SB.insert 옵션 검증 우회) */
  async function _directInsert(table, data) {
    const res = await fetch(`tables/${table}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });
    if (!res.ok) {
      let msg = `HTTP ${res.status}`;
      try { const j = await res.json(); msg = j.message || j.error || msg; } catch(_) {}
      throw new Error(msg);
    }
    return res.json();
  }

  async function importAppsFromCSV(input) {
    const file = input.files[0];
    if (!file) return;
    input.value = '';

    const records = _parseCSV(await file.text());
    if (records.length < 2) { Toast.show('CSV가 비어있습니다.', 'error'); return; }

    const headers = records[0].map(h => h.trim());
    const ci = n => headers.indexOf(n);

    const ocIdx     = ci('original_created_at');
    const dtIdx     = ci('신청일시');
    const nameIdx   = ci('이름');
    const emailIdx  = ci('이메일');
    const phoneIdx  = ci('전화번호');
    const semIdx    = ci('세미나');
    const sdateIdx  = ci('세미나날짜');
    const methodIdx = ci('결제방법');
    const amtIdx    = ci('금액');
    const statusIdx = ci('상태');
    const memoIdx   = ci('메모');

    if (nameIdx < 0 || semIdx < 0) {
      Toast.show(`헤더 인식 실패: ${headers.slice(0,6).join(' / ')}`, 'error'); return;
    }

    const dataRows = records.slice(1).filter(r => r.some(c => c.trim()));
    const total = dataRows.length;
    if (!confirm(`CSV ${total}건을 DB에 복구합니다.\n동일 이메일+세미나 조합은 건너뜁니다.\n계속하시겠습니까?`)) return;

    const statusEl = document.getElementById('app-restore-status');
    if (statusEl) { statusEl.style.display = 'inline'; statusEl.textContent = 'DB 조회 중...'; }

    // 현재 DB 로드 → 중복 체크
    let existing = [];
    try { existing = await SB.getAll('applications', { limit: 2000 }); } catch(_) {}
    const dupSet = new Set(existing.map(e =>
      `${(e.applicant_email||'').toLowerCase().trim()}|${(e.seminar_title||'').trim()}`
    ));

    let inserted = 0, skipped = 0, failed = 0;
    const errors = [];

    for (let i = 0; i < dataRows.length; i++) {
      const r   = dataRows[i];
      const get = idx => (idx >= 0 && idx < r.length) ? r[idx].trim() : '';

      const name    = get(nameIdx);
      const email   = get(emailIdx).toLowerCase();
      const seminar = get(semIdx);
      if (!name && !seminar) { skipped++; continue; }

      const dupKey = `${email}|${seminar}`;
      if (dupSet.has(dupKey)) { skipped++; continue; }

      // 금액 — 숫자만 추출
      const amount = parseFloat(get(amtIdx).replace(/[^0-9.]/g, '')) || 0;

      // 결제수단 — 원문 그대로 저장 (스키마 옵션 제한 없앴으므로)
      const method = get(methodIdx) || '계좌이체';

      // 결제상태
      const status = get(statusIdx) || '결제대기';

      // 메모: " | " → 개행 변환
      const memo = get(memoIdx).replace(/ \| /g, '\n');

      // 신청일 → ms 타임스탬프
      const dtRaw = get(ocIdx) || get(dtIdx);
      const origTs = _parseKoDate(dtRaw);

      try {
        await _directInsert('applications', {
          applicant_name:  name,
          applicant_email: get(emailIdx),   // 원문 그대로 저장
          applicant_phone: get(phoneIdx),
          seminar_title:   seminar,
          seminar_date:    get(sdateIdx),
          payment_method:  method,
          payment_amount:  amount,
          payment_status:  status,
          memo:            memo,
          ...(origTs ? { original_created_at: origTs } : {})
        });
        inserted++;
        dupSet.add(dupKey);
      } catch(e) {
        console.error('[importAppsCSV] row', i + 2, e.message);
        errors.push(`행${i+2}(${name}): ${e.message}`);
        failed++;
      }

      if ((i + 1) % 5 === 0 && statusEl)
        statusEl.textContent = `복구 중… ${i+1}/${total}`;
    }

    if (statusEl) statusEl.style.display = 'none';
    await loadApplications();

    const errTail = errors.length
      ? `\n\n[오류 상세]\n${errors.slice(0, 5).join('\n')}${errors.length > 5 ? `\n…외 ${errors.length-5}건` : ''}`
      : '';
    Toast.show(`복구: 삽입 ${inserted} / 건너뜀 ${skipped} / 실패 ${failed}`, failed ? 'error' : 'success');
    alert(`📋 CSV 복구 결과\n\n✅ 삽입 완료: ${inserted}건\n⏭ 중복 건너뜀: ${skipped}건\n❌ 실패: ${failed}건\n\n총 ${total}건 처리${errTail}`);
  }

