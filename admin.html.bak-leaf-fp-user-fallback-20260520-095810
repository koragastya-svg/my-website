    if (allCategories.find(c => c.name === name)) { Toast.show('이미 존재하는 카테고리입니다.', 'error'); return; }
    const key = 'seminar_cat_' + Date.now();
    const created = await SB.insert('site_content', { key, content: name, label: name, section: 'seminar_category', sort_order: 0 });
    siteContentMap[key] = { id: created.id, content: name };
    Toast.show(`'${name}' 카테고리가 추가되었습니다.`, 'success');
    closeCatModal();
    await loadCategories();
