  /* ── 신청자 엑셀(CSV) 다운로드 ── */
  function exportDashAppsExcel() {
    const semId = document.getElementById('dash-seminar-filter').value;
    if (!semId) { Toast.show('세미나를 먼저 선택해주세요.', 'error'); return; }
    const statusFilter = document.getElementById('dash-status-filter').value;
    let list = statusFilter ? dashAppsRaw.filter(a => a.payment_status === statusFilter) : [...dashAppsRaw];
    list.sort((a,b) => (b.created_at||0) - (a.created_at||0));

    const sem = allSeminars.find(s => s.id === semId);
    const semTitle = sem ? sem.title : '세미나';

    const header = ['신청일시', '이름', '이메일', '전화번호', '결제방법', '금액', '상태', '메모'];
    const rows = list.map(a => [
      a.created_at ? new Date(a.created_at).toLocaleDateString('ko-KR') + ' ' + new Date(a.created_at).toLocaleTimeString('ko-KR',{hour:'2-digit',minute:'2-digit',hour12:false}) : '-',
      a.applicant_name || '-',
      a.applicant_email || '-',
      a.applicant_phone || '-',
      a.payment_method || '-',
      a.payment_amount || 0,
      a.payment_status || '-',
      (a.memo || '').replace(/\n/g, ' | ')
    ]);

    // BOM + CSV
    const BOM = '\uFEFF';
    const csv = BOM + [header, ...rows].map(r =>
      r.map(c => `"${String(c).replace(/"/g,'""')}"`).join(',')
    ).join('\n');

    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    const today = new Date().toISOString().slice(0,10);
    a.download = `신청자_${semTitle}_${today}.csv`;
    a.click();
    URL.revokeObjectURL(url);
    Toast.show('엑셀(CSV) 파일이 다운로드되었습니다.', 'success');
  }

