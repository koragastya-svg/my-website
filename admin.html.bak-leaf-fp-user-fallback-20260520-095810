  /* 신청 내역 정렬: 드롭다운 선택 기준 */
  function _sortApps(apps) {
    const key = (document.getElementById('app-sort-key')||{}).value || 'created_at_desc';
    const list = [...apps];
    // original_created_at 우선 사용
    const toMs = a => {
      const v = appCreatedAt(a);
      if (!v) return 0;
      if (typeof v === 'string' && v.includes('-') && v.length > 8) return new Date(v).getTime();
      return Number(v) || 0;
    };
    if (key === 'created_at_asc')  return list.sort((a,b) => toMs(a) - toMs(b));
    if (key === 'name_asc')        return list.sort((a,b) => (a.applicant_name||'').localeCompare(b.applicant_name||'', 'ko'));
    if (key === 'amount_desc')     return list.sort((a,b) => (b.payment_amount||0) - (a.payment_amount||0));
    if (key === 'amount_asc')      return list.sort((a,b) => (a.payment_amount||0) - (b.payment_amount||0));
    return list.sort((a,b) => toMs(b) - toMs(a)); // 기본: 최신순
  }

