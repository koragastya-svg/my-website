                    oninput="updateSurveyOption('${f.id}',${oi},'extraPrice',parseInt(this.value)||0)" placeholder="0" min="0" step="1000">
                  <span style="font-size:0.72rem;color:var(--text-light);">원</span>
                </div>` : ''}
              <button onclick="removeSurveyOption('${f.id}',${oi})" title="삭제" style="color:#bbb;background:none;border:none;cursor:pointer;font-size:0.9rem;flex-shrink:0;">✕</button>
            </div>`).join('')}
          <button class="btn btn--sm btn--outline" style="font-size:0.75rem;margin-top:4px;width:fit-content;" onclick="addSurveyOption('${f.id}')">+ 옵션 추가</button>
        </div>` : '';
      const previewHtml = !hasOptions ? `
        <div style="margin-top:8px;">
          ${f.type==='textarea' ? `<textarea disabled style="width:100%;min-height:50px;border:1px solid var(--border);border-radius:4px;padding:6px 8px;font-size:0.8rem;color:#bbb;resize:none;box-sizing:border-box;" placeholder="장문 답변 영역"></textarea>`
          : f.type==='date' ? `<input type="date" disabled style="font-size:0.8rem;border:1px solid var(--border);border-radius:4px;padding:5px 8px;width:160px;">`
          : f.type==='number' ? `<input type="number" disabled style="font-size:0.8rem;border:1px solid var(--border);border-radius:4px;padding:5px 8px;width:120px;" placeholder="숫자">`
          : `<input type="text" disabled style="width:100%;border:1px solid var(--border);border-radius:4px;padding:5px 8px;font-size:0.8rem;color:#bbb;box-sizing:border-box;" placeholder="단답 답변 영역">`}
        </div>` : '';
      return `<div class="survey-field-card" data-field-id="${f.id}">
        <div class="survey-field-card__header">
          <span class="survey-field-card__drag" title="드래그하여 순서 변경">⠿</span>
