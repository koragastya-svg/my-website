  /* ════════════════════════════════════════
     신청 폼 커스텀 필드 관리
     site_content key: apply_custom_fields (JSON 배열)
     [{id, label, type('text'|'textarea'|'select'), required, options}]
  ════════════════════════════════════════ */
  let customFields = [];

  function getCustomFieldsFromMap() {
    const raw = (siteContentMap['apply_custom_fields']||{}).content || '';
    try { return raw ? JSON.parse(raw) : getDefaultCustomFields(); }
    catch(e) { return getDefaultCustomFields(); }
  }

  function getDefaultCustomFields() {
    return [
      { id: 'cf_memo', label: '참가 동기 / 문의 사항', type: 'textarea', required: false, options: '' }
    ];
  }

  function renderCustomFields() {
    customFields = getCustomFieldsFromMap();
    const container = document.getElementById('custom-fields-list');
    if (!container) return;
    if (!customFields.length) {
      container.innerHTML = '<p style="font-size:0.82rem;color:var(--text-light);">추가된 필드가 없습니다.</p>';
      return;
    }
    container.innerHTML = customFields.map((f, i) => `
      <div style="display:grid;grid-template-columns:1fr 120px 100px 80px 40px;gap:8px;align-items:center;background:white;border:1px solid var(--border);border-radius:6px;padding:10px 14px;" data-idx="${i}">
        <input type="text" class="form-input" value="${escHtml(f.label)}" placeholder="필드 제목 (예: 참가 동기)"
          oninput="customFields[${i}].label=this.value" style="font-size:0.83rem;">
        <select class="form-select" onchange="customFields[${i}].type=this.value" style="font-size:0.82rem;">
          <option value="text" ${f.type==='text'?'selected':''}>단답형</option>
          <option value="textarea" ${f.type==='textarea'?'selected':''}>장문형</option>
          <option value="select" ${f.type==='select'?'selected':''}>선택형</option>
        </select>
        <input type="text" class="form-input" value="${escHtml(f.options||'')}" placeholder="선택지(쉼표 구분)"
          oninput="customFields[${i}].options=this.value" style="font-size:0.76rem;" title="선택형일 때 옵션을 쉼표로 구분하여 입력">
        <label style="display:flex;align-items:center;gap:6px;font-size:0.8rem;cursor:pointer;white-space:nowrap;">
          <input type="checkbox" ${f.required?'checked':''} onchange="customFields[${i}].required=this.checked" style="accent-color:var(--gold);">
          필수
        </label>
        <button onclick="removeCustomField(${i})" style="background:none;border:none;cursor:pointer;color:#c53030;font-size:1.2rem;line-height:1;padding:0;" title="삭제">×</button>
      </div>`).join('');
  }

  /* applications 신청일 헬퍼 — original_created_at 우선, 없으면 created_at */
  function appCreatedAt(a) {
    return a.original_created_at || a.created_at;
  }

  /* 날짜+시간 포맷 헬퍼 - 모든 형식 처리 (밀리초숫자/ISO문자열/날짜문자열) */
  function formatDateTime(ts) {
    if (ts === null || ts === undefined || ts === '' || ts === 0) return '-';
    let d;
    if (typeof ts === 'number') {
      d = new Date(ts);
    } else if (typeof ts === 'string') {
      // ISO 형식 "2025-04-14T10:30:00.000Z" 또는 숫자문자열 "1713088200000"
      d = isNaN(Number(ts)) ? new Date(ts) : new Date(Number(ts));
    } else {
      d = new Date(ts);
    }
    if (!d || isNaN(d.getTime()) || d.getFullYear() < 2000) return '-';
    const date = d.toLocaleDateString('ko-KR', { year:'numeric', month:'2-digit', day:'2-digit' });
    const time = d.toLocaleTimeString('ko-KR', { hour:'2-digit', minute:'2-digit', hour12: false });
    return `${date} ${time}`;
  }

  function escHtml(str) {
    return String(str||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function addCustomField() {
    customFields.push({ id: 'cf_' + Date.now(), label: '', type: 'text', required: false, options: '' });
    renderCustomFields();
    // 마지막 입력창에 포커스
    const inputs = document.querySelectorAll('#custom-fields-list input[type="text"]');
    if (inputs.length) inputs[inputs.length - 2]?.focus();
  }

  function removeCustomField(idx) {
    customFields.splice(idx, 1);
    renderCustomFields();
  }

  async function saveCustomFields() {
    // 빈 라벨 필드 제거
    const valid = customFields.filter(f => f.label.trim());
    const json = JSON.stringify(valid);
    const existing = siteContentMap['apply_custom_fields'];
    if (existing) {
      await SB.update('site_content', existing.id, { content: json });
      siteContentMap['apply_custom_fields'].content = json;
    } else {
      const created = await SB.insert('site_content', { key: 'apply_custom_fields', content: json, label: 'apply_custom_fields', section: 'apply', sort_order: 0 });
      siteContentMap['apply_custom_fields'] = { id: created.id, content: json };
    }
    customFields = valid;
    renderCustomFields();
    const badge = document.getElementById('saved-custom-fields');
    if (badge) { badge.classList.add('show'); setTimeout(() => badge.classList.remove('show'), 2500); }
    Toast.show('신청 폼 필드 설정이 저장되었습니다.', 'success');
  }

  function renderSeminarsTable(seminars) {
