  /* ════════════════════════════════════════════════════════
     🌿 리딩 신청 내역 (leaf_readings)
  ════════════════════════════════════════════════════════ */

  /**
   * 표시용 상태 변환
   * ▸ DB 저장값 '결제대기' → 화면 표시 '접수중' (통합)
   * ▸ DB 저장값 '실행완료' → 화면 표시 '종료'   (통합)
   * 저장 시에는 원래 값 그대로 유지하되, UI에서는 이 함수를 통해 표시
   */
  // ════════════════════════════════════════════════════════════
  //  잎 리딩 패키지 표기 공통 헬퍼 (_PKG)
  //  표기 규칙:
  //   - 기본장(1~14장) → 원형숫자로 변환: "기본장 ①+②+③+⑬+⑭"
  //   - 의식/부적 대행 → 텍스트 그대로: "기본장 ①+의식+부적"
  //   - 특별장 → prefix 뒤 공백 + 원형숫자: "별의 과학 ①+②+③"
  //   - 다른 카테고리 혼합 시 " / " 구분: "기본장 ①+② / 별의 과학 ①+② / 조상 ①"
  //   - 모든 숫자(원형숫자) 오름차순 정렬
  // ════════════════════════════════════════════════════════════
  const _PKG = (() => {
    const CIRCLED = ['①','②','③','④','⑤','⑥','⑦','⑧','⑨','⑩',
      '⑪','⑫','⑬','⑭','⑮','⑯','⑰','⑱','⑲','⑳',
      '㉑','㉒','㉓','㉔','㉕','㉖','㉗','㉘','㉙','㉚',
      '㉛','㉜','㉝','㉞','㉟','㊱','㊲','㊳','㊴','㊵',
      '㊶','㊷','㊸','㊹','㊺','㊻','㊼','㊽','㊾','㊿'];
    const CSTR = CIRCLED.join('');

    // chapter key → 정렬 숫자
    const sortVal = (ch) => {
      const n = parseInt(ch);
      if (!isNaN(n) && n >= 1 && n <= 14) return n;
      if (ch === 'ritual_13') return 15;
      if (ch === 'ritual_14') return 16;
      return 99;
    };
    const isBasic = (ch) => sortVal(ch) <= 16;

    // 기본장 번호 → 원형숫자 (1→①, 2→②, ... 14→⑭)
    const numToCircled = (n) => CIRCLED[n - 1] || (n + '장');
    // 기본장 suffix 표기: 숫자는 원형숫자, ritual은 텍스트
    const basicSuffix = (ch) => {
      const n = parseInt(ch);
      if (!isNaN(n) && n >= 1 && n <= 14) return numToCircled(n);
      if (ch === 'ritual_13') return '의식';
      if (ch === 'ritual_14') return '부적';
      return ch;
    };

    // label에서 원형숫자를 앞에서 탐색 → {prefix, suffix}
    const parseLabel = (lbl) => {
      if (!lbl) return { prefix: '', suffix: '' };
      for (let i = 0; i < lbl.length; i++) {
        if (CSTR.includes(lbl[i])) return { prefix: lbl.slice(0, i).trim(), suffix: lbl[i] };
      }
      return { prefix: lbl.trim(), suffix: '' };
    };

    // 그룹핑 핵심 로직 → [{label, text}] 배열 반환 (label=카테고리명, text=조합형 숫자문자열)
    const _buildGroups = (rows, fallbackMap) => {
      const sorted = [...rows].sort((a, b) => sortVal(a.chapter) - sortVal(b.chapter));
      const basics   = sorted.filter(r => isBasic(r.chapter));
      const specials = sorted.filter(r => !isBasic(r.chapter));
      const groups = [];

      // 기본장: "기본장 ①+②+⑬+⑭+의식+부적"
      if (basics.length > 0) {
        const suffixes = basics.map(r => basicSuffix(r.chapter));
        groups.push({ label: '기본장', text: '기본장 ' + suffixes.join('+') });
      }

      // 특별장: prefix별 그룹핑, suffix(원형숫자) 오름차순
      if (specials.length > 0) {
        const pOrder = [], pMap = {};
        specials.forEach(r => {
          const lbl = r.chapter_label || (fallbackMap && fallbackMap[r.chapter]) || r.chapter || '-';
          const { prefix, suffix } = parseLabel(lbl);
          if (!pMap[prefix]) { pMap[prefix] = []; pOrder.push(prefix); }
          if (suffix) pMap[prefix].push(suffix);
        });
        pOrder.forEach(p => {
          pMap[p].sort((a, b) => CIRCLED.indexOf(a) - CIRCLED.indexOf(b));
          const text = p + ' ' + (pMap[p].length > 0 ? pMap[p].join('+') : '');
          groups.push({ label: p, text: text.trim() });
        });
      }
      return groups;
    };

    // rows → 조합형 텍스트 (카테고리 " / " 구분)
    const buildLabel = (rows, fallbackMap) => {
      return _buildGroups(rows, fallbackMap).map(g => g.text).join(' / ');
    };

    // rows → 배지 HTML (카테고리마다 별도 배지, 각 배지 내부 " / " 없음)
    const buildBadgeHtml = (rows, fallbackMap, badgeStyle) => {
      const groups = _buildGroups(rows, fallbackMap);
      const mk = (text) => `<span style="${badgeStyle}">${text}</span>`;
      const sep = `<span style="font-size:0.65rem;color:#94a3b8;padding:0 2px;">/</span>`;
      return groups.map(g => mk(g.text)).join(sep);
    };

    return { sortVal, buildLabel, buildBadgeHtml };
  })();

  function leafDisplayStatus(raw) {
    if (!raw || raw === '결제대기') return '접수중';
    if (raw === '실행완료')        return '종료';
    return raw; // '접수중', '결제완료', '종료', '취소' 그대로
  }

  /** 상태별 인라인 스타일 */
  function leafStatusStyle(s) {
    if (s === '결제완료') return 'background:#d1fae5;color:#065f46;';   // 초록
    if (s === '종료')     return 'background:#e2e8f0;color:#334155;';   // 슬레이트 회색
    if (s === '취소')     return 'background:#fee2e2;color:#991b1b;';   // 빨강
    /* 접수중 */          return 'background:#dbeafe;color:#1e40af;';   // 파랑
  }

  let _allLeafReadings = [];

  async function loadLeafReadings() {
    document.getElementById('leaf-tbody').innerHTML = '<tr class="empty-row"><td colspan="9">로딩 중...</td></tr>';
    try {
      const raw = await SB.getAll('leaf_readings', { limit: 500 });
      _allLeafReadings = raw.filter(r => !r.deleted);
      _allLeafReadings.sort((a,b) => b.created_at - a.created_at);

      // username 매핑 (users 테이블에서 아이디 조회)
      try {
        const users = await SB.getAll('users', { limit: 1000 });
        const uMap = {};
        users.forEach(u => { if (u.id) uMap[u.id] = u.username || u.email || ''; });
        _allLeafReadings.forEach(r => {
          if (r.user_id && uMap[r.user_id]) r.username = uMap[r.user_id];
        });
      } catch(_) { /* username 조회 실패 시 무시 */ }

      // ── 확정날짜 경과 시 자동 '종료' 전환 ──
      // 조건: appointment_date 있음 + 해당 날짜가 오늘 이전 + status가 '결제완료'
      await _autoExpireLeafReadings(_allLeafReadings);

      renderLeafReadingsTable(_allLeafReadings);
    } catch(e) {
      document.getElementById('leaf-tbody').innerHTML = '<tr class="empty-row"><td colspan="9">불러오기 실패</td></tr>';
      console.error('[loadLeafReadings]', e);
    }
  }

  /**
   * 확정날짜가 지난 '결제완료' 건을 자동으로 '종료'로 업데이트
   * (DB 값도 변경해 일관성 유지, 실패해도 무시)
   */
  async function _autoExpireLeafReadings(rows) {
    const today = new Date(); today.setHours(0, 0, 0, 0);
    const toExpire = rows.filter(r => {
      if (!r.appointment_date) return false;
      if (r.payment_status !== '결제완료') return false; // 이미 종료/취소된 건 제외
      const apptD = new Date(r.appointment_date); apptD.setHours(0, 0, 0, 0);
      return apptD < today; // 오늘 이전이면 종료
    });
    if (toExpire.length === 0) return;
    try {
      await Promise.all(
        toExpire.map(r => SB.update('leaf_readings', r.id, { payment_status: '종료' }))
      );
      toExpire.forEach(r => { r.payment_status = '종료'; });
      console.log(`[autoExpire] ${toExpire.length}건 종료 처리`);
    } catch(e) {
      console.warn('[autoExpire] 종료 처리 실패:', e.message);
    }
  }

  function renderLeafReadingsTable(rows) {
    window._filteredLeafRows = rows;

    const chapterLabel = { '1':'1장','13':'13장','14':'14장','ritual_13':'의식대행','ritual_14':'부적대행','other':'기타' };

    if (!rows.length) {
      document.getElementById('leaf-tbody').innerHTML = '<tr class="empty-row"><td colspan="9">리딩 신청 내역이 없습니다.</td></tr>';
      return;
    }

    // ── 같은 user_id + 신청 시각 2분 이내 오차 허용 클러스터링 ──
    // 알고리즘: user_id별로 분리 후, created_at 기준 오름차순 정렬 →
    //           직전 클러스터의 마지막(최대) 시각과 2분 이내면 동일 그룹으로 병합
    const GROUP_GAP_MS = 2 * 60 * 1000; // 2분

    // user_id별 row 분류
    const _byUser = new Map(); // userId → [row, ...]
    const _noUser = [];
    rows.forEach(r => {
      if (r.user_id && r.created_at) {
        if (!_byUser.has(r.user_id)) _byUser.set(r.user_id, []);
        _byUser.get(r.user_id).push(r);
      } else {
        _noUser.push(r);
      }
    });

    // 각 user별 클러스터링
    // 결과: _clusters = [{ key, rows: [...] }, ...]  (key = 클러스터 대표 created_at 기준)
    const _clusters = [];
    _byUser.forEach((userRows, userId) => {
      // created_at 오름차순 정렬
      const sorted = [...userRows].sort((a, b) => (Number(a.created_at)||0) - (Number(b.created_at)||0));
      let curCluster = null;
      let curMaxTs = 0;
      sorted.forEach(r => {
        const ts = Number(r.created_at) || 0;
        if (!curCluster || ts - curMaxTs > GROUP_GAP_MS) {
          // 새 클러스터 시작
          curCluster = { key: userId + '|' + ts, rows: [] };
          _clusters.push(curCluster);
        }
        curCluster.rows.push(r);
        curMaxTs = Math.max(curMaxTs, ts);
      });
    });
    // user_id 없는 단독 행은 각각 별도 클러스터
    _noUser.forEach(r => _clusters.push({ key: r.id, rows: [r] }));

    // 클러스터를 대표 row의 created_at 내림차순으로 정렬 (최신 먼저)
    _clusters.sort((a, b) => {
      const tA = Math.max(...a.rows.map(r => Number(r.created_at)||0));
      const tB = Math.max(...b.rows.map(r => Number(r.created_at)||0));
      return tB - tA;
    });

    // 기존 코드 호환을 위해 _groupMap / _groupOrder 형태로 변환
    const _groupMap = new Map();
    const _groupOrder = [];
    _clusters.forEach(c => {
      _groupMap.set(c.key, c.rows);
      _groupOrder.push(c.key);
    });

    const BADGE_BASE = 'display:inline-block;font-size:0.69rem;padding:3px 4px;border-radius:5px;font-weight:700;white-space:nowrap;letter-spacing:.02em;min-width:62px;text-align:center;box-sizing:border-box;';

    let html = '';
    let rowIdx = 0;
    _groupOrder.forEach(key => {
      const grp = _groupMap.get(key);
      const rep = grp[0]; // 대표 row (상태·날짜·신청자·성별·전화는 대표 사용)
      const bg  = rowIdx % 2 !== 0 ? 'background:rgba(0,0,0,0.018);' : '';
      rowIdx++;

      // ── 신청일시 ──
      let dateStr = '-';
      if (rep.created_at) {
        const d = new Date(Number(rep.created_at) || rep.created_at);
        if (!isNaN(d)) {
          const ymd = d.toLocaleDateString('ko-KR');
          const hm  = d.toLocaleTimeString('ko-KR', { hour:'2-digit', minute:'2-digit', hour12: false });
          dateStr = `<span style="white-space:nowrap;">${ymd}<br><span style="color:var(--text-light);font-size:0.7rem;">${hm}</span></span>`;
        }
      }

      // ── 상태 배지 (대표) ──
      const rawStatus = rep.payment_status || '접수중';
      const status    = leafDisplayStatus(rawStatus);
      const statusBg  = leafStatusStyle(status);
      const statusCell = `<span style="${BADGE_BASE}${statusBg}">${status}</span>`;

      // ── 날짜 열 (대표 appointment_date) ──
      const apptRaw = rep.appointment_date || '';
      let apptCell = '';
      if (!apptRaw) {
        apptCell = `<span style="${BADGE_BASE}background:#fef3c7;color:#92400e;">⏳ 미확정</span>`;
      } else {
        const todayD = new Date(); todayD.setHours(0,0,0,0);
        const apptD  = new Date(apptRaw); apptD.setHours(0,0,0,0);
        const isPast = apptD <= todayD;
        const badgeSt = isPast ? 'background:#e2e8f0;color:#334155;' : 'background:#d1fae5;color:#065f46;';
        const badgeTx = isPast ? '🏁 종료' : '✅ 확정';
        apptCell = `<span style="${BADGE_BASE}${badgeSt}">${badgeTx}</span>`
                 + `<div style="font-size:0.68rem;color:var(--text-mid);margin-top:3px;white-space:nowrap;">${apptRaw}</div>`;
      }

      // ── 패키지 열: 조합형 배지 (_PKG 공통 헬퍼 사용) ──
      const _tblBadgeStyle = 'display:inline-block;font-size:0.7rem;font-weight:700;color:var(--gold);background:rgba(186,117,23,0.1);border-radius:4px;padding:2px 6px;white-space:nowrap;line-height:1.4;';
      const pkgCell = `<div style="display:flex;flex-direction:row;flex-wrap:wrap;gap:2px;align-items:center;overflow:visible;">${_PKG.buildBadgeHtml(grp, chapterLabel, _tblBadgeStyle)}</div>`;

      // ── 체크박스: 정렬된 순서(sortedGrp) 기준으로 id 연결 ──
      const sortedGrp = [...grp].sort((a, b) => (_PKG.sortVal(a.chapter)||99) - (_PKG.sortVal(b.chapter)||99));
      const allIds  = sortedGrp.map(r => r.id).join(',');
      const checkEl = `<input type="checkbox" class="leaf-row-check" value="${rep.id}" data-group-ids="${allIds}" onchange="onLeafRowCheck()">`;

      // ── 상세보기 버튼: 그룹 내 건수 표시 ──
      const btnLabel = grp.length > 1 ? `상세보기 (${grp.length})` : '상세보기';
      const detailBtn = `<button onclick="openLeafDetailGroup('${allIds}')"
        style="font-size:0.72rem;padding:5px 10px;border-radius:5px;border:1.5px solid var(--navy);color:var(--navy);background:#fff;cursor:pointer;white-space:nowrap;font-weight:600;line-height:1;transition:background .15s;"
        onmouseover="this.style.background='var(--navy)';this.style.color='#fff';"
        onmouseout="this.style.background='#fff';this.style.color='var(--navy)';">
        ${btnLabel}
      </button>`;

      // ── 신청자 ──
      const nameHtml = `<div style="font-size:0.82rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
          ${rep.user_name || '-'}${rep.username ? `<span style="font-size:0.66rem;color:var(--gold);margin-left:3px;font-weight:400;">@${rep.username}</span>` : ''}
        </div>
        <div style="font-size:0.69rem;color:var(--text-light);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${rep.user_email || ''}</div>`;

      html += `<tr data-id="${rep.id}" data-group-ids="${allIds}"${bg ? ` style="${bg}"` : ''}>
        <td>${checkEl}</td>
        <td style="text-align:center;">${statusCell}</td>
        <td style="text-align:center;">${apptCell}</td>
        <td style="font-size:0.74rem;line-height:1.55;">${dateStr}</td>
        <td>${nameHtml}</td>
        <td style="font-size:0.78rem;white-space:nowrap;">${rep.gender || '-'}</td>
        <td style="font-size:0.74rem;white-space:nowrap;">${rep.user_phone || '-'}</td>
        <td style="overflow:visible;">${pkgCell}</td>
        <td style="overflow:visible;">${detailBtn}</td>
      </tr>`;
    });

    document.getElementById('leaf-tbody').innerHTML = html;
  }

  // 그룹 상세보기: 그룹 내 모든 row를 단일 모달에 한번에 표시
  function openLeafDetailGroup(allIdsStr) {
    const ids = allIdsStr.split(',').filter(Boolean);
    if (ids.length === 1) { openLeafDetail(ids[0]); return; }

    // ── 오름차순 정렬: 기본장은 장번호, 특별장은 chapter_label의 원형숫자 인덱스 ──
    const _GRP_CIRCLED = '①②③④⑤⑥⑦⑧⑨⑩⑪⑫⑬⑭⑮⑯⑰⑱⑲⑳㉑㉒㉓㉔㉕㉖㉗㉘㉙㉚㉛㉜㉝㉞㉟㊱㊲㊳㊴㊵㊶㊷㊸㊹㊺㊻㊼㊽㊾㊿';
    const _GRP_SORT = (r) => {
      const n = parseInt(r.chapter);
      if (!isNaN(n) && n >= 1 && n <= 14) return n;          // 기본장: 1~14
      if (r.chapter === 'ritual_13') return 15;
      if (r.chapter === 'ritual_14') return 16;
      // 특별장: chapter_label에서 원형숫자 찾아 인덱스로 정렬
      const lbl = r.chapter_label || '';
      for (let i = 0; i < lbl.length; i++) {
        const ci = _GRP_CIRCLED.indexOf(lbl[i]);
        if (ci >= 0) return 100 + ci; // 특별장은 100+인덱스
      }
      return 999;
    };
    const rows = ids.map(id => _allLeafReadings.find(x => x.id === id)).filter(Boolean)
                    .sort((a,b) => _GRP_SORT(a) - _GRP_SORT(b));
    if (rows.length === 0) return;

    const rep = rows[0]; // 신청자 공통 정보 대표 row

    // 기존 모달 제거
    const prev = document.getElementById('leaf-detail-modal');
    if (prev) prev.remove();

    // ── 패키지별 카드 HTML 생성 ──
    const _chLabelFallbackGrp = { '1':'1장','13':'13장','14':'14장','ritual_13':'의식 대행','ritual_14':'부적 대행','other':'기타' };

    // ── 차수 계산: 같은 user_id + chapter 기준, 취소 제외, created_at 오름차순 몇 번째인지 ──
    const _getChapterOrder = (r) => {
      const sameChapter = (_allLeafReadings || [])
        .filter(x => x.user_id === r.user_id && x.chapter === r.chapter && x.payment_status !== '취소')
        .sort((a, b) => Number(a.created_at || 0) - Number(b.created_at || 0));
      const idx = sameChapter.findIndex(x => x.id === r.id);
      return idx >= 0 ? idx + 1 : 1; // 1부터 시작
    };

    const pkgCardsHtml = rows.map((r, i) => {
      const rawStatus = r.payment_status || '접수중';
      const status    = leafDisplayStatus(rawStatus);
      const statusBg  = leafStatusStyle(status);
      // chapter_label 파싱: 원형숫자 또는 '장' 다음 공백 기준으로 짧은이름/풀이름 분리
      // 예) "별의 과학④ 나크샤트라" → chName="별의 과학④", chTitle="나크샤트라"
      // 예) "2장 가족 리딩" → chName="2장", chTitle="가족 리딩"
      const _CIRCLED_STR = '①②③④⑤⑥⑦⑧⑨⑩⑪⑫⑬⑭⑮⑯⑰⑱⑲⑳㉑㉒㉓㉔㉕㉖㉗㉘㉙㉚㉛㉜㉝㉞㉟㊱㊲㊳㊴㊵㊶㊷㊸㊹㊺㊻㊼㊽㊾㊿';
      const _splitLabel = (lbl) => {
        if (!lbl) return { short: '', full: '' };
        // 1) 원형숫자 다음 공백
        for (let i = 0; i < lbl.length; i++) {
          if (_CIRCLED_STR.includes(lbl[i]) && lbl[i+1] === ' ') {
            return { short: lbl.slice(0, i+1).trim(), full: lbl.slice(i+2).trim() };
          }
        }
        // 2) '장' 다음 공백 (기본장: "2장 가족 리딩")
        const jangIdx = lbl.indexOf('장 ');
        if (jangIdx >= 0) {
          return { short: lbl.slice(0, jangIdx+1).trim(), full: lbl.slice(jangIdx+2).trim() };
        }
        return { short: lbl.trim(), full: '' };
      };
      const _rawLabel = r.chapter_label || _chLabelFallbackGrp[r.chapter] || r.chapter || '-';
      const _parsed   = _splitLabel(_rawLabel);
      const chName    = _parsed.short || _rawLabel;
      const chTitle   = r.chapter_title || _parsed.full || '';

      // 차수 계산 (1차면 뱃지 없음, 2차 이상만 표시)
      const chOrder = _getChapterOrder(r);
      const orderBadge = chOrder >= 2
        ? `<span style="font-size:0.62rem;font-weight:700;background:#fef3c7;color:#92400e;border-radius:4px;padding:1px 6px;flex-shrink:0;">${chOrder}차</span>`
        : '';

      const appt = r.appointment_date || '';
      let dateBadgeText, dateBadgeCss, dateValText;
      if (!appt) {
        dateBadgeText = '⏳ 미확정'; dateBadgeCss = 'background:#fef3c7;color:#92400e;'; dateValText = '-';
      } else {
        const todayD = new Date(); todayD.setHours(0,0,0,0);
        const apptD  = new Date(appt); apptD.setHours(0,0,0,0);
        if (apptD > todayD) {
          dateBadgeText = '✅ 확정'; dateBadgeCss = 'background:#d1fae5;color:#065f46;'; dateValText = appt;
        } else {
          dateBadgeText = '🏁 종료'; dateBadgeCss = 'background:#e2e8f0;color:#334155;'; dateValText = appt;
        }
      }

      // 알림톡 버튼 가능 여부
      const isRitual = r.chapter === 'ritual_13' || r.chapter === 'ritual_14';
      const canKakao = r.payment_status === '접수중' || r.payment_status === '결제완료' || r.payment_status === '실행완료' || isRitual;

      return `
      <div id="grp-card-${r.id}" style="border:1.5px solid #e2e8f0;border-radius:10px;overflow:hidden;background:#fff;">

        <!-- 카드 헤더 -->
        <div style="display:flex;align-items:center;gap:8px;padding:9px 14px;background:#f8faff;border-bottom:1px solid #e2e8f0;">
          <div style="flex:1;min-width:0;">
            <div style="display:flex;align-items:center;gap:5px;flex-wrap:wrap;">
              <span style="font-size:0.9rem;font-weight:800;color:var(--gold);line-height:1.2;">${chName}</span>
              ${orderBadge}
            </div>
            ${chTitle ? `<div style="font-size:0.71rem;color:#6b7280;font-weight:400;margin-top:2px;line-height:1.4;">${chTitle}</div>` : ''}
          </div>
          <div style="display:flex;align-items:center;gap:4px;flex-shrink:0;">
            <span style="font-size:0.68rem;padding:2px 8px;border-radius:20px;font-weight:700;${statusBg}">${status}</span>
            <span style="font-size:0.68rem;padding:2px 7px;border-radius:10px;font-weight:700;${dateBadgeCss}">${dateBadgeText}</span>
            <span style="font-size:0.62rem;color:#94a3b8;">ID: ${r.id.slice(0,8)}…</span>
          </div>
        </div>

        <!-- 카드 바디 -->
        <div style="padding:10px 14px;display:grid;gap:8px;">

          <!-- 상태 변경 + 패키지 변경 -->
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
            <div style="background:#f8f9fb;border-radius:7px;padding:8px 10px;display:flex;flex-direction:column;gap:5px;">
              <div style="font-size:0.62rem;font-weight:700;color:var(--text-light);text-transform:uppercase;letter-spacing:.04em;">상태 변경</div>
              <div class="grp-custom-sel">
                <select id="grp-status-sel-${r.id}">
                  <option value="">-- 선택 --</option>
                  <option value="접수중"  ${status==='접수중' ?'selected':''}>접수중</option>
                  <option value="결제완료" ${status==='결제완료'?'selected':''}>결제완료</option>
                  <option value="종료"    ${status==='종료'   ?'selected':''}>종료</option>
                  <option value="취소"    ${status==='취소'   ?'selected':''}>취소</option>
                </select>
              </div>
              <button onclick="applyGrpStatus('${r.id}')"
                style="width:100%;height:32px;border-radius:5px;background:var(--navy);color:#fff;border:none;font-size:0.74rem;font-weight:600;cursor:pointer;line-height:1;">
                상태 저장
