      return;
    }
    // super-advisor 패널: username 'admin' 계정만 접근 허용
    if (name === 'super-advisor' && _sess.username !== 'admin') {
      Toast && Toast.show('Super Advisor 패널은 최고관리자만 접근할 수 있습니다.', 'error');
      return;
    }

    document.querySelectorAll('.admin-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.admin-nav-item').forEach(i => i.classList.remove('active'));
    const panel = document.getElementById(`panel-${name}`);
    if (panel) { panel.classList.add('active'); panel.style.removeProperty('display'); }
