  async function promoteUser() {
    const uname = document.getElementById('promote-username').value.trim();
    if (!uname) { Toast.show('아이디를 입력해주세요.', 'error'); return; }
    try {
      // Supabase 직접: 전체 사용자 로드
      const allUsersForCheck = await SB.getAll('users', { limit: 500, order: 'created_at.asc' });
      const activeUsersForCheck = allUsersForCheck.filter(u => !u.deleted);
      const latestAdmins = activeUsersForCheck.filter(u => u.role === 'admin' || u.role === 'superadmin');
      const _maxP = _currentMaxAdmins || await getMaxAdmins();
      if (latestAdmins.length >= _maxP) { Toast.show(`관리자는 최대 ${_maxP}명까지 등록 가능합니다.`, 'error'); return; }

      // username 기준으로 찾기 (삭제된 계정 제외)
      let user = activeUsersForCheck.find(u => u.username === uname);
      if (!user) {
        // findOne으로 재시도
        const found = await SB.findOne('users', 'username', uname);
        if (found && !found.deleted) user = found;
      }

      if (!user) {
        Toast.show('해당 아이디의 회원을 찾을 수 없습니다. 아이디를 정확히 입력해주세요.', 'error');
        return;
      }
      if (user.role === 'admin' || user.role === 'superadmin') { Toast.show('이미 관리자 계정입니다.', 'error'); return; }

      // Supabase 직접 PATCH
      await SB.update('users', user.id, { role: 'admin' });
      Toast.show(`✅ ${user.name || uname}(${uname})에게 관리자 권한이 부여되었습니다.`, 'success');
      closeAdminModal();
      loadAdminAccounts();
    } catch(e) {
      console.error('promoteUser error:', e);
      Toast.show('오류: ' + e.message, 'error');
    }
  }

  async function createAdminAccount() {
    const name = document.getElementById('new-admin-name').value.trim();
    const username = document.getElementById('new-admin-username').value.trim();
    const email = document.getElementById('new-admin-email').value.trim();
    const pw = document.getElementById('new-admin-pw').value;
    if (!name || !username || !email || !pw) { Toast.show('모든 항목을 입력해주세요.', 'error'); return; }
    if (pw.length < 6) { Toast.show('비밀번호는 6자 이상이어야 합니다.', 'error'); return; }
    try {
      // Supabase 직접: 최신 사용자 로드
      const latestUsers = await SB.getAll('users', { limit: 500, order: 'created_at.asc' });
      const activeLatestUsers = latestUsers.filter(u => !u.deleted);
      const latestAdmins = activeLatestUsers.filter(u => u.role === 'admin' || u.role === 'superadmin');
      const _maxC = _currentMaxAdmins || await getMaxAdmins();
      if (latestAdmins.length >= _maxC) { Toast.show(`관리자는 최대 ${_maxC}명까지 등록 가능합니다.`, 'error'); return; }
      // 소프트딜리트 제외하고 중복 체크
      if (activeLatestUsers.find(u => u.username === username)) { Toast.show('이미 사용 중인 아이디입니다.', 'error'); return; }
      // PBKDF2 해싱
      const salt = Array.from(crypto.getRandomValues(new Uint8Array(16))).map(b=>b.toString(16).padStart(2,'0')).join('');
      const enc = new TextEncoder();
      const key = await crypto.subtle.importKey('raw', enc.encode(pw), 'PBKDF2', false, ['deriveBits']);
      const bits = await crypto.subtle.deriveBits({ name:'PBKDF2', hash:'SHA-256', salt: enc.encode(salt), iterations:100000 }, key, 256);
      const hex = Array.from(new Uint8Array(bits)).map(b=>b.toString(16).padStart(2,'0')).join('');
      const hash = 'pbkdf2:' + salt + ':' + hex;
      // Supabase 직접 INSERT
      await SB.insert('users', { name, username, email, password_hash: hash, role: 'admin', is_active: true, reset_code:'', reset_code_expires:'' });
      Toast.show(`관리자 계정 '${name}'이 생성되었습니다.`, 'success');
      closeAdminModal(); loadAdminAccounts();
    } catch(e) { Toast.show('오류: ' + e.message, 'error'); }
  }

