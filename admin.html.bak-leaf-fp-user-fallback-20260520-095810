  async function saveSaServices() {
    const btn = document.getElementById('btn-save-saved-sa-services');
    if (btn) { btn.disabled = true; btn.textContent = '저장 중...'; }
    try {
      const map = await fetchSaMap();
      const items = document.querySelectorAll('#sa-service-list .sa-svc-item');

      // ── 현재 UI에 남아있는 extra 슬러그 목록 ──
      const activeExtraSlugs = new Set();
      items.forEach(item => {
        const slug = item.getAttribute('data-slug');
        if (slug && slug.startsWith('extra_')) activeExtraSlugs.add(slug);
      });

      // ── DB에 존재하는 extra 슬러그 목록 파악 ──
      const dbExtraSlugs = new Set();
      let n = 1;
      while (map['service_extra_' + n + '_title']) {
        dbExtraSlugs.add('extra_' + n);
        n++;
      }

      // ── DB에는 있지만 UI에 없는 extra → 삭제 ──
      const delPromises = [];
      dbExtraSlugs.forEach(slug => {
        if (!activeExtraSlugs.has(slug)) {
          ['_img','_title','_desc'].forEach(suffix => {
            const key = 'service_' + slug + suffix;
            const entry = map[key];
            if (entry && entry.id) {
              delPromises.push(SB.remove('site_content', entry.id));
            }
          });
        }
      });
      if (delPromises.length) await Promise.all(delPromises);

      // ── 남아있는 extra 항목을 1번부터 재정렬 저장 ──
      // (번호에 공백이 생기지 않도록)
      const extraItems = Array.from(items).filter(item => item.getAttribute('data-slug').startsWith('extra_'));
      const reSaves = [];
      extraItems.forEach((item, idx) => {
        const newSlug = 'extra_' + (idx + 1);
        item.setAttribute('data-slug', newSlug);
        const imgEl   = item.querySelector('.svc-img-url');
        const titleEl = item.querySelector('.svc-title');
        const descEl  = item.querySelector('.svc-desc');
        if (imgEl)   reSaves.push(saUpsert(map, 'service_' + newSlug + '_img',   imgEl.value));
        if (titleEl) reSaves.push(saUpsert(map, 'service_' + newSlug + '_title', titleEl.value));
        if (descEl)  reSaves.push(saUpsert(map, 'service_' + newSlug + '_desc',  descEl.value));
      });

      // ── 기본 6개 저장 (카드 필드 + MORE 상세 필드) ──
      const saves = [];
      items.forEach(item => {
        const slug = item.getAttribute('data-slug');
        if (slug.startsWith('extra_')) return; // 위에서 처리
        const imgEl   = item.querySelector('.svc-img-url');
        const titleEl = item.querySelector('.svc-title');
        const descEl  = item.querySelector('.svc-desc');
        if (imgEl)   saves.push(saUpsert(map, 'service_' + slug + '_img',   imgEl.value));
        if (titleEl) saves.push(saUpsert(map, 'service_' + slug + '_title', titleEl.value));
        if (descEl)  saves.push(saUpsert(map, 'service_' + slug + '_desc',  descEl.value));
      });

      // ── extra 재정렬 시 body도 저장 ──
      extraItems.forEach((item, idx) => {
        const newSlug = 'extra_' + (idx + 1);
        const bodyEl  = item.querySelector('.svc-body');
        if (bodyEl) reSaves.push(saUpsert(map, 'service_' + newSlug + '_body', bodyEl.value));
      });

      await Promise.all([...saves, ...reSaves]);
      showSaBadge('saved-sa-services');
      Toast.show('✅ 서비스 저장 완료!', 'success');
      // 저장 후 목록 새로고침
      const freshMap = await fetchSaMap();
      renderSaServiceList(freshMap);
    } catch(e) {
      Toast.show('❌ 서비스 저장 실패: ' + e.message, 'error');
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = '저장'; }
    }
  }

