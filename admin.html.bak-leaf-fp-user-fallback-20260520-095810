  /* ════ 멀티 날짜 달력 ════ */
  let _slotCalYear  = new Date().getFullYear();
  let _slotCalMonth = new Date().getMonth(); // 0-based
  let _slotSelDates = new Set(); // 'YYYY-MM-DD' 집합

  function _slotCalRender() {
    const label = document.getElementById('slot-cal-label');
    const grid  = document.getElementById('slot-cal-grid');
    if (!label || !grid) return;

    const y = _slotCalYear, m = _slotCalMonth;
    const monthNames = ['1월','2월','3월','4월','5월','6월','7월','8월','9월','10월','11월','12월'];
    label.textContent = y + '년 ' + monthNames[m];

    const firstDay = new Date(y, m, 1).getDay(); // 0=일
    const lastDate = new Date(y, m + 1, 0).getDate();
    const today = new Date().toISOString().slice(0, 10);

    let html = '';
    // 앞 빈칸
    for (let i = 0; i < firstDay; i++) {
      html += `<div></div>`;
    }
    for (let d = 1; d <= lastDate; d++) {
      const mm = String(m + 1).padStart(2, '0');
      const dd = String(d).padStart(2, '0');
      const dateStr = `${y}-${mm}-${dd}`;
      const dow = new Date(y, m, d).getDay();
      const isSelected = _slotSelDates.has(dateStr);
      const isToday = dateStr === today;
      const isSun = dow === 0, isSat = dow === 6;

      const bg    = isSelected ? 'var(--gold)' : 'transparent';
      const color = isSelected ? 'white' : isSun ? '#e53e3e' : isSat ? '#1d4ed8' : 'var(--text-dark)';
      const fw    = isSelected || isToday ? '700' : '400';
      const ring  = isToday && !isSelected ? '1px solid var(--gold)' : 'none';

      html += `<div onclick="slotCalToggle('${dateStr}')"
        style="text-align:center;font-size:0.92rem;padding:8px 4px;border-radius:7px;cursor:pointer;
               background:${bg};color:${color};font-weight:${fw};outline:${ring};
               transition:background 0.12s;min-height:40px;display:flex;align-items:center;justify-content:center;"
        onmouseover="if(!${isSelected})this.style.background='#f0ede8'"
        onmouseout="if(!${isSelected})this.style.background='transparent'"
      >${d}</div>`;
    }
    grid.innerHTML = html;
    _slotCalUpdateTags();
  }

  function slotCalToggle(dateStr) {
    if (_slotSelDates.has(dateStr)) {
      _slotSelDates.delete(dateStr);
    } else {
      _slotSelDates.add(dateStr);
    }
    _slotCalRender();
  }

  function slotCalPrev() {
    _slotCalMonth--;
    if (_slotCalMonth < 0) { _slotCalMonth = 11; _slotCalYear--; }
    _slotCalRender();
  }

  function slotCalNext() {
    _slotCalMonth++;
    if (_slotCalMonth > 11) { _slotCalMonth = 0; _slotCalYear++; }
    _slotCalRender();
  }

  function slotCalClearAll() {
    _slotSelDates.clear();
    _slotCalRender();
  }

  function _slotCalUpdateTags() {
    const wrap    = document.getElementById('slot-selected-dates');
    const countEl = document.getElementById('slot-date-count');
    const noMsg   = document.getElementById('slot-no-date-msg');
    if (!wrap) return;
    const sorted = [..._slotSelDates].sort();
    if (countEl) countEl.textContent = sorted.length;
    if (sorted.length === 0) {
      wrap.innerHTML = '<span style="font-size:0.75rem;color:var(--text-light);padding:4px 0;" id="slot-no-date-msg">날짜를 선택하세요</span>';
      return;
    }
    wrap.innerHTML = sorted.map(d => {
      const [y, m, dd] = d.split('-');
      const dow = ['일','월','화','수','목','금','토'][new Date(d).getDay()];
      const color = new Date(d).getDay() === 0 ? '#e53e3e' : new Date(d).getDay() === 6 ? '#1d4ed8' : 'var(--navy)';
      return `<span style="display:inline-flex;align-items:center;gap:4px;font-size:0.74rem;background:white;
                border:1px solid var(--border);border-radius:20px;padding:3px 10px;color:${color};">
        ${m}/${dd}(${dow})
        <button type="button" onclick="slotCalToggle('${d}')"
          style="background:none;border:none;cursor:pointer;font-size:0.7rem;color:#9ca3af;padding:0;line-height:1;">✕</button>
      </span>`;
    }).join('');
  }

