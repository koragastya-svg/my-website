  /* ── 섹션 저장 ── */
  async function saveSection(keys, savedBadgeId) {
    try {
      const promises = keys.map(async (key) => {
        const el = document.getElementById(`cf-${key}`);
        if (!el) return;
        const newContent = el.value;
        const existing = siteContentMap[key];
        if (existing) {
          await SB.update('site_content', existing.id, { content: newContent });
          siteContentMap[key].content = newContent;
        } else {
          const created = await SB.insert('site_content', { key, content: newContent, label: key, section: key.split('_')[0], sort_order: 0 });
          siteContentMap[key] = { id: created.id, content: newContent };
        }
      });
      await Promise.all(promises);
      const badge = document.getElementById(savedBadgeId);
      if (badge) {
        badge.classList.add('show');
        setTimeout(() => badge.classList.remove('show'), 2500);
      }
    } catch(e) {
      Toast.show('저장 중 오류가 발생했습니다.', 'error');
    }
  }

