  async function dbImportAll(input) {
    const file = input.files[0];
    if (!file) return;
    if (!confirm(
      'JSON 백업 파일을 가져옵니다.\n\n' +
      '• site_content(페이지 콘텐츠): key 기준으로 덮어쓰기\n' +
      '• 나머지 테이블: 신규 항목만 추가(중복 ID 건너뜀)\n\n' +
      '계속할까요?'
    )) { input.value = ''; return; }
    dbLogClear();
    try {
      const text = await file.text();
      const backup = JSON.parse(text);
      if (!backup.tables) throw new Error('올바른 백업 파일이 아닙니다.');
      dbLog(`⏳ 복원 시작... (버전 ${backup.version || 1}, 내보낸 시각: ${backup.exported_at || '알 수 없음'})`);

      /* ── ① site_content: key 기준 upsert (재배포 후 ID가 달라져도 콘텐츠 복원 보장) ── */
      const scRows = backup.tables['site_content'];
      if (scRows && scRows.length > 0) {
        dbLog(`✏️ site_content(페이지 콘텐츠) 복원 중... (${scRows.length}건)`);
        // 현재 DB의 key→id 맵 구성
        const existing = await fetchAllPages('site_content');
        const keyMap = {};
        existing.forEach(r => { if (r.key) keyMap[r.key] = r.id; });
        let upserted = 0, failed = 0;
        for (const row of scRows) {
          if (!row.key) continue;
          const { gs_project_id, gs_table_name, deleted, id, ...fields } = row;
          try {
            if (keyMap[row.key]) {
              // 기존 key 존재 → 콘텐츠 업데이트
              await SB.update('site_content', keyMap[row.key], { content: fields.content });
            } else {
              // 신규 key → 삽입
              await SB.insert('site_content', fields);
            }
            upserted++;
          } catch { failed++; }
        }
        dbLog(`✅ site_content: ${upserted}건 복원, ${failed}건 실패`);
      } else {
        dbLog('⏭ site_content: 데이터 없음');
      }

      /* ── ② 나머지 테이블: ID 기준 신규 삽입 ── */
      const otherTables = [
        'users', 'seminars', 'news', 'inquiries', 'applications',
        'leaf_readings', 'reading_slots', 'special_chapters', 'dimension_access'
      ];
      for (const t of otherTables) {
        const rows = backup.tables[t];
        if (!rows || rows.length === 0) { dbLog(`⏭ ${t}: 데이터 없음`); continue; }
        const existing = await fetchAllPages(t);
        const existingIds = new Set(existing.map(r => r.id));
        let added = 0, skipped = 0;
        for (const row of rows) {
          if (existingIds.has(row.id)) { skipped++; continue; }
          const { gs_project_id, gs_table_name, deleted, ...data } = row;
          // applications / inquiries: created_at 원본값을 original_created_at에 보존
          if ((t === 'applications' || t === 'inquiries') && data.created_at && !data.original_created_at) {
            data.original_created_at = data.created_at;
          }
          try {
            await SB.insert(t, data);
            added++;
          } catch { skipped++; }
        }
        dbLog(`✅ ${t}: ${added}건 추가, ${skipped}건 건너뜀`);
      }

      dbLog('🎉 전체 복원 완료!', '#1a7a4a');
      Toast.show('DB 복원이 완료되었습니다.', 'success');
    } catch(e) {
      dbLog('❌ 오류: ' + e.message, '#c62828');
      Toast.show('복원 실패: ' + e.message, 'error');
    }
    input.value = '';
  }

