  /* ── 신청 자격 UI 토글 (누구나 / 회원 전용) ── */
  function toggleMemberOnlyUI() {
    const isMember = document.getElementById('sm-member-only-radio').checked;
    const openLabel = document.getElementById('sm-member-open-label');
    const memberLabel = document.getElementById('sm-member-only-label');
    const memberNote = document.getElementById('sm-member-only-note');
    openLabel.style.borderColor = isMember ? 'transparent' : 'var(--gold)';
    memberLabel.style.borderColor = isMember ? '#e65100' : 'transparent';
    memberNote.style.display = isMember ? 'block' : 'none';
  }

  /* ── 외부 URL 미리보기 ── */
  document.addEventListener('input', function(e) {
    if (e.target && e.target.id === 'sm-external-url') {
      const val = e.target.value.trim();
      const preview = document.getElementById('sm-ext-url-preview');
      const previewText = document.getElementById('sm-ext-url-preview-text');
      if (val && (val.startsWith('http://') || val.startsWith('https://'))) {
        previewText.textContent = val;
        preview.style.display = 'block';
      } else {
        preview.style.display = 'none';
      }
    }
  });

  function toggleSurveyTypeMenu(e) {
    e.stopPropagation();
    const menu = document.getElementById('survey-type-menu');
    menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
    const close = () => { menu.style.display = 'none'; document.removeEventListener('click', close); };
    setTimeout(() => document.addEventListener('click', close), 0);
  }

  function addSurveyField(type) {
    document.getElementById('survey-type-menu').style.display = 'none';
    const id = 'sf_' + Date.now();
    const hasOpts = type === 'radio' || type === 'checkbox' || type === 'select';
    // options: [{label, extraPrice}] 구조로 확장
    const field = { id, type, label: '', sublabel: '', required: false,
      options: hasOpts ? [{label:'옵션 1', extraPrice:0}] : [],
      hasExtraPrice: false // 추가금 사용 여부 토글
    };
    smSurveyFields.push(field);
    renderSurveyFields(smSurveyFields);
  }

  function renderSurveyFields(fields) {
    smSurveyFields = fields || [];
    const container = document.getElementById('sm-survey-fields');
