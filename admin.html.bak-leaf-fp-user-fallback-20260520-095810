  /* 장별 기준 금액 */
  const LEAF_PRICES = {
    '1': 500000,
    '13': 500000,
    '14': 500000,
    'ritual_13': 2000000,
    'ritual_14': 2000000
  };
  function getLeafPrice(chapter) {
    return LEAF_PRICES[String(chapter)] || 0;
  }

  let _allLeafPayRows = [];

  async function loadLeafPayments() {
    document.getElementById('lp-tbody').innerHTML = '<tr class="empty-row"><td colspan="8">로딩 중…</td></tr>';
    try {
      const raw = await SB.getAll('leaf_readings', { limit: 1000 });
      _allLeafPayRows = raw.filter(r => !r.deleted)
        .sort((a,b) => (b.created_at||0) - (a.created_at||0));
      _renderLeafPayments(_allLeafPayRows);
      _updateLpStats(_allLeafPayRows);
    } catch(e) {
      document.getElementById('lp-tbody').innerHTML = '<tr class="empty-row"><td colspan="8">로드 실패: ' + e.message + '</td></tr>';
    }
  }

  function _updateLpStats(rows) {
    const total   = rows.length;
    const pending = rows.filter(r => r.payment_status === '결제대기').length;
    const done    = rows.filter(r => ['결제완료','실행완료'].includes(r.payment_status)).length;
    const revenue = rows
      .filter(r => ['결제완료','실행완료'].includes(r.payment_status))
      .reduce((s,r) => s + (r.payment_amount || getLeafPrice(r.chapter) || 0), 0);

    document.getElementById('lp-total').textContent   = total;
    document.getElementById('lp-pending').textContent = pending;
    document.getElementById('lp-done').textContent    = done;
    document.getElementById('lp-revenue').textContent = revenue.toLocaleString('ko-KR') + '원';
  }

  function filterLeafPayments() {
    const q  = (document.getElementById('lp-search')||{}).value || '';
    const st = (document.getElementById('lp-status-filter')||{}).value || '';
    const ch = (document.getElementById('lp-chapter-filter')||{}).value || '';
    const f  = _allLeafPayRows.filter(r =>
      (!st || r.payment_status === st) &&
      (!ch || r.chapter === ch) &&
      (!q  || (r.user_name||'').includes(q) || (r.user_email||'').includes(q))
    );
    _renderLeafPayments(f);
  }

  function _renderLeafPayments(rows) {
    const chLabelFn = (ch) => {
      const map = {
        '1':'1장','2':'2장','3':'3장','4':'4장','5':'5장',
        '6':'6장','7':'7장','8':'8장','9':'9장','10':'10장','11':'11장',
        '12':'12장','13':'13장','14':'14장',
        'ritual_13':'의식대행','ritual_14':'부적대행'
      };
      return map[String(ch)] || (ch ? ch : '-');
    };
    const stBadge = { '접수중':'badge--navy','결제대기':'badge--gold','결제완료':'badge--green','실행완료':'badge--green','취소':'badge--red' };
    const fmt = v => Number(v||0).toLocaleString('ko-KR');

    if (!rows.length) {
      document.getElementById('lp-tbody').innerHTML = '<tr class="empty-row"><td colspan="8">결제 내역이 없습니다.</td></tr>';
      return;
    }

    // user_id(없으면 user_name) 기준으로 묶기
    const grouped = {};
    const groupOrder = [];
    rows.forEach(r => {
      const key = r.user_id || ('_name_' + (r.user_name || r.id));
      if (!grouped[key]) { grouped[key] = []; groupOrder.push(key); }
      grouped[key].push(r);
    });

    document.getElementById('lp-tbody').innerHTML = groupOrder.map(key => {
      const grp = grouped[key];
      const rep = grp[0]; // 대표 행 (이름·연락처)

      // 장 목록 칩
      const chipsHtml = grp.map(r => {
        const badge = stBadge[r.payment_status] || 'badge--gray';
        return `<span style="display:inline-flex;align-items:center;gap:3px;background:#fff;border:1px solid #e2c97e;border-radius:4px;padding:2px 7px;font-size:0.7rem;white-space:nowrap;">
          <span style="color:var(--gold);font-weight:700;">${chLabelFn(r.chapter)}</span>
          <span class="badge ${badge}" style="font-size:0.62rem;padding:0 4px;">${r.payment_status||'접수중'}</span>
        </span>`;
      }).join('');

      // 금액 합산 (결제완료·실행완료 row만 합산, 나머지는 기준가 합산)
      const totalPaid = grp.reduce((s,r) => s + (Number(r.payment_amount)||0), 0);
      const totalBase = grp.reduce((s,r) => s + (getLeafPrice(r.chapter)||0), 0);
      const priceHtml = totalPaid
        ? `<strong>${fmt(totalPaid)}원</strong>${totalPaid !== totalBase && totalBase ? `<br><span style="font-size:0.67rem;color:var(--text-light);">기준 ${fmt(totalBase)}원</span>` : ''}`
        : `<span style="color:var(--text-light);font-size:0.77rem;">기준 ${fmt(totalBase)}원</span>`;

      // 날짜: 그룹 내 날짜가 다를 수 있으면 고유값 목록
      const dates = [...new Set(grp.map(r => r.appointment_date).filter(Boolean))];
      const dateHtml = dates.length ? dates.join('<br>') : '<span style="color:var(--text-light);">미정</span>';

      // 결제수단: 그룹 내 첫 번째 값
      const method = grp.find(r => r.payment_method)?.payment_method || '';

      // 결제처리 버튼: 건이 1개면 기존 모달, 여러 건이면 각 행마다 버튼
      const btnHtml = grp.length === 1
        ? `<button class="btn btn--outline btn--sm" style="font-size:0.72rem;" onclick="openLpModal('${grp[0].id}')">💳 결제처리</button>`
        : grp.map(r =>
            `<button class="btn btn--outline btn--sm" style="font-size:0.68rem;margin-bottom:3px;display:block;width:100%;" onclick="openLpModal('${r.id}')">💳 ${chLabelFn(r.chapter)}</button>`
          ).join('');

      return `<tr style="${grp.length > 1 ? 'background:#fffdf5;' : ''}">
        <td>
          <strong style="font-size:0.85rem;">${rep.user_name||'-'}</strong>
          <div style="font-size:0.72rem;color:var(--text-light);">${rep.user_email||''}</div>
          <div style="font-size:0.72rem;color:var(--text-light);">${rep.user_phone||''}</div>
          ${grp.length > 1 ? `<div style="font-size:0.68rem;color:var(--gold);margin-top:2px;">총 ${grp.length}건</div>` : ''}
        </td>
        <td style="vertical-align:top;padding-top:10px;">
          <div style="display:flex;flex-direction:column;gap:3px;">${chipsHtml}</div>
        </td>
        <td style="font-size:0.8rem;">${dateHtml}</td>
        <td style="font-size:0.8rem;">${method||'<span style="color:var(--text-light);">미정</span>'}</td>
        <td style="font-size:0.82rem;">${priceHtml}</td>
        <td>—</td>
        <td style="font-size:0.75rem;color:var(--text-light);white-space:nowrap;">${rep.created_at ? new Date(rep.created_at).toLocaleDateString('ko-KR') : '-'}</td>
        <td style="vertical-align:top;padding-top:8px;">${btnHtml}</td>
      </tr>`;
    }).join('');
  }

