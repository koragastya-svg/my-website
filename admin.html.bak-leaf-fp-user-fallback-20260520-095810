  async function getMaxAdmins() {
    try {
      const item = await SB.findOne('site_content', 'key', 'sys_max_admins');
      if (item && item.content) {
        const v = parseInt(item.content);
        if (!isNaN(v) && v >= 1) return Math.min(v, 20);
      }
    } catch(_) {}
    return 5;
  }

  function updateMaxAdminsUI() {
    const disp = document.getElementById('sa-max-admins-display');
    if (disp) disp.textContent = _currentMaxAdmins;
    // 상태 텍스트 갱신
    const statusEl = document.getElementById('sa-max-admins-status');
    if (statusEl) {
      const cur = allAdmins ? allAdmins.length : 0;
      const remain = _currentMaxAdmins - cur;
      statusEl.textContent = `현재 등록된 관리자 ${cur}명 / 최대 ${_currentMaxAdmins}명 (여유 ${remain >= 0 ? remain : 0}명)`;
      statusEl.style.background = remain <= 0 ? '#fff0f0' : '#f0f4ff';
      statusEl.style.color = remain <= 0 ? '#c53030' : '#3a4a8a';
    }
    // 관리자 계정 패널 안내문 갱신
    const notice = document.querySelector('#panel-admin-accounts .admin-notice-max');
    if (notice) notice.textContent = `⚠️ 관리자는 최대 ${_currentMaxAdmins}명까지 등록 가능합니다. 본인 계정은 권한 해제할 수 없습니다.`;
    const badge = document.getElementById('admin-count-badge');
    if (badge) badge.textContent = `(${allAdmins ? allAdmins.length : 0}/${_currentMaxAdmins}명)`;
  }

  function adjustMaxAdmins(delta) {
