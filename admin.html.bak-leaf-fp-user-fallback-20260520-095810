  /* 결제완료 시 해당 회원이 1+13+14 모두 완료면 리더 승급 알림 */
  async function checkAutoLeaderUpgrade(changedId) {
    const changed = _allLeafReadings.find(r => r.id === changedId);
    if (!changed || !changed.user_id) return;
    const userApps = _allLeafReadings.filter(r => r.user_id === changed.user_id && r.payment_status === '결제완료');
    const has1  = userApps.some(r => r.chapter === '1');
    const has13 = userApps.some(r => r.chapter === '13');
    const has14 = userApps.some(r => r.chapter === '14');
    if (has1 && has13 && has14) {
      // 현재 등급 확인
      const user = await SB.getOne('users', changed.user_id);
      if (user && user.role === 'user') {
        const upgrade = confirm(`✅ ${user.name} 회원이 1+13+14장을 모두 완료했습니다.\n리더 등급으로 승급하시겠습니까?`);
        if (upgrade) {
          await SB.update('users', user.id, { role: 'leader', leader_upgraded_at: Date.now() });
          Toast.show(`${user.name} 회원이 리더로 승급되었습니다.`, 'success');
        }
      }
    }
  }

  /* ════════════════════════════════════════════════════════
     📅 예약 날짜 관리 (reading_slots)
  ════════════════════════════════════════════════════════ */
  let _allSlots = [];

  async function loadReadingSlots() {
    document.getElementById('slots-tbody').innerHTML = '<tr class="empty-row"><td colspan="10">로딩 중...</td></tr>';
    try {
      const raw = await SB.getAll('reading_slots', { limit: 300 });
      _allSlots = raw.filter(r => !r.deleted);
      _allSlots.sort((a,b) => (a.slot_date||'').localeCompare(b.slot_date||''));

      // 회원 목록 → datalist 채우기 + id/username/phone 맵
      let _userInfoMap = {}; // userId → { username, name, phone }
      try {
        const users = await SB.getAll('users', { limit: 1000 });
        const dl = document.getElementById('slot-user-datalist');
        if (dl) {
          dl.innerHTML = users.filter(u => u.username)
            .map(u => `<option value="${u.username}">${u.username}${u.name?' ('+u.name+')':''}</option>`).join('');
        }
        window._slotUserMap = {};
        users.forEach(u => { if (u.username) window._slotUserMap[u.username] = u.id; });
        window._slotIdMap = {};
        users.forEach(u => {
          if (u.id) {
            window._slotIdMap[u.id] = u.username || u.name || u.email || u.id;
            _userInfoMap[u.id] = { username: u.username||'', name: u.name||'', phone: u.phone||u.mobile||'' };
          }
        });
      } catch(_) {}

      // leaf_readings → slotId별 / 날짜별 신청자 목록 맵 구성
      // _slotApplicantMap : slotId → [항목1, 항목2, ...]  (같은 사람 여러 장 → 각각 별도 항목)
      // _dateApplicantMap : 'YYYY-MM-DD' → [항목, ...]    (slot_id 없고 appointment_date만 있는 경우)
      let _slotApplicantMap = {};
      let _dateApplicantMap = {};
      try {
        const leafRaw = await SB.getAll('leaf_readings', { limit: 1000 });
        leafRaw.filter(r => !r.deleted).forEach(r => {
          const phone = r.user_phone || (_userInfoMap[r.user_id] && _userInfoMap[r.user_id].phone) || '';
          const uname = r.username || (_userInfoMap[r.user_id] && _userInfoMap[r.user_id].username) || '';
          const item = {
            userId:    r.user_id,
            leafId:    r.id,
            name:      r.user_name || '',
            username:  uname,
            phone:     phone,
            status:    r.payment_status || '',
            payMethod: r.payment_method || '',
            apptDate:  r.appointment_date || '',
            chapter:   r.chapter || '',
            chapterLabel: r.chapter_label || '',
            slotId:    r.slot_id || ''
          };

          if (r.slot_id) {
            // slot_id 기준 맵: 같은 사람 + 같은 장도 각각 별도 항목으로 저장
            if (!_slotApplicantMap[r.slot_id]) _slotApplicantMap[r.slot_id] = [];
            _slotApplicantMap[r.slot_id].push(item);
          } else if (r.appointment_date && r.payment_status !== '취소') {
            // slot_id 없지만 확정 날짜가 있는 경우 → 날짜별 맵에 추가
            const dkey = r.appointment_date;
            if (!_dateApplicantMap[dkey]) _dateApplicantMap[dkey] = [];
            _dateApplicantMap[dkey].push(item);
          }
        });
      } catch(_) {}

      const filterStatus = document.getElementById('slot-filter-status')?.value || '';
      let filtered = [..._allSlots];
      if (filterStatus === 'open')   filtered = filtered.filter(s => s.is_open === true || s.is_open === 'true');
      if (filterStatus === 'closed') filtered = filtered.filter(s => s.is_open !== true && s.is_open !== 'true');

      // 날짜 최신순 정렬
      filtered.sort((a, b) => (b.slot_date||'').localeCompare(a.slot_date||''));

      // 결제수단 배지 색상
      const payMethodBadge = (m) => {
        if (!m) return '';
        const cfg = {
          '계좌이체': { bg:'#dbeafe', c:'#1d4ed8' },
          '카카오페이': { bg:'#fef9c3', c:'#854d0e' },
          '현금':     { bg:'#dcfce7', c:'#166534' },
          '카드':     { bg:'#ede9fe', c:'#5b21b6' }
        };
        const s = cfg[m] || { bg:'#f3f4f6', c:'#6b7280' };
        return `<span style="font-size:0.63rem;padding:1px 6px;border-radius:4px;background:${s.bg};color:${s.c};font-weight:600;white-space:nowrap;">${m}</span>`;
      };

      document.getElementById('slots-tbody').innerHTML = filtered.length
        ? filtered.map(s => {
            const isOpen = s.is_open === true || s.is_open === 'true';

            // 시간 표시
            let timeStr = '-';
            if (s.slot_time_start || s.slot_time_end) {
              timeStr = (s.slot_time_start||'?') + ' ~ ' + (s.slot_time_end||'?');
            } else if (s.slot_time) {
              timeStr = s.slot_time;
            }

            // 신청대상
            let targetLabel = `<span style="font-size:0.7rem;color:var(--text-light);">전체</span>`;
            if (s.target_user_id) {
              const ids = s.target_user_id.split(',').map(x => x.trim()).filter(Boolean);
              targetLabel = ids.map(uid => {
                const label = (window._slotIdMap && window._slotIdMap[uid]) || uid;
                return `<span style="font-size:0.68rem;background:#ede9fe;color:#5b21b6;padding:1px 6px;border-radius:4px;white-space:nowrap;display:inline-block;margin:1px;">👤 ${label}</span>`;
              }).join('');
            }

            // 신청자 + 결제수단 셀
            // slot_id 매핑된 신청 + appointment_date만으로 매핑된 신청 합산
            const slotApps  = _slotApplicantMap[s.id] || [];
            const dateApps  = (_dateApplicantMap[s.slot_date] || []).filter(a => !a.slotId); // 중복 방지
            const applicants = [...slotApps, ...dateApps];

            const stColor = { '접수중':'#b45309','결제대기':'#1d4ed8','결제완료':'#1a7a3a','실행완료':'#1a7a3a','취소':'#9ca3af' };
            const chLabelMap = {'1':'1장','13':'13장','14':'14장','ritual_13':'의식대행','ritual_14':'부적대행'};

            // 장 이름 표시: chapter_label이 있으면 우선, 없으면 chLabelMap 폴백
            const _getChDispLabel = (a) => {
              if (a.chapterLabel) {
                // "별의 과학④ 나크샤트라" → "별의 과학④" 앞부분만 짧게
                const CIRC = '①②③④⑤⑥⑦⑧⑨⑩⑪⑫⑬⑭⑮⑯⑰⑱⑲⑳㉑㉒㉓㉔㉕㉖㉗㉘㉙㉚㉛㉜㉝㉞㉟㊱㊲㊳㊴㊵㊶㊷㊸㊹㊺㊻㊼㊽㊾㊿';
                const lbl = a.chapterLabel;
                for (let i = 0; i < lbl.length; i++) {
                  if (CIRC.includes(lbl[i]) && lbl[i+1] === ' ') return lbl.slice(0, i+1).trim();
                }
                const jIdx = lbl.indexOf('장 ');
                if (jIdx >= 0) return lbl.slice(0, jIdx+1).trim();
                return lbl.split(' ')[0];
              }
              return chLabelMap[a.chapter] || a.chapter || '';
            };

            // 이 슬롯 날짜와 확정일이 일치하면 "확정" 표시
            const _isConfirmedForSlot = (a) => a.apptDate && a.apptDate === s.slot_date;

            let applicantCell;
            if (applicants.length === 0) {
              applicantCell = `<span style="font-size:0.72rem;color:var(--text-light);">없음</span>`;
            } else {
              // 같은 사람의 여러 장을 그룹핑하여 표시
              const byUser = {};
              applicants.forEach(a => {
                const key = a.userId || a.name;
                if (!byUser[key]) byUser[key] = { info: a, items: [] };
                byUser[key].items.push(a);
              });

              applicantCell = Object.values(byUser).map(({ info: a, items }) => {
                const chipsHtml = items.map(item => {
                  const chDisp = _getChDispLabel(item);
                  const confirmed = _isConfirmedForSlot(item);
                  const cancelledCls = item.status === '취소' ? 'opacity:0.45;text-decoration:line-through;' : '';
                  // 확정된 장: 초록 배지, 미확정: 노란 배지, 취소: 회색
                  const chipStyle = item.status === '취소'
                    ? `background:#f3f4f6;color:#9ca3af;${cancelledCls}`
                    : confirmed
                      ? 'background:#d1fae5;color:#065f46;font-weight:700;'
                      : 'background:#fef3c7;color:#92400e;';
                  const confirmedMark = confirmed ? '✅ ' : '';
                  return `<span style="font-size:0.64rem;padding:1px 7px;border-radius:12px;${chipStyle}display:inline-flex;align-items:center;gap:2px;margin:1px;white-space:nowrap;">
                    ${confirmedMark}${chDisp || '-'}
                    ${item.status ? `<span style="opacity:0.75;margin-left:2px;">· ${item.status}</span>` : ''}
                  </span>`;
                }).join('');

                return `
                <div style="font-size:0.74rem;line-height:1.6;padding:5px 0;border-bottom:1px dashed rgba(0,0,0,0.07);">
                  <div style="display:flex;align-items:center;gap:4px;flex-wrap:wrap;margin-bottom:3px;">
                    <strong style="color:var(--text-dark);">${a.name||'-'}</strong>
                    ${a.username ? `<span style="color:var(--gold);font-size:0.68rem;">@${a.username}</span>` : ''}
                    ${a.phone ? `<span style="font-size:0.66rem;color:var(--text-light);">${a.phone}</span>` : ''}
                  </div>
                  <div style="display:flex;flex-wrap:wrap;gap:2px;margin-bottom:3px;">${chipsHtml}</div>
                  <div style="display:flex;align-items:center;gap:4px;flex-wrap:wrap;">
                    ${payMethodBadge(items.find(i => i.payMethod)?.payMethod || '')}
                  </div>
                </div>`;
              }).join('');
            }

            return `<tr id="slot-row-${s.id}">
              <td style="text-align:center;"><input type="checkbox" class="slot-row-check" value="${s.id}" onchange="onSlotRowCheck()"></td>
              <td><strong style="${!isOpen?'color:var(--text-light);':''};">${s.slot_date||'-'}</strong></td>
              <td style="font-size:0.82rem;white-space:nowrap;">${timeStr}</td>
              <td>${targetLabel}</td>
              <td style="min-width:160px;">${applicantCell}</td>
              <td>
                <span class="badge ${isOpen?'badge--green':'badge--red'}">${isOpen?'개방 중':'마감'}</span>
              </td>
              <td><div class="action-btns">
                <button class="btn btn--sm" style="border:1px solid #c53030;color:#c53030;font-size:0.7rem;" onclick="deleteSlot('${s.id}')">🗑 삭제</button>
              </div></td>
            </tr>`;
          }).join('')
        : '<tr class="empty-row"><td colspan="7">등록된 날짜가 없습니다.</td></tr>';

      // ── 달력 뷰 렌더링 ──
      _renderOverviewCal();

    } catch(e) {
      document.getElementById('slots-tbody').innerHTML = '<tr class="empty-row"><td colspan="6">불러오기 실패</td></tr>';
      console.error('[loadReadingSlots]', e);
    }
  }

  /* ════════════════════════════════════════════════════════
     📆 슬롯 개요 달력 (Overview Calendar)
  ════════════════════════════════════════════════════════ */
  let _ovCalYear  = null;
  let _ovCalMonth = null; // 0-based

  /** loadReadingSlots 완료 후 호출 — _allSlots 데이터로 달력 그림 */
  function _renderOverviewCal() {
    const now = new Date();
    if (_ovCalYear === null)  _ovCalYear  = now.getFullYear();
    if (_ovCalMonth === null) _ovCalMonth = now.getMonth();
    _ovCalDraw();
  }

  function ovCalPrev() {
    if (_ovCalMonth === null) return;
    _ovCalMonth--;
    if (_ovCalMonth < 0) { _ovCalMonth = 11; _ovCalYear--; }
    _ovCalDraw();
    document.getElementById('ov-cal-detail').style.display = 'none';
  }

  function ovCalNext() {
    if (_ovCalMonth === null) return;
    _ovCalMonth++;
    if (_ovCalMonth > 11) { _ovCalMonth = 0; _ovCalYear++; }
    _ovCalDraw();
    document.getElementById('ov-cal-detail').style.display = 'none';
  }

  function _ovCalDraw() {
    const yr = _ovCalYear, mo = _ovCalMonth;
    const labelEl = document.getElementById('ov-cal-label');
    const gridEl  = document.getElementById('ov-cal-grid');
    if (!labelEl || !gridEl) return;

    labelEl.textContent = `${yr}년 ${mo + 1}월`;

    // 이 달의 슬롯을 날짜별로 그룹핑
    const dateMap = {}; // 'YYYY-MM-DD' → [slot, ...]
    (_allSlots || []).forEach(s => {
      if (!s.slot_date) return;
      const [sy, sm] = s.slot_date.split('-').map(Number);
      if (sy === yr && (sm - 1) === mo) {
        if (!dateMap[s.slot_date]) dateMap[s.slot_date] = [];
        dateMap[s.slot_date].push(s);
      }
    });

    // 이 달 1일의 요일 (0=일, 6=토)
    const firstDay = new Date(yr, mo, 1).getDay();
    // 이 달 마지막 날
    const lastDate = new Date(yr, mo + 1, 0).getDate();

    const todayStr = (() => {
      const t = new Date();
      return `${t.getFullYear()}-${String(t.getMonth()+1).padStart(2,'0')}-${String(t.getDate()).padStart(2,'0')}`;
    })();

    let html = '';
    // 앞 빈 칸
    for (let i = 0; i < firstDay; i++) {
      html += `<div style="min-height:56px;"></div>`;
    }

    for (let d = 1; d <= lastDate; d++) {
      const dateStr = `${yr}-${String(mo+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
      const slots   = dateMap[dateStr] || [];
      const hasSlot = slots.length > 0;
      const openSlots   = slots.filter(s => s.is_open === true || s.is_open === 'true');
      const closedSlots = slots.filter(s => s.is_open !== true && s.is_open !== 'true');
      const isToday = dateStr === todayStr;
      const dow = (firstDay + d - 1) % 7; // 0=일, 6=토

      // 총 잔여석 계산
      let totalRem = 0;
      openSlots.forEach(s => {
        const rem = Math.max(0, (parseInt(s.max_bookings)||1) - (parseInt(s.current_bookings)||0));
        totalRem += rem;
      });
      const allFull = openSlots.length > 0 && totalRem === 0;
      const hasClosed = closedSlots.length > 0 && openSlots.length === 0;

      // 날짜 텍스트 색
      let dayColor = dow === 0 ? '#e53e3e' : (dow === 6 ? '#1d4ed8' : 'var(--text-dark)');
      if (!hasSlot) dayColor = '#9ca3af';

      // 셀 배경 스타일
      let cellBg = 'transparent';
      let cellBorder = '1px solid transparent';
      let cellOpacity = '1';
      let dotHtml = '';
      let clickable = false;

      if (hasSlot) {
        clickable = true;
        if (openSlots.length > 0 && !allFull) {
          // 개방 중 + 잔여석 있음 → 초록
          cellBg = '#f0fff4';
          cellBorder = '1px solid #9ae6b4';
          dotHtml = `<div style="display:flex;flex-wrap:wrap;gap:2px;justify-content:center;margin-top:2px;">` +
            openSlots.map(() => `<span style="width:6px;height:6px;border-radius:50%;background:#1a7a3a;display:inline-block;"></span>`).join('') +
            `</div>`;
        } else if (allFull) {
          // 개방 중이지만 잔여석 0 → 주황
          cellBg = '#fffbeb';
          cellBorder = '1px solid #f6e05e';
          dotHtml = `<div style="margin-top:2px;font-size:0.55rem;color:#b45309;font-weight:700;text-align:center;">FULL</div>`;
        } else {
          // 마감만 있는 경우 → 회색 흐리게
          cellBg = '#f9fafb';
          cellBorder = '1px solid #e5e7eb';
          cellOpacity = '0.5';
          dotHtml = `<div style="display:flex;flex-wrap:wrap;gap:2px;justify-content:center;margin-top:2px;">` +
            closedSlots.map(() => `<span style="width:6px;height:6px;border-radius:50%;background:#e53e3e;display:inline-block;"></span>`).join('') +
            `</div>`;
        }
      } else {
        // 슬롯 없는 날 — 흐리게
        cellOpacity = '0.35';
      }

      const todayRing = isToday ? 'outline:2px solid var(--gold);outline-offset:1px;' : '';
      const cursor    = clickable ? 'cursor:pointer;' : '';
      const hoverAttr = clickable ? `onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform=''"` : '';
      const clickAttr = clickable ? `onclick="ovCalShowDetail('${dateStr}')"` : '';

      // 잔여석 표시 배지
      let remBadge = '';
      if (openSlots.length > 0) {
        remBadge = `<div style="font-size:0.58rem;color:${totalRem===0?'#e53e3e':'#1a7a3a'};font-weight:700;text-align:center;line-height:1.2;">${totalRem===0?'마감':totalRem+'석'}</div>`;
      }

      html += `
        <div ${clickAttr} ${hoverAttr}
          style="min-height:56px;border-radius:8px;padding:5px 3px;text-align:center;
                 background:${cellBg};border:${cellBorder};opacity:${cellOpacity};
                 ${cursor}${todayRing}transition:transform 0.1s;">
          <div style="font-size:0.82rem;font-weight:${hasSlot?'700':'400'};color:${dayColor};line-height:1.2;">${d}</div>
          ${remBadge}
          ${dotHtml}
        </div>`;
    }

    gridEl.innerHTML = html;
  }

  /** 날짜 클릭 → 슬롯 상세 표시 (신청자 포함) */
  async function ovCalShowDetail(dateStr) {
    const slots = (_allSlots || []).filter(s => s.slot_date === dateStr);
    if (!slots.length) return;

    const detailEl = document.getElementById('ov-cal-detail');
    const titleEl  = document.getElementById('ov-cal-detail-title');
    const bodyEl   = document.getElementById('ov-cal-detail-body');
    if (!detailEl || !titleEl || !bodyEl) return;

    // 날짜 한국식 표기
    const [yr, mo, dy] = dateStr.split('-').map(Number);
    const dowNames = ['일','월','화','수','목','금','토'];
    const dow = new Date(yr, mo-1, dy).getDay();
    titleEl.textContent = `📅 ${yr}년 ${mo}월 ${dy}일 (${dowNames[dow]}) — ${slots.length}개 슬롯`;
    bodyEl.innerHTML = '<div style="font-size:0.8rem;color:var(--text-light);padding:12px 0;">신청자 정보 불러오는 중...</div>';
    detailEl.style.display = 'block';
    detailEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

    // leaf_readings + users 로드하여 slotId별 신청자 매핑
    let slotApplicantMap = {}; // slotId → [{name,username,phone,status,chapter_label}]
    try {
      const [leafRaw, usersRaw] = await Promise.all([
        SB.getAll('leaf_readings', { limit: 1000 }),
        SB.getAll('users', { limit: 1000 })
      ]);
      const uMap = {};
      usersRaw.forEach(u => {
        if (u.id) uMap[u.id] = { username: u.username||'', phone: u.phone||u.mobile||'' };
      });
      leafRaw.filter(r => !r.deleted && r.slot_id).forEach(r => {
        if (!slotApplicantMap[r.slot_id]) slotApplicantMap[r.slot_id] = [];
        const phone = r.user_phone || (uMap[r.user_id]&&uMap[r.user_id].phone) || '';
        const uname = r.username  || (uMap[r.user_id]&&uMap[r.user_id].username) || '';
        // 같은 슬롯+같은 유저 → row 추가 (chapter 원본 보존)
        const existing = slotApplicantMap[r.slot_id].find(a => a.userId === r.user_id);
        if (existing) {
          existing.chapterRows.push(r);
        } else {
          slotApplicantMap[r.slot_id].push({
            userId: r.user_id,
            name: r.user_name || '',
            username: uname,
            phone: phone,
            status: r.payment_status || '',
            chapterRows: [r]
          });
        }
      });
    } catch(_) {}

    const stColor = { '접수중':'#b45309','결제대기':'#1d4ed8','결제완료':'#1a7a3a','실행완료':'#1a7a3a','취소':'#9ca3af' };

    // 슬롯 카드 렌더링
    bodyEl.innerHTML = slots.map(s => {
      const max    = parseInt(s.max_bookings) || 1;
      const cur    = parseInt(s.current_bookings) || 0;
      const rem    = Math.max(0, max - cur);
      const isOpen = s.is_open === true || s.is_open === 'true';
      const remColor = rem === 0 ? '#c53030' : (rem <= 2 ? '#b45309' : '#1a7a3a');

      let timeStr = '시간 미정';
      if (s.slot_time_start || s.slot_time_end) timeStr = `${s.slot_time_start||'?'} ~ ${s.slot_time_end||'?'}`;
      else if (s.slot_time) timeStr = s.slot_time;

      const pct = max > 0 ? Math.round((cur / max) * 100) : 0;
      const barColor = rem === 0 ? '#e53e3e' : (rem <= 2 ? '#f6ad55' : '#68d391');

      // 신청자 목록
      const applicants = slotApplicantMap[s.id] || [];
      const applicantHtml = applicants.length === 0
        ? `<div style="font-size:0.73rem;color:var(--text-light);padding:6px 0;">신청자 없음</div>`
        : applicants.map(a => `
            <div style="display:flex;align-items:flex-start;gap:8px;padding:7px 10px;background:#f8fafc;border-radius:6px;margin-bottom:4px;">
              <div style="flex:1;min-width:0;">
                <div style="font-size:0.8rem;font-weight:700;color:var(--text-dark);">${a.name||'-'}
                  ${a.username?`<span style="font-size:0.68rem;color:var(--gold);margin-left:3px;">@${a.username}</span>`:''}
                </div>
                <div style="font-size:0.72rem;color:var(--text-mid);">📞 ${a.phone||'전화 없음'}</div>
                <div style="font-size:0.68rem;color:var(--text-light);margin-top:1px;">${_PKG.buildLabel(a.chapterRows, {})}</div>
              </div>
              <span style="font-size:0.65rem;font-weight:600;padding:2px 7px;border-radius:12px;background:rgba(0,0,0,0.05);color:${stColor[a.status]||'#6b7280'};white-space:nowrap;flex-shrink:0;">${a.status}</span>
            </div>`).join('');

      return `
        <div style="background:${isOpen?'white':'#f9fafb'};border:1px solid ${isOpen?'#9ae6b4':'#e5e7eb'};
                    border-radius:10px;padding:14px 16px;min-width:220px;flex:1;max-width:320px;
                    opacity:${isOpen?'1':'0.65'};">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
            <span style="font-size:0.88rem;font-weight:700;color:var(--navy);">🕐 ${timeStr}</span>
            <span style="font-size:0.68rem;font-weight:600;padding:2px 8px;border-radius:20px;
                         background:${isOpen?'#c6f6d5':'#fed7d7'};color:${isOpen?'#1a7a3a':'#c53030'};">
              ${isOpen?'개방 중':'마감'}
            </span>
          </div>
          <!-- 잔여석 바 -->
          <div style="margin-bottom:10px;">
            <div style="display:flex;justify-content:space-between;font-size:0.7rem;color:var(--text-mid);margin-bottom:3px;">
              <span>잔여석</span>
              <span style="font-weight:700;color:${remColor};">${rem} / ${max}</span>
            </div>
            <div style="background:#e5e7eb;border-radius:4px;height:6px;overflow:hidden;">
              <div style="width:${pct}%;height:100%;background:${barColor};border-radius:4px;transition:width 0.3s;"></div>
            </div>
          </div>
          ${s.memo ? `<div style="font-size:0.72rem;color:var(--text-light);margin-bottom:8px;">📝 ${s.memo}</div>` : ''}
          <!-- 신청자 목록 -->
          <div style="margin-bottom:10px;">
            <div style="font-size:0.72rem;font-weight:700;color:var(--text-mid);margin-bottom:5px;border-bottom:1px solid var(--border);padding-bottom:4px;">
              👥 신청자 ${applicants.length}명
            </div>
            ${applicantHtml}
          </div>
          <!-- 관리 버튼 -->
          <div style="display:flex;gap:6px;flex-wrap:wrap;">
            <button class="btn btn--sm"
              style="font-size:0.68rem;background:${isOpen?'#fff5f5':'#e6f4ea'};
                     color:${isOpen?'#c53030':'#1a7a3a'};
                     border:1px solid ${isOpen?'#fca5a5':'#9ae6b4'};white-space:nowrap;"
              onclick="toggleSlot('${s.id}',${isOpen});ovCalShowDetail('${dateStr}')">
              ${isOpen?'🔒 마감 처리':'🔓 재개방'}
            </button>
            <button class="btn btn--sm"
              style="font-size:0.68rem;border:1px solid #fca5a5;color:#c53030;"
              onclick="deleteSlot('${s.id}')">
              🗑 삭제
            </button>
          </div>
          <button type="button"
            onclick="document.getElementById('slot-row-${s.id}')?.scrollIntoView({behavior:'smooth',block:'center'});
                     document.getElementById('slot-row-${s.id}')?.animate([{background:'#fef9c3'},{background:'transparent'}],{duration:1200});"
            style="margin-top:6px;font-size:0.65rem;color:var(--text-light);background:none;border:none;cursor:pointer;text-decoration:underline;display:block;">
            ↓ 목록에서 보기
          </button>
        </div>`;
    }).join('');

    detailEl.style.display = 'block';
    // 상세 패널로 부드럽게 스크롤
    detailEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  /* ── 날짜 미배정 신청자 목록 로드 + 직접 배정 (user_id 기준 묶음) ── */
  async function loadUnassignedApplicants() {
    const container = document.getElementById('unassigned-applicants-list');
    if (!container) return;
    container.innerHTML = '<div style="font-size:0.83rem;color:var(--text-light);text-align:center;padding:20px 0;">로딩 중...</div>';
    try {
      const raw   = await SB.getAll('leaf_readings', { limit: 500 });
      const users = await SB.getAll('users', { limit: 1000 });
      const uMap  = {};
      users.forEach(u => { if (u.id) uMap[u.id] = { name: u.name || u.user_name || '', username: u.username || '', email: u.email || '' }; });

      const unassigned = raw.filter(r =>
        !r.deleted &&
        ['접수중','결제대기','결제완료'].includes(r.payment_status) &&
        (!r.appointment_date || r.appointment_date === '')
      );
      unassigned.sort((a,b) => (b.created_at||0) - (a.created_at||0));

      if (unassigned.length === 0) {
        container.innerHTML = '<div style="font-size:0.83rem;color:#1a7a3a;text-align:center;padding:20px 0;">✅ 날짜 미배정 신청자가 없습니다.</div>';
        return;
      }

      // user_id 기준으로 묶기
      const grouped = {};
      unassigned.forEach(r => {
        const key = r.user_id || ('_' + (r.user_name || r.id));
        if (!grouped[key]) grouped[key] = { rows: [], user_id: r.user_id, user_name: r.user_name, username: r.username };
        grouped[key].rows.push(r);
      });

      // 장 표시 레이블 (숫자 + 특별장 포함)
      const chLabel = (ch) => {
        const map = {
          '1':'1장','2':'2장','3':'3장','4':'4장','5':'5장',
          '6':'6장','7':'7장','8':'8장','9':'9장','10':'10장','11':'11장',
          '12':'12장','13':'13장','14':'14장',
          'ritual_13':'의식대행','ritual_14':'부적대행'
        };
        return map[String(ch)] || (ch ? ch+'장' : '-');
      };
      const stColor = { '접수중':'#b45309','결제대기':'#b45309','결제완료':'#1d4ed8' };

      const groupKeys = Object.keys(grouped);
      container.innerHTML = `
        <div style="display:flex;flex-direction:column;gap:10px;">
          ${groupKeys.map(key => {
            const g = grouped[key];
            const u = uMap[g.user_id] || {};
            const nameStr = g.user_name || u.name || '-';
            const idStr   = g.username  || u.username || '';
            const ids = g.rows.map(r => r.id).join(',');
            // 장 목록을 접수 상태별로 정리
            const chipsHtml = g.rows.map(r => {
              const stStr = r.payment_status || '접수중';
              const color = stColor[stStr] || '#555';
              return `<span style="display:inline-flex;align-items:center;gap:3px;background:#fff;border:1px solid #e2c97e;border-radius:4px;padding:2px 8px;font-size:0.72rem;">
                <span style="color:var(--gold);font-weight:700;">${chLabel(r.chapter)}</span>
                <span style="color:${color};font-size:0.68rem;">${stStr}</span>
              </span>`;
            }).join('');
