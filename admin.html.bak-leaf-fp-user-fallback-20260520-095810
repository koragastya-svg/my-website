  async function changeAdminPassword() {
    const curPw     = (document.getElementById('sa-pw-current')?.value || '').trim();
    const newPw     = (document.getElementById('sa-pw-new')?.value || '').trim();
    const confirmPw = (document.getElementById('sa-pw-confirm')?.value || '').trim();

    if (!curPw)              { Toast.show('현재 비밀번호를 입력하세요.', 'error'); return; }
    if (newPw.length < 6)    { Toast.show('새 비밀번호는 6자 이상이어야 합니다.', 'error'); return; }
    if (newPw !== confirmPw) { Toast.show('새 비밀번호가 일치하지 않습니다.', 'error'); return; }

    const btn = document.getElementById('btn-save-sa-pw');
    if (btn) { btn.disabled = true; btn.textContent = '변경 중...'; }

    try {
      // ① 세션에서 현재 로그인 정보 가져오기
      const session = Auth.getSession ? Auth.getSession() : null;
      if (!session) {
        Toast.show('❌ 로그인이 필요합니다. 다시 로그인해 주세요.', 'error');
        return;
      }

      // ② admin 아이디만 이 기능 사용 가능
      if (session.username !== 'admin') {
        Toast.show('❌ admin 계정만 이 기능을 사용할 수 있습니다.', 'error');
        return;
      }

      // ③ 전체 유저 목록에서 username='admin' 검색 (id 방식 대신 검색 방식 사용)
      const userData = await SB.findOne('users', 'username', 'admin');
      if (!userData) {
        Toast.show('❌ admin 계정을 찾을 수 없습니다.', 'error');
        return;
      }

      // ④ password_hash 필드로 현재 비밀번호 검증
      const storedHash = userData.password_hash || '';
      if (!storedHash) {
        Toast.show('❌ 저장된 비밀번호 정보가 없습니다.', 'error');
        return;
      }

      const match = await Auth.verifyPassword(curPw, storedHash);
      if (!match) {
        Toast.show('❌ 현재 비밀번호가 올바르지 않습니다.', 'error');
        return;
