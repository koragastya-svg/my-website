  function filterLeafReadings(q) {
    const query = (typeof q === 'string') ? q : (document.getElementById('leaf-search-q')?.value || '');
    const statusVal = document.getElementById('leaf-status-filter')?.value || '';
    const pkgVal    = document.getElementById('leaf-pkg-filter')?.value || '';
    const sortKey   = document.getElementById('leaf-sort-key')?.value || 'created_desc';

    let filtered = _allLeafReadings.filter(r => {
      const matchQ = !query ||
        (r.user_name||'').includes(query) ||
        (r.user_email||'').includes(query) ||
        (r.user_phone||'').includes(query) ||
        (r.username||'').includes(query);
      // 필터 '접수중' → DB의 '접수중' + '결제대기' 모두 포함
      // 필터 '종료'   → DB의 '종료' + '실행완료' 모두 포함
      const matchS = !statusVal || (() => {
        const ds = leafDisplayStatus(r.payment_status || '접수중');
        return ds === statusVal;
      })();
      const matchP = !pkgVal || r.chapter === pkgVal ||
        (pkgVal === 'single' && r.chapter === '1') ||
        (pkgVal === 'full'   && ['13','14'].includes(r.chapter));
      return matchQ && matchS && matchP;
    });

    // 정렬
    const chapterPrice = { '1': 500000, '13': 2000000, '14': 2000000, 'ritual_13': 0, 'ritual_14': 0, 'other': 0 };
    filtered.sort((a, b) => {
      if (sortKey === 'created_desc') return (b.created_at||0) - (a.created_at||0);
      if (sortKey === 'created_asc')  return (a.created_at||0) - (b.created_at||0);
      if (sortKey === 'name_asc')     return (a.user_name||'').localeCompare(b.user_name||'', 'ko');
      if (sortKey === 'amount_desc')  return (chapterPrice[b.chapter]||0) - (chapterPrice[a.chapter]||0);
      if (sortKey === 'amount_asc')   return (chapterPrice[a.chapter]||0) - (chapterPrice[b.chapter]||0);
      return 0;
    });

    renderLeafReadingsTable(filtered);
  }

  // 결제완료 확정 시 — 같은 target_user_id의 나머지 후보 슬롯 자동 삭제
  async function _deleteOtherCandidateSlots(confirmedSlotId, userId) {
    if (!confirmedSlotId || !userId) return;
    try {
      const allSlots = await SB.getAll('reading_slots', { limit: 500 });
      const others = allSlots.filter(s =>
        !s.deleted &&
        s.target_user_id === userId &&
        s.id !== confirmedSlotId
      );
      if (others.length === 0) return;
      await Promise.all(others.map(s => SB.remove('reading_slots', s.id)));
      console.log(`[슬롯정리] 확정 슬롯 ${confirmedSlotId} 외 후보 ${others.length}개 자동 삭제 (user: ${userId})`);
    } catch(e) {
      console.warn('[슬롯정리] 후보 슬롯 삭제 중 오류:', e.message);
    }
  }

  // 그룹 내 모든 row 상태 일괄 변경
  async function changeLeafStatusAll(ids, status) {
    if (!status || !ids || !ids.length) return;
    try {
      await Promise.all(ids.map(id => SB.update('leaf_readings', id, { payment_status: status })));
      ids.forEach(id => {
        const row = _allLeafReadings.find(r => r.id === id);
        if (row) row.payment_status = status;
      });
      Toast.show('상태가 변경되었습니다.', 'success');
      if (status === '결제완료') {
        checkAutoLeaderUpgrade(ids[0]);
        // 확정된 slot_id 찾아서 나머지 후보 슬롯 자동 삭제
        const repRow = _allLeafReadings.find(r => ids.includes(r.id) && r.slot_id);
        if (repRow && repRow.slot_id && repRow.user_id) {
          await _deleteOtherCandidateSlots(repRow.slot_id, repRow.user_id);
          // 슬롯 목록도 새로고침 (열려 있는 경우)
          if (typeof loadReadingSlots === 'function') {
            try { await loadReadingSlots(); } catch(_) {}
          }
        }
      }
      renderLeafReadingsTable(_allLeafReadings);
    } catch(e) {
      Toast.show('상태 변경 실패: ' + e.message, 'error');
    }
  }

