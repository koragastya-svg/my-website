  async function addReadingSlot() {
    const dates     = [..._slotSelDates].sort();
    const timeStart = document.getElementById('slot-new-time-start')?.value || '';
    const timeEnd   = document.getElementById('slot-new-time-end')?.value || '';
    const max       = parseInt(document.getElementById('slot-new-max')?.value) || 1;
    const memo      = document.getElementById('slot-new-memo')?.value?.trim() || '';
    const targetRaw = document.getElementById('slot-new-target-user')?.value?.trim() || '';

    if (dates.length === 0) { Toast.show('날짜를 하나 이상 선택해주세요.', 'error'); return; }

    // 여러 username → user_id 변환
    let targetUserIds = '';
    if (targetRaw) {
      const parts = targetRaw.split(',').map(x => x.trim()).filter(Boolean);
      targetUserIds = parts
        .map(raw => (window._slotUserMap && window._slotUserMap[raw]) || raw)
        .join(',');
    }

    const slotTime = (timeStart || timeEnd)
      ? (timeStart && timeEnd ? timeStart + '~' + timeEnd : timeStart || timeEnd)
      : '';

    const statusEl = document.getElementById('slot-add-status');
    if (statusEl) { statusEl.style.display = 'inline'; statusEl.textContent = `0 / ${dates.length} 등록 중...`; }

    try {
      let done = 0;
      for (const date of dates) {
        await SB.insert('reading_slots', {
          slot_date: date,
          slot_time: slotTime,
          slot_time_start: timeStart || null,
          slot_time_end: timeEnd || null,
          chapter: 'all', max_bookings: max,
          current_bookings: 0, is_open: true,
          memo: memo,
          target_user_id: targetUserIds || null
        });
        done++;
        if (statusEl) statusEl.textContent = `${done} / ${dates.length} 등록 중...`;
      }

      Toast.show(`✅ ${dates.length}개 날짜가 등록되었습니다.`, 'success');

      // 폼 초기화
      _slotSelDates.clear();
      _slotCalRender();
      document.getElementById('slot-new-time-start').value = '';
      document.getElementById('slot-new-time-end').value = '';
      document.getElementById('slot-new-max').value = '1';
      if (document.getElementById('slot-new-memo')) document.getElementById('slot-new-memo').value = '';
      if (document.getElementById('slot-new-target-user')) document.getElementById('slot-new-target-user').value = '';
      if (statusEl) statusEl.style.display = 'none';

      await loadReadingSlots();
    } catch(e) {
      Toast.show('추가 실패: ' + e.message, 'error');
      if (statusEl) statusEl.style.display = 'none';
    }
  }

