  }
  document.addEventListener('input', e => {
    if (e.target.id === 'sm-capacity' || e.target.id === 'sm-current-applicants') updateSmRemaining();
  });

  function toggleApplyTypeUI() {
    const isExt = document.getElementById('sm-apply-type-ext').checked;
    const extWrap = document.getElementById('sm-external-url-wrap');
    const siteNote = document.getElementById('sm-site-form-note');
    const siteLabel = document.getElementById('sm-apply-type-site-label');
    const extLabel = document.getElementById('sm-apply-type-ext-label');
    extWrap.style.display = isExt ? 'block' : 'none';
    siteNote.style.display = isExt ? 'none' : 'block';
    siteLabel.style.borderColor = isExt ? 'transparent' : 'var(--gold)';
