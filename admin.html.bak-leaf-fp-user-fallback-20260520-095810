  /* ── 이메일 발송 ── */
  async function sendEmail(type) {
    const ejsKey = (siteContentMap['emailjs_public_key']||{}).content || '';
    const ejsSvc = (siteContentMap['emailjs_service_id']||{}).content || '';
    const ejsTpl = type === 'approved'
      ? (siteContentMap['emailjs_template_approved']||{}).content || ''
      : (siteContentMap['emailjs_template_id']||{}).content || '';

    const resultEl = document.getElementById('email-send-result');
    resultEl.style.display = 'block';

    if (!ejsKey || !ejsSvc || !ejsTpl) {
      resultEl.style.color = '#c53030';
      resultEl.textContent = '⚠️ 결제·이메일 설정 페이지에서 EmailJS 키를 먼저 저장해주세요.';
      return;
    }

    const toEmail = document.getElementById('app-e-email').value.trim();
    const name = document.getElementById('app-e-name').value.trim();
    const semTitle = document.getElementById('app-e-title').value.trim();
    const semDate = document.getElementById('app-e-date').value;
    const method = document.getElementById('app-e-method').value;

    const bankName = (siteContentMap['bank_name']||{}).content || '';
    const bankAcc = (siteContentMap['bank_account']||{}).content || '';
    const bankHolder = (siteContentMap['bank_holder']||{}).content || '';
    const bankDeadline = (siteContentMap['bank_deadline']||{}).content || '';

    const msg = type === 'approved'
      ? `${name}님의 세미나 신청이 승인/결제 완료되었습니다.\n세미나: ${semTitle}\n일정: ${semDate}`
      : (method === '계좌이체'
          ? `신청이 완료되었습니다.\n\n[입금 안내]\n은행: ${bankName}\n계좌: ${bankAcc}\n예금주: ${bankHolder}\n기한: ${bankDeadline}`
          : `${name}님, 세미나 신청이 정상적으로 접수되었습니다.\n세미나: ${semTitle}\n일정: ${semDate}`);

    resultEl.style.color = '#2b6cb0'; resultEl.textContent = '발송 중...';

    try {
      if (!window.emailjs) {
        await loadEmailJSSdk(ejsKey);
      } else {
        emailjs.init(ejsKey);
      }
      await emailjs.send(ejsSvc, ejsTpl, {
        to_email: toEmail,
        applicant_name: name,
        seminar_title: semTitle,
        seminar_date: semDate,
        payment_method: method,
        message: msg
      });
      resultEl.style.color = '#276749';
      resultEl.textContent = `✅ ${toEmail} 로 메일이 발송되었습니다.`;
    } catch(err) {
      resultEl.style.color = '#c53030';
      resultEl.textContent = '❌ 발송 실패: ' + (err.text || err.message || JSON.stringify(err));
    }
  }

  function loadEmailJSSdk(publicKey) {
    return new Promise((resolve, reject) => {
      if (window.emailjs) { emailjs.init(publicKey); resolve(); return; }
      const s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js';
      s.onload = () => { emailjs.init(publicKey); resolve(); };
      s.onerror = reject;
      document.head.appendChild(s);
    });
  }

