  // 환불 금액 계산
  function calcRefund() {
    const seminarDateStr  = document.getElementById('calc-seminar-date').value;
    const cancelDateStr   = document.getElementById('calc-cancel-date').value;
    const paymentDateEl   = document.getElementById('calc-payment-date');
    const paymentDateStr  = paymentDateEl ? paymentDateEl.value : '';
    const price = parseInt(document.getElementById('calc-price').value) || 0;
    const resultEl = document.getElementById('refund-result');

    if (!seminarDateStr || !cancelDateStr || price <= 0) {
      if (resultEl) resultEl.style.display = 'none';
      return;
    }

    const seminarDate  = new Date(seminarDateStr);
    const cancelDate   = new Date(cancelDateStr);
    const paymentDate  = paymentDateStr ? new Date(paymentDateStr) : null;

    // 세미나까지 남은 일수 (취소일 기준)
    const diffDays = Math.ceil((seminarDate - cancelDate) / (1000 * 60 * 60 * 24));
    // 결제 후 경과 일수
    const daysSincePayment = paymentDate
      ? Math.floor((cancelDate - paymentDate) / (1000 * 60 * 60 * 24))
      : null;

    let rule = '', refundRate = 0, penalty = 0, extra = '';

    // 결제 후 7일 이내 & 세미나 30일 이전 → 전액 환불 (공정거래위 원칙)
    if (paymentDate && daysSincePayment !== null && daysSincePayment <= 7 && diffDays >= 30) {
      rule = '✨ 결제 후 7일 이내 & 세미나 30일 이상 이전 취소';
      refundRate = 100; penalty = 0;
      extra = `(결제후 ${daysSincePayment}일, 세미나 D-${Math.max(diffDays,0)})`;
    } else if (diffDays >= 30) {
      rule = '세미나 30일 이상 이전 취소';
      refundRate = 100; penalty = 0;
      extra = `(세미나 D-${diffDays})`;
    } else if (diffDays >= 15) {
      rule = '세미나 30일 ~ 15일 이전 취소';
      refundRate = 70; penalty = 100000;
      extra = `(세미나 D-${diffDays})`;
    } else if (diffDays >= 7) {
      rule = '세미나 14일 ~ 7일 이전 취소';
      refundRate = 50; penalty = 150000;
      extra = `(세미나 D-${diffDays})`;
    } else if (diffDays >= 3) {
      rule = '세미나 6일 ~ 3일 이전 취소';
      refundRate = 30; penalty = 210000;
      extra = `(세미나 D-${diffDays})`;
    } else if (diffDays >= 0) {
      rule = '세미나 2일 이전 ~ 당일 취소';
      refundRate = 0; penalty = price;
      extra = `(세미나 D-${diffDays})`;
    } else {
      rule = '세미나 종료 후 취소 요청';
      refundRate = 0; penalty = price;
      extra = '(세미나 이미 종료)';
    }

    const refundAmt = Math.floor(price * refundRate / 100);

    document.getElementById('refund-rule-text').textContent = rule;
    document.getElementById('refund-rule-label').textContent = '적용 규정  ' + extra;
    document.getElementById('refund-amount-text').textContent = refundRate === 0
      ? '환불 불가'
      : refundAmt.toLocaleString('ko-KR') + '원';
    document.getElementById('refund-amount-text').style.color = refundRate === 0 ? '#c53030' : (refundRate === 100 ? '#2a7a2a' : 'var(--gold)');
    document.getElementById('refund-penalty-text').textContent = penalty > 0 && refundRate > 0
      ? `위약금 ${penalty.toLocaleString('ko-KR')}원 / 환불율 ${refundRate}%`
      : refundRate === 100 ? '✅ 전액 환불' : '⛔ 환불 불가 (위약금 100%)';

    if (resultEl) resultEl.style.display = 'block';
  }

