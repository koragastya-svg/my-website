  /* 회원 필드 인라인 편집 (email / phone / memo) */
  function editUserField(id, field, currentVal, _unused) {
    const cellId = `user-${field}-${id}`;
    const cell = document.getElementById(cellId);
    if (!cell || cell.querySelector('input,textarea')) return;

    const fieldLabels = { email: '이메일', phone: '전화번호', memo: '비고' };
    const isTextarea = field === 'memo';
    const el = document.createElement(isTextarea ? 'textarea' : 'input');
    if (!isTextarea) el.type = field === 'email' ? 'email' : 'text';
    el.value = currentVal || '';
    el.placeholder = field === 'memo' ? '메모/비고 입력...' : (field === 'phone' ? '010-0000-0000' : 'email@example.com');
    el.style.cssText = `font-size:0.78rem;border:1px solid var(--gold);border-radius:4px;padding:4px 6px;outline:none;width:100%;box-sizing:border-box;min-width:120px;${isTextarea?'min-height:60px;resize:vertical;':''}`;
    // 전화번호 자동 하이픈
    if (field === 'phone') {
      el.setAttribute('maxlength', '13');
      el.oninput = function() {
        let v = this.value.replace(/\D/g, '');
        if (v.length <= 3) { this.value = v; }
        else if (v.length <= 7) { this.value = v.slice(0,3)+'-'+v.slice(3); }
        else if (v.length <= 11) {
          if (v.startsWith('02')) this.value = v.slice(0,2)+'-'+v.slice(2,6)+(v.length>6?'-'+v.slice(6,10):'');
          else this.value = v.slice(0,3)+'-'+v.slice(3,7)+(v.length>7?'-'+v.slice(7,11):'');
        }
      };
    }

    const save = async () => {
      const newVal = el.value.trim();
      if (field === 'email' && newVal && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(newVal)) {
        Toast.show('올바른 이메일 형식이 아닙니다.', 'error');
        renderUserCell(cell, field, currentVal);
        return;
      }
      if (newVal !== currentVal) {
        try {
          await SB.update('users', id, { [field]: newVal });
          Toast.show(`${fieldLabels[field]}이(가) 수정되었습니다.`, 'success');
          renderUserCell(cell, field, newVal, id);
          // allUsers 업데이트
          const u = allUsers.find(x => x.id === id);
          if (u) u[field] = newVal;
        } catch(e) {
          Toast.show('수정 중 오류가 발생했습니다.', 'error');
          renderUserCell(cell, field, currentVal, id);
        }
      } else {
        renderUserCell(cell, field, currentVal, id);
      }
    };

    el.onblur = save;
    el.onkeydown = (e) => {
      if (e.key === 'Enter' && !isTextarea) el.blur();
      if (e.key === 'Escape') { el.onblur = null; renderUserCell(cell, field, currentVal, id); }
    };
    cell.innerHTML = '';
    cell.appendChild(el);
    el.focus(); el.select && el.select();
  }

  function renderUserCell(cell, field, val, id) {
    if (field === 'memo') {
      cell.innerHTML = val
        ? `<span style="display:inline-block;max-width:130px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${val}</span>`
        : '<span style="color:#bbb;">비고</span>';
      cell.style.color = val ? 'var(--text-mid)' : 'var(--text-light)';
    } else {
      cell.textContent = val || '-';
