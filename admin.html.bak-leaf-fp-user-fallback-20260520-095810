      document.getElementById('sm-date-single').style.display = 'block';
      document.getElementById('sm-date-range').style.display = 'none';
      document.getElementById('sm-date').value = seminar ? (seminar.date || '') : '';
      document.getElementById('sm-date-range-start').value = '';
      document.getElementById('sm-date-range-end').value = '';
    }
    document.getElementById('sm-time').value = seminar ? seminar.time : '';
    document.getElementById('sm-location').value = seminar ? seminar.location : '';
    document.getElementById('sm-organizer').value = seminar ? (seminar.organizer || '') : '';
    document.getElementById('sm-form-title').value = seminar ? (seminar.form_title || '') : '';
    document.getElementById('sm-form-subtitle').value = seminar ? (seminar.form_subtitle || '') : '';
    // 신청 방식
    const applyType = seminar ? (seminar.apply_type || 'site') : 'site';
    document.getElementById('sm-apply-type-site').checked = applyType === 'site';
    document.getElementById('sm-apply-type-ext').checked = applyType === 'external';
    document.getElementById('sm-external-url').value = seminar ? (seminar.external_url || '') : '';
    toggleApplyTypeUI();
    // 신청 자격 (member_only)
    const memberOnly = seminar ? (seminar.member_only === 'member') : false;
    document.getElementById('sm-member-open').checked = !memberOnly;
    document.getElementById('sm-member-only-radio').checked = memberOnly;
    toggleMemberOnlyUI();
