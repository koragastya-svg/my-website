  /* ════════════════════════════════════════════════
     상세 모달 — 날짜 후보 관리
     흐름: 관리자 후보 등록 → 회원 마이페이지 선택 → 자동 확정
  ════════════════════════════════════════════════ */

  /** 이 회원 전용으로 등록된 후보 슬롯 목록 로드 */
  async function loadDetailCandidates(userId) {
    const listEl = document.getElementById('leaf-detail-cand-list');
    const badge  = document.getElementById('leaf-detail-cand-badge');
    if (!listEl) return;
    listEl.innerHTML = `<div style="font-size:0.78rem;color:var(--text-light);text-align:center;padding:8px 0;">로딩 중...</div>`;
    try {
      const raw = await SB.getAll('reading_slots', { limit: 300 });
      // 이 회원 ID가 포함된 슬롯 + 삭제 안 된 것
      const mine = raw.filter(s => {
        if (s.deleted) return false;
        if (!s.target_user_id) return false;
        return s.target_user_id.split(',').map(x => x.trim()).includes(userId);
      });
      mine.sort((a,b) => (a.slot_date||'').localeCompare(b.slot_date||''));

      // 배지 갱신
      if (badge) {
        if (mine.length === 0) {
          badge.style.background = '#fbbf24'; badge.style.color = '#78350f';
          badge.textContent = '⏳ 후보 없음';
        } else {
          badge.style.background = '#3b82f6'; badge.style.color = '#fff';
          badge.textContent = `📋 ${mine.length}개 후보`;
        }
      }

      if (mine.length === 0) {
        listEl.innerHTML = `<div style="font-size:0.78rem;color:var(--text-light);text-align:center;padding:10px 0;background:#fff;border-radius:8px;border:1px dashed #e2e8f0;">아직 등록된 후보가 없습니다</div>`;
        return;
      }

      listEl.innerHTML = mine.map(s => {
        const isOpen = s.is_open === true || s.is_open === 'true';
        const timeStr = (s.slot_time_start && s.slot_time_end)
          ? `${s.slot_time_start} ~ ${s.slot_time_end}`
          : (s.slot_time || '시간 미정');
        const rem = Math.max(0, (s.max_bookings||1) - (s.current_bookings||0));
        const isSelected = (s.current_bookings || 0) > 0;
        return `<div style="display:flex;align-items:center;gap:10px;padding:9px 12px;
            background:${isSelected ? '#d1fae5' : '#fff'};
            border:1px solid ${isSelected ? '#6ee7b7' : '#dbe4f5'};border-radius:8px;">
          <div style="flex:1;min-width:0;">
            <div style="font-size:0.85rem;font-weight:700;color:${isSelected?'#065f46':'var(--text-dark)'};">
              📅 ${s.slot_date}
              ${isSelected ? '<span style="font-size:0.65rem;background:#34d399;color:#fff;padding:1px 6px;border-radius:4px;margin-left:4px;">✓ 선택됨</span>' : ''}
            </div>
            <div style="font-size:0.72rem;color:var(--text-light);margin-top:2px;">
              🕐 ${timeStr}
              &nbsp;·&nbsp; 잔여 ${rem}/${s.max_bookings||1}석
              ${s.memo ? `&nbsp;·&nbsp; ${s.memo}` : ''}
              &nbsp;·&nbsp; <span style="color:${isOpen?'#1a7a3a':'#c53030'};font-weight:600;">${isOpen?'개방':'마감'}</span>
            </div>
          </div>
          <button onclick="removeCandidateSlot('${s.id}','${userId}')"
            style="flex-shrink:0;padding:4px 10px;border-radius:5px;border:1px solid #fca5a5;color:#c53030;background:#fff;font-size:0.72rem;cursor:pointer;font-weight:600;white-space:nowrap;">
            삭제
          </button>
        </div>`;
      }).join('');

    } catch(e) {
      listEl.innerHTML = `<div style="font-size:0.78rem;color:#c53030;text-align:center;padding:8px 0;">불러오기 실패: ${e.message}</div>`;
    }
  }

  /**
   * 후보 슬롯 추가 — 날짜 기준 슬롯 공유
   *
   * ▸ 같은 날짜(slot_date)의 슬롯이 이미 존재하면
   *     - max_bookings +1
   *     - target_user_id 에 userId 추가 (콤마 구분, 중복 제외)
   * ▸ 없으면 신규 insert (max_bookings: 1)
   *
   * 이 회원이 이미 해당 날짜에 배정되어 있으면 중복 등록 방지.
   */
  async function addCandidateSlot(userId, recordId) {
    if (!userId) { Toast.show('회원 ID가 없어 후보를 추가할 수 없습니다.', 'error'); return; }

    const dateVal   = document.getElementById('cand-new-date')?.value;
    const timeStart = document.getElementById('cand-new-time-start')?.value || '';
    const timeEnd   = document.getElementById('cand-new-time-end')?.value || '';
    const memoVal   = document.getElementById('cand-new-memo')?.value?.trim() || '';

    if (!dateVal) { Toast.show('날짜를 선택해 주세요.', 'error'); return; }

    try {
      // 전체 슬롯 조회 (삭제되지 않은 것)
      const allSlots = await SB.getAll('reading_slots', { limit: 500 });
      const active   = allSlots.filter(s => !s.deleted);

      // 같은 날짜의 슬롯 탐색 (삭제 안 된 것 중 첫 번째)
      const sameDate = active.find(s => s.slot_date === dateVal);

      if (sameDate) {
        // ── 같은 날짜 슬롯 존재 → 이 회원이 이미 배정됐는지 확인
        const ids = (sameDate.target_user_id || '')
          .split(',').map(x => x.trim()).filter(Boolean);

        if (ids.includes(userId)) {
          Toast.show(`${dateVal}은 이미 이 회원에게 배정된 날짜입니다.`, 'error');
          return;
        }

        // max_bookings +1, target_user_id에 userId 추가
        ids.push(userId);
        const newMax = (sameDate.max_bookings || 1) + 1;

        await SB.update('reading_slots', sameDate.id, {
          max_bookings:   newMax,
          target_user_id: ids.join(',')
        });

        Toast.show(
          `✅ ${dateVal} 기존 슬롯에 후보 추가 완료 (총 ${newMax}석).\n` +
          `회원 마이페이지에 표시됩니다.`,
          'success'
        );

      } else {
        // ── 해당 날짜 슬롯 없음 → 신규 생성
        const slotTime = (timeStart && timeEnd)
          ? `${timeStart}~${timeEnd}`
          : (timeStart || timeEnd || '');

        await SB.insert('reading_slots', {
          slot_date:        dateVal,
          slot_time:        slotTime,
          slot_time_start:  timeStart || null,
          slot_time_end:    timeEnd   || null,
          chapter:          'all',
          max_bookings:     1,
          current_bookings: 0,
          is_open:          true,
          memo:             memoVal || null,
          target_user_id:   userId
        });

        Toast.show(
          `✅ ${dateVal} 후보가 등록되었습니다.\n회원 마이페이지에 표시됩니다.`,
          'success'
        );
      }

      // 폼 초기화
      ['cand-new-date', 'cand-new-time-start', 'cand-new-time-end', 'cand-new-memo']
        .forEach(id => { const el = document.getElementById(id); if (el) el.value = ''; });

      // 후보 목록 + 슬롯 탭 갱신
      await loadDetailCandidates(userId);
      if (typeof loadReadingSlots === 'function') {
        try { await loadReadingSlots(); } catch(_) {}
      }

    } catch(e) {
      Toast.show('후보 추가 실패: ' + e.message, 'error');
    }
  }

  /** 후보 슬롯 삭제 */
  /**
   * 후보 슬롯 삭제 — 날짜 기준 공유 슬롯 대응
   *
   * ▸ 이 userId만 배정된 단독 슬롯  → 슬롯 완전 삭제
   * ▸ 여러 명이 공유하는 슬롯        → userId만 target_user_id에서 제거 + max_bookings -1
   */
  async function removeCandidateSlot(slotId, userId) {
    if (!confirm('이 날짜 후보를 삭제하시겠습니까?\n회원 마이페이지에서 더 이상 보이지 않게 됩니다.')) return;
    try {
      // 슬롯 정보 조회
      const slot = await SB.getOne('reading_slots', slotId).catch(() => null)
                || (await SB.getAll('reading_slots', { limit: 500 })).find(s => s.id === slotId);

      if (!slot) { Toast.show('슬롯 정보를 찾을 수 없습니다.', 'error'); return; }

      const ids = (slot.target_user_id || '')
        .split(',').map(x => x.trim()).filter(Boolean);
      const remaining = ids.filter(x => x !== userId);

      if (remaining.length === 0) {
        // 이 userId만 있던 슬롯 → 완전 삭제
        await SB.remove('reading_slots', slotId);
        Toast.show('후보 날짜가 삭제되었습니다.', 'success');
      } else {
        // 다른 userId도 있는 공유 슬롯 → userId만 제거, max_bookings -1
        const newMax = Math.max(1, (slot.max_bookings || 1) - 1);
        await SB.update('reading_slots', slotId, {
          target_user_id: remaining.join(','),
          max_bookings:   newMax
        });
        Toast.show('후보 날짜가 배정에서 제외되었습니다.', 'success');
      }

      await loadDetailCandidates(userId);
      if (typeof loadReadingSlots === 'function') {
        try { await loadReadingSlots(); } catch(_) {}
      }
    } catch(e) {
      Toast.show('삭제 실패: ' + e.message, 'error');
    }
  }

  /* ─ 하위 호환용 stub (더 이상 모달에서 호출되지 않음) ─ */
  async function loadDetailSlots(recordId, userId) {
    const container = document.getElementById('leaf-detail-slot-list');
    if (!container) return;
    container.innerHTML = `<div style="font-size:0.78rem;color:var(--text-light);text-align:center;padding:10px 0;">로딩 중...</div>`;

    try {
      const raw = await SB.getAll('reading_slots', { limit: 300 });
      const slots = raw.filter(s => !s.deleted && (s.is_open === true || s.is_open === 'true'));
      slots.sort((a,b) => (a.slot_date||'').localeCompare(b.slot_date||''));

      if (slots.length === 0) {
        container.innerHTML = `<div style="font-size:0.78rem;color:var(--text-light);text-align:center;padding:10px 0;">등록된 개방 슬롯이 없습니다.<br>아래 직접 입력을 이용하세요.</div>`;
        return;
      }

      // 날짜별로 그룹핑
      const byDate = {};
      slots.forEach(s => {
        if (!byDate[s.slot_date]) byDate[s.slot_date] = [];
        byDate[s.slot_date].push(s);
      });
      const dates = Object.keys(byDate).sort();

      // 현재 기록의 예약 날짜/슬롯 확인
      const rec = _allLeafReadings.find(x => x.id === recordId);
      const curSlotId = rec?.slot_id || '';
      const curDate   = rec?.appointment_date || '';

      // 미니 달력 + 슬롯 리스트 렌더링
      // 달력 상태 변수 (모달 전용)
      const now = new Date();
      let calYear  = now.getFullYear();
      let calMonth = now.getMonth();

      // 날짜 → 슬롯 매핑을 window에 임시 저장
      window._detailSlotMap = byDate;
      window._detailRecordId = recordId;

      renderDetailSlotCal(calYear, calMonth, byDate, curDate, curSlotId, recordId);

    } catch(e) {
      container.innerHTML = `<div style="font-size:0.78rem;color:#c53030;text-align:center;padding:10px 0;">불러오기 실패: ${e.message}</div>`;
    }
  }

  /** 상세 모달 미니 달력 렌더 */
  function renderDetailSlotCal(year, month, byDate, curDate, curSlotId, recordId) {
    const container = document.getElementById('leaf-detail-slot-list');
    if (!container) return;

    const monthNames = ['1월','2월','3월','4월','5월','6월','7월','8월','9월','10월','11월','12월'];
    const firstDay = new Date(year, month, 1).getDay();
    const lastDate = new Date(year, month + 1, 0).getDate();
    const todayStr  = new Date().toISOString().slice(0,10);
    const monthStr  = `${year}-${String(month+1).padStart(2,'0')}`;

    // 이 달에 슬롯이 있는 날짜 set
    const slotDatesThisMonth = new Set(
      Object.keys(byDate).filter(d => d.startsWith(monthStr))
    );

    // 날짜 셀 생성
    let cells = '';
    for (let i = 0; i < firstDay; i++) cells += `<div></div>`;
    for (let d = 1; d <= lastDate; d++) {
      const ds = `${year}-${String(month+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
      const hasSlot = slotDatesThisMonth.has(ds);
      const isPast  = ds < todayStr;
      const isCur   = ds === curDate;
      const isToday = ds === todayStr;

      let bg = 'transparent', color = hasSlot ? '#0b1629' : '#cbd5e1', cursor = 'default', border = 'none';
      let dotHtml = '';

      if (isCur) {
        bg = '#0b1629'; color = '#fff'; cursor = 'pointer'; border = '2px solid #4ade80';
      } else if (hasSlot && !isPast) {
        bg = '#dbeafe'; color = '#1d4ed8'; cursor = 'pointer'; border = '1px solid #93c5fd';
        dotHtml = `<div style="width:5px;height:5px;border-radius:50%;background:#1d4ed8;margin:1px auto 0;"></div>`;
      } else if (isToday) {
        border = '1.5px solid #1d4ed8';
      }

      cells += `<div onclick="${hasSlot && !isPast ? `showDetailSlotOptions('${ds}','${recordId}')` : ''}"
        style="aspect-ratio:1;display:flex;flex-direction:column;align-items:center;justify-content:center;
          border-radius:6px;font-size:0.78rem;font-weight:${hasSlot?'700':'400'};
          background:${bg};color:${color};cursor:${cursor};border:${border};
          transition:all .15s;${isPast?'opacity:0.35;':''}"
        title="${hasSlot ? (byDate[ds].map(s => (s.slot_time_start||s.slot_time||'시간미정')).join(', ')) : ''}">
        ${d}
        ${dotHtml}
      </div>`;
    }

    container.innerHTML = `
      <div style="background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:12px;margin-bottom:8px;">
        <!-- 달력 헤더 -->
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
          <button type="button" onclick="detailCalNav(-1,'${recordId}')"
            style="background:none;border:none;cursor:pointer;font-size:1.1rem;color:var(--navy);padding:2px 8px;">‹</button>
          <span style="font-size:0.85rem;font-weight:700;color:var(--navy);">${year}년 ${monthNames[month]}</span>
          <button type="button" onclick="detailCalNav(1,'${recordId}')"
            style="background:none;border:none;cursor:pointer;font-size:1.1rem;color:var(--navy);padding:2px 8px;">›</button>
        </div>
        <!-- 요일 -->
        <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:3px;margin-bottom:4px;">
          ${['일','월','화','수','목','금','토'].map((d,i) =>
            `<div style="text-align:center;font-size:0.68rem;font-weight:700;color:${i===0?'#e53e3e':i===6?'#1d4ed8':'#94a3b8'};padding:3px 0;">${d}</div>`
          ).join('')}
        </div>
        <!-- 날짜 그리드 -->
        <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:3px;">${cells}</div>
        <!-- 범례 -->
        <div style="display:flex;gap:10px;margin-top:8px;font-size:0.66rem;color:var(--text-light);">
          <span><span style="display:inline-block;width:8px;height:8px;border-radius:2px;background:#dbeafe;border:1px solid #93c5fd;margin-right:3px;vertical-align:middle;"></span>예약 가능</span>
          <span><span style="display:inline-block;width:8px;height:8px;border-radius:2px;background:#0b1629;margin-right:3px;vertical-align:middle;"></span>현재 배정일</span>
        </div>
      </div>
      <!-- 슬롯 선택 패널 (날짜 클릭 시 표시) -->
      <div id="detail-slot-options" style="display:none;"></div>`;

    // 현재 달력 월/년 저장
    window._detailCalYear  = year;
    window._detailCalMonth = month;
  }

  /** 달력 월 이동 */
  function detailCalNav(dir, recordId) {
    let y = window._detailCalYear  || new Date().getFullYear();
    let m = window._detailCalMonth !== undefined ? window._detailCalMonth : new Date().getMonth();
    m += dir;
    if (m < 0)  { m = 11; y--; }
    if (m > 11) { m = 0;  y++; }
    const rec = _allLeafReadings.find(x => x.id === recordId);
    renderDetailSlotCal(y, m, window._detailSlotMap || {}, rec?.appointment_date||'', rec?.slot_id||'', recordId);
  }

  /** 날짜 클릭 → 해당 날짜의 슬롯 선택 패널 표시 */
  function showDetailSlotOptions(dateStr, recordId) {
    const panel = document.getElementById('detail-slot-options');
    if (!panel) return;
    const slotsOnDate = (window._detailSlotMap || {})[dateStr] || [];
    const rec = _allLeafReadings.find(x => x.id === recordId);
    const curSlotId = rec?.slot_id || '';

    panel.style.display = 'block';
    panel.innerHTML = `
      <div style="font-size:0.75rem;font-weight:700;color:var(--navy);margin-bottom:8px;">
        📅 ${dateStr} — 슬롯 선택
      </div>
      <div style="display:flex;flex-direction:column;gap:6px;">
        ${slotsOnDate.map(s => {
          const timeStr = (s.slot_time_start && s.slot_time_end)
            ? `${s.slot_time_start} ~ ${s.slot_time_end}`
            : (s.slot_time || '시간 미정');
          const remain  = (s.max_bookings||1) - (s.current_bookings||0);
          const isCur   = s.id === curSlotId;
          return `<div style="display:flex;align-items:center;justify-content:space-between;
              background:${isCur?'#dbeafe':'#f8faff'};border:1px solid ${isCur?'#93c5fd':'#e2e8f0'};
              border-radius:8px;padding:10px 14px;">
            <div>
              <div style="font-size:0.85rem;font-weight:700;color:${isCur?'#1d4ed8':'var(--text-dark)'};">
                🕐 ${timeStr}
                ${isCur ? '<span style="font-size:0.65rem;background:#1d4ed8;color:#fff;padding:1px 6px;border-radius:4px;margin-left:4px;">현재 배정</span>' : ''}
              </div>
              <div style="font-size:0.7rem;color:var(--text-light);margin-top:2px;">
                잔여 ${remain}석 / 최대 ${s.max_bookings||1}석
                ${s.memo ? `&nbsp;·&nbsp; ${s.memo}` : ''}
              </div>
            </div>
            <button onclick="assignSlotFromDetail('${recordId}','${s.id}','${dateStr}')"
              style="padding:6px 14px;border-radius:6px;font-size:0.78rem;font-weight:700;cursor:pointer;white-space:nowrap;
                ${isCur
                  ? 'background:#fff;border:1px solid #1d4ed8;color:#1d4ed8;'
                  : 'background:var(--navy);color:#fff;border:none;'}">
              ${isCur ? '재배정' : '배정'}
            </button>
          </div>`;
        }).join('')}
      </div>`;
  }

  /** 슬롯 배정 실행: leaf_readings.slot_id + appointment_date 저장, current_bookings++ */
  async function assignSlotFromDetail(recordId, slotId, dateStr) {
    const rec = _allLeafReadings.find(x => x.id === recordId);
    if (!rec) return;
    const prevSlotId = rec.slot_id;

    try {
      // 1) leaf_reading 업데이트 — 날짜 확정 시 결제완료 자동 전환
      const newStatus = '결제완료';
      await SB.update('leaf_readings', recordId, {
        slot_id:          slotId,
        appointment_date: dateStr,
        payment_status:   newStatus
      });
      rec.slot_id          = slotId;
      rec.appointment_date = dateStr;
      rec.payment_status   = newStatus;

      // 2) 새 슬롯 current_bookings +1 (같은 슬롯 재배정이면 증가 안 함)
      if (slotId !== prevSlotId) {
        const newSlot = _allSlots?.find(s => s.id === slotId);
        const newCnt  = (newSlot?.current_bookings || 0) + 1;
        await SB.update('reading_slots', slotId, { current_bookings: newCnt });
        if (newSlot) newSlot.current_bookings = newCnt;

        // 3) 이전 슬롯 current_bookings -1
        if (prevSlotId) {
          const prevSlot = _allSlots?.find(s => s.id === prevSlotId);
          const prevCnt  = Math.max(0, (prevSlot?.current_bookings || 1) - 1);
          await SB.update('reading_slots', prevSlotId, { current_bookings: prevCnt });
          if (prevSlot) prevSlot.current_bookings = prevCnt;
        }
      }

      Toast.show(`✅ ${dateStr} 리딩 날짜가 배정되었습니다.`, 'success');

      // 4) 모달 배지 갱신
      const badge = document.getElementById('leaf-detail-appt-badge');
      if (badge) {
        badge.style.background = '#4ade80'; badge.style.color = '#14532d';
        badge.textContent = '✅ ' + dateStr + ' 확정';
      }
      // 5) 직접입력 필드 동기화
      const directInput = document.getElementById('leaf-detail-direct-date');
      if (directInput) directInput.value = dateStr;

      // 6) 달력 재렌더
      renderDetailSlotCal(
        window._detailCalYear || new Date().getFullYear(),
        window._detailCalMonth !== undefined ? window._detailCalMonth : new Date().getMonth(),
        window._detailSlotMap || {}, dateStr, slotId, recordId
      );
      // 슬롯 패널 닫기
      const opts = document.getElementById('detail-slot-options');
      if (opts) opts.style.display = 'none';

      // 7) 리딩 신청 테이블 갱신
      renderLeafReadingsTable(window._filteredLeafRows || _allLeafReadings);
      // 8) 슬롯 테이블도 갱신 (열려 있을 경우)
      if (typeof loadReadingSlots === 'function') {
        try { await loadReadingSlots(); } catch(_) {}
      }

    } catch(e) {
      Toast.show('날짜 배정 실패: ' + e.message, 'error');
    }
  }

  /** 직접 날짜 입력으로 배정 (슬롯 없이) */
  async function assignDirectDate(recordId) {
    const rec  = _allLeafReadings.find(x => x.id === recordId);
    const dateEl = document.getElementById('leaf-detail-direct-date');
    const dateStr = dateEl?.value;
    if (!dateStr) { Toast.show('날짜를 입력해주세요.', 'error'); return; }
    try {
      // 날짜 직접 배정 시 결제완료 자동 전환
      await SB.update('leaf_readings', recordId, {
        appointment_date: dateStr,
        payment_status:   '결제완료'
      });
      if (rec) { rec.appointment_date = dateStr; rec.payment_status = '결제완료'; }
      Toast.show(`✅ ${dateStr} 날짜가 저장되었습니다.`, 'success');
      // 배지 갱신
      const badge = document.getElementById('leaf-detail-appt-badge');
      if (badge) {
        badge.style.background = '#4ade80'; badge.style.color = '#14532d';
        badge.textContent = '✅ ' + dateStr + ' 확정';
      }
      renderLeafReadingsTable(window._filteredLeafRows || _allLeafReadings);
    } catch(e) {
      Toast.show('저장 실패: ' + e.message, 'error');
    }
  }

  /** 배정 취소 — appointment_date + slot_id 제거 */
  async function clearAppointmentDate(recordId) {
    if (!confirm('날짜 배정을 취소하시겠습니까?')) return;
    const rec = _allLeafReadings.find(x => x.id === recordId);
    try {
      // 슬롯 current_bookings -1
      if (rec?.slot_id) {
        const slot = _allSlots?.find(s => s.id === rec.slot_id);
        const cnt  = Math.max(0, (slot?.current_bookings || 1) - 1);
        await SB.update('reading_slots', rec.slot_id, { current_bookings: cnt });
        if (slot) slot.current_bookings = cnt;
      }
      await SB.update('leaf_readings', recordId, { appointment_date: '', slot_id: '' });
      if (rec) { rec.appointment_date = ''; rec.slot_id = ''; }
      Toast.show('날짜 배정이 취소되었습니다.', 'success');
      // 모달 갱신
      document.getElementById('leaf-detail-modal')?.remove();
      openLeafDetail(recordId);
      renderLeafReadingsTable(window._filteredLeafRows || _allLeafReadings);
      if (typeof loadReadingSlots === 'function') {
        try { await loadReadingSlots(); } catch(_) {}
      }
    } catch(e) {
      Toast.show('취소 실패: ' + e.message, 'error');
    }
  }

  /* 상세 모달 — 확정일 저장 */
  async function applyLeafDetailAppt(id) {
    const input = document.getElementById('leaf-detail-appt-input');
    const newDate = input ? input.value : '';
    if (!newDate) { Toast.show('날짜를 선택해주세요.', 'error'); return; }
    try {
      await SB.update('leaf_readings', id, { appointment_date: newDate });
      const row = _allLeafReadings.find(r => r.id === id);
      if (row) row.appointment_date = newDate;
      Toast.show(`확정일이 [${newDate}]로 저장되었습니다.`, 'success');
      document.getElementById('leaf-detail-modal')?.remove();
      openLeafDetail(id);
      renderLeafReadingsTable(window._filteredLeafRows || _allLeafReadings);
    } catch(e) {
      Toast.show('저장 실패: ' + e.message, 'error');
    }
  }

  /* 상세 모달 — 확정일 취소 (초기화, 회원이 재선택 가능) */
  async function cancelLeafDetailAppt(id) {
    if (!confirm('확정일을 취소하면 회원이 마이페이지에서 다시 날짜를 선택해야 합니다.\n계속하시겠습니까?')) return;
    try {
      const row = _allLeafReadings.find(r => r.id === id);
      const prevSlotId = row?.slot_id || '';
      // appointment_date + slot_id + 상태 전체 주가 수선닥
      await SB.update('leaf_readings', id, { appointment_date: null, slot_id: null, payment_status: '접수중' });
      if (row) { row.appointment_date = ''; row.slot_id = ''; row.payment_status = '접수중'; }
      // 이전 슬론 current_bookings -1
      if (prevSlotId) {
        try {
          const prevSlot = await SB.getOne('reading_slots', prevSlotId);
          if (prevSlot) {
            const prevCnt = Math.max(0, (parseInt(prevSlot.current_bookings) || 1) - 1);
            await SB.update('reading_slots', prevSlotId, { current_bookings: prevCnt, is_open: true });
          }
        } catch(_) {}
      }
      Toast.show('확정일이 취소되었습니다. 회원이 재선택할 수 있습니다.', 'success');
      document.getElementById('leaf-detail-modal')?.remove();
      openLeafDetail(id);
      renderLeafReadingsTable(window._filteredLeafRows || _allLeafReadings);
    } catch(e) {
      Toast.show('취소 실패: ' + e.message, 'error');
    }
  }

  /* 상세 모달 — 상태 저장 */
  async function applyLeafDetailStatus(id) {
    const sel = document.getElementById('leaf-detail-status-sel');
    if (!sel || !sel.value) { Toast.show('변경할 상태를 선택해주세요.', 'error'); return; }
    await changeLeafStatusAll([id], sel.value);
    document.getElementById('leaf-detail-modal')?.remove();
    openLeafDetail(id);
  }

  /* 상세 모달 — 패키지(chapter) 변경 */
  async function applyLeafDetailChapter(id) {
    const newChapter = _resolveChapterValue('leaf-detail-chapter-sel', 'leaf-detail-chapter-custom');
    if (!newChapter) { Toast.show('변경할 패키지를 선택하거나 직접 입력해주세요.', 'error'); return; }
    const chLabel = { '1':'1장','13':'13장','14':'14장','ritual_13':'의식 대행','ritual_14':'부적 대행','other':'기타' };
    if (!confirm(`패키지를 [${chLabel[newChapter]||newChapter}]으로 변경하시겠습니까?`)) return;
    try {
      await SB.update('leaf_readings', id, { chapter: newChapter });
      const row = _allLeafReadings.find(r => r.id === id);
      if (row) row.chapter = newChapter;
      Toast.show(`패키지가 [${chLabel[newChapter]||newChapter}]으로 변경되었습니다.`, 'success');
      document.getElementById('leaf-detail-modal')?.remove();
      openLeafDetail(id);
      renderLeafReadingsTable(_allLeafReadings);
    } catch(e) {
      Toast.show('패키지 변경 실패: ' + e.message, 'error');
    }
  }

  /* 상세 모달 — 관리자 메모 저장 */
  async function saveLeafDetailMemo(id) {
    const r = _allLeafReadings.find(x => x.id === id);
    if (!r) return;
    const MEMO_MARKER = '\n[관리자메모]\n';
    const ta = document.getElementById('leaf-detail-memo');
    const adminText = ta ? ta.value.trim() : '';
    const rawMemo = r.memo || '';
    const sepIdx  = rawMemo.indexOf(MEMO_MARKER);
    const userPart = sepIdx >= 0 ? rawMemo.slice(0, sepIdx) : rawMemo;
    const newMemo = adminText ? `${userPart}${MEMO_MARKER}${adminText}` : userPart;
    try {
      await SB.update('leaf_readings', id, { memo: newMemo });
      r.memo = newMemo;
      Toast.show('메모가 저장되었습니다.', 'success');
    } catch(e) {
      Toast.show('메모 저장 실패: ' + e.message, 'error');
    }
  }

  /* 상세 모달 — 삭제 */
  async function deleteLeafReadingFromDetail(id) {
    if (!confirm('이 신청 내역을 삭제하시겠습니까?')) return;
    try {
      await SB.remove('leaf_readings', id);
      _allLeafReadings = _allLeafReadings.filter(r => r.id !== id);
      document.getElementById('leaf-detail-modal')?.remove();
      renderLeafReadingsTable(window._filteredLeafRows.filter(r => r.id !== id));
      Toast.show('삭제되었습니다.', 'success');
    } catch(e) {
      Toast.show('삭제 실패: ' + e.message, 'error');
    }
  }

  /* ── 잎 리딩 일괄 처리 함수들 ── */
  function onLeafRowCheck() {
    const checks = document.querySelectorAll('.leaf-row-check:checked');
    const allChecks = document.querySelectorAll('.leaf-row-check');
    const bulkBar = document.getElementById('leaf-bulk-bar');
    const countEl = document.getElementById('leaf-bulk-count');
    const allCbx  = document.getElementById('leaf-check-all');
    const n = checks.length;
    // 실제 건수 = 그룹 내 ids 합산
    const totalRows = [...checks].reduce((s, cb) => {
      const ids = (cb.dataset.groupIds || cb.value).split(',').filter(Boolean);
      return s + ids.length;
    }, 0);
    if (bulkBar) bulkBar.style.display = n > 0 ? 'flex' : 'none';
    if (countEl) countEl.textContent = n === totalRows ? `${n}건 선택됨` : `${n}그룹(${totalRows}건) 선택됨`;
    if (allCbx)  allCbx.checked = n > 0 && n === allChecks.length;
  }

  function toggleAllLeafRows(checked) {
    document.querySelectorAll('.leaf-row-check').forEach(cb => { cb.checked = checked; });
    onLeafRowCheck();
  }

  function clearLeafSelection() {
    document.querySelectorAll('.leaf-row-check').forEach(cb => { cb.checked = false; });
    const allCbx = document.getElementById('leaf-check-all');
    if (allCbx) allCbx.checked = false;
