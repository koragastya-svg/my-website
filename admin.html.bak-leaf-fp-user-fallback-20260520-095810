      if (!top10.length) {
        tbody.innerHTML = '<tr class="empty-row"><td colspan="6">잎 리딩 신청 내역이 없습니다.</td></tr>';
        return;
      }

      tbody.innerHTML = top10.map(({ rows: grp }) => {
        const rep = grp[0];
        // 장번호 오름차순 정렬
        const sortedGrp = [...grp].sort((a,b) => (chOrder[a.chapter]||99) - (chOrder[b.chapter]||99));
        // 패키지: 조합형 배지 (_PKG 공통 헬퍼 사용)
        const _dashBadgeStyle = 'display:inline-block;font-size:0.7rem;font-weight:700;color:var(--gold);background:rgba(186,117,23,0.1);border:1px solid rgba(186,117,23,0.2);border-radius:4px;padding:2px 6px;white-space:nowrap;';
        const pkgCell = _PKG.buildBadgeHtml(grp, chapterLabel, _dashBadgeStyle);
        // 대표 상태 (가장 낮은 단계 기준)
        const statusOrder = ['취소','접수중','결제대기','결제완료','실행완료'];
        const repStatus = grp.reduce((worst, r) => {
          const wi = statusOrder.indexOf(worst);
          const ri = statusOrder.indexOf(r.payment_status||'접수중');
          return ri < wi ? r.payment_status : worst;
        }, grp[0].payment_status||'접수중');
        // 신청일
        const ts = Math.max(...grp.map(r => Number(r.created_at)||0));
        const dateStr = ts ? new Date(ts).toLocaleDateString('ko-KR') : '-';

        return `<tr>
          <td><strong>${rep.user_name||'-'}</strong><br><span style="font-size:0.75rem;color:var(--text-light);">${rep.user_email||''}</span></td>
          <td style="font-size:0.8rem;">${rep.gender||'-'}</td>
          <td style="font-size:0.78rem;">${rep.user_phone||'-'}</td>
          <td><div style="display:flex;flex-direction:row;flex-wrap:wrap;gap:3px;align-items:center;">${pkgCell}</div></td>
          <td><span style="display:inline-block;padding:2px 10px;border-radius:12px;font-size:0.72rem;font-weight:600;background:${statusBg(repStatus)};color:${statusColor(repStatus)};">${repStatus}</span></td>
          <td style="font-size:0.78rem;white-space:nowrap;">${dateStr}</td>
        </tr>`;
      }).join('');
    } catch(e) {
      tbody.innerHTML = '<tr class="empty-row"><td colspan="6">불러오기 실패</td></tr>';
      console.error('[loadDashLeafReadings]', e);
