  async function loadApplications() {
    // Tables API에서 직접 fetch해 created_at 필드 원본 보존
    try {
      const res = await fetch('tables/applications?limit=500');
      const json = await res.json();
      const rows = json.data || json || [];
      allApps = (Array.isArray(rows) ? rows : []).map(r => {
        // id 정규화
        if (!r.id && r.gs_id) r = { ...r, id: r.gs_id };
        // original_created_at 우선 사용 (백업 복원 시 원본 신청일 보존용)
        if (r.original_created_at) r = { ...r, created_at: r.original_created_at };
        // created_at 없으면 updated_at 시도
        else if (!r.created_at && r.updated_at) r = { ...r, created_at: r.updated_at };
