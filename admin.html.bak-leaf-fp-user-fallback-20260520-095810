  /* ── YouTube 미리보기 ── */
  function extractYouTubeIdAdmin(url) {
    const patterns = [
      /youtu\.be\/([a-zA-Z0-9_-]{11})/,
      /youtube\.com\/watch\?(?:.*&)?v=([a-zA-Z0-9_-]{11})/,
      /youtube\.com\/embed\/([a-zA-Z0-9_-]{11})/,
      /youtube\.com\/shorts\/([a-zA-Z0-9_-]{11})/
    ];
    for (const p of patterns) { const m = url.match(p); if (m) return m[1]; }
    return null;
  }
  function previewYouTube(url) {
    const preview = document.getElementById('nm-yt-preview');
    const iframe = document.getElementById('nm-yt-iframe');
    if (!url) { preview.style.display = 'none'; iframe.src = ''; return; }
    const id = extractYouTubeIdAdmin(url);
    if (id) {
      iframe.src = `https://www.youtube.com/embed/${id}`;
      preview.style.display = 'block';
    } else {
      preview.style.display = 'none';
      iframe.src = '';
    }
  }

