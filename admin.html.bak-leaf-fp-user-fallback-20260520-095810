  /* CSV 파일 생성 + 다운로드 헬퍼 */
  function _csvDownload(header, rows, filename) {
    const BOM = '\uFEFF';
    const esc = v => `"${String(v ?? '').replace(/"/g, '""')}"`;
    const csv = BOM + [header, ...rows].map(r => r.map(esc).join(',')).join('\n');
    const url = URL.createObjectURL(new Blob([csv], { type: 'text/csv;charset=utf-8;' }));
    Object.assign(document.createElement('a'), { href: url, download: filename }).click();
    URL.revokeObjectURL(url);
  }

  /* ── 신청 상세 모달 ── */
  function openAppModal(id) {
    const a = allApps.find(x => x.id === id);
    if (!a) return;
    document.getElementById('app-edit-id').value = a.id;
    document.getElementById('app-e-name').value = a.applicant_name || '';
    document.getElementById('app-e-email').value = a.applicant_email || '';
    document.getElementById('app-e-phone').value = a.applicant_phone || '';
    document.getElementById('app-e-amount').value = a.payment_amount || 0;
    document.getElementById('app-e-method').value = a.payment_method || '카드';
    document.getElementById('app-e-status').value = a.payment_status || '결제대기';
    document.getElementById('app-e-date').value = a.seminar_date || '';
    document.getElementById('app-e-title').value = a.seminar_title || '';
    // memo 파싱: 카드 결제 민감정보 블록 제거 / 설문 [질문] 블록 / [관리자메모] 마커 이후 관리자 메모 분리
    const memoFull = a.memo || '';

    // ── 신규 방식: [관리자메모] 마커로 명확히 분리 ──
    const ADMIN_MEMO_MARKER = '\n[관리자메모]\n';
    let rawSurveyPart, rawAdminMemoPart;
    if (memoFull.includes(ADMIN_MEMO_MARKER)) {
      const idx = memoFull.indexOf(ADMIN_MEMO_MARKER);
      rawSurveyPart   = memoFull.slice(0, idx);
      rawAdminMemoPart = memoFull.slice(idx + ADMIN_MEMO_MARKER.length);
    } else {
      rawSurveyPart   = memoFull;
      rawAdminMemoPart = '';
    }

    const lines = rawSurveyPart.split('\n');
    // ── 설문 줄 파싱 ──
    // 카드 결제 민감정보 블록은 보안상 표시/복호화/재저장하지 않고 완전히 무시한다.
    let surveyLines = [], adminMemoLines = [];
    let inSensitivePaymentBlock = false;
    lines.forEach(l => {
      const t = l.trim();

      if (t === '[카드정보]') {
        inSensitivePaymentBlock = true;
        return;
      }

      if (inSensitivePaymentBlock) {
        const isSensitiveLine =
          l.startsWith('카드번호') ||
          l.startsWith('카드종류') ||
          l.startsWith('유효기간') ||
          l.startsWith('CVC') ||
          l.startsWith('비밀번호') ||
          l.startsWith('카드소유자') ||
          l.startsWith('※ 실제값') ||
          l.startsWith('[AES256]');

        if (isSensitiveLine) return;
        inSensitivePaymentBlock = false;
      }

      // [질문명] ... 형태의 줄 → 새 설문 항목
      if (l.startsWith('[') && l.includes(']')) {
        surveyLines.push(l);
        return;
      }

      // 주소 구버전 형식
      if (t.startsWith('주소:') || t.startsWith('주소 :')) {
        surveyLines.push(`[주소] ${t.replace(/^주소\s*:\s*/, '')}`);
        return;
      }

      // 구버전 관리자메모 마커 단독 줄 → 이후는 adminMemoLines (마커 없는 경우)
      if (t === '[관리자메모]') {
        // 이미 신규 방식으로 분리됐으면 여기 도달 안 함
        adminMemoLines.push(l); return;
      }

      // [질문명] 없는 줄은 직전 설문 항목의 줄바꿈 연속 내용으로 처리
      //   (textarea에 개행을 포함한 답변을 입력했을 때 발생)
      if (surveyLines.length > 0) {
        // 빈 줄도 포함 (textarea 빈 줄 보존)
        surveyLines[surveyLines.length - 1] += '\n' + l;
        return;
      }

      // surveyLines 없고 내용 있으면 구버전 adminMemo fallback
      if (t) adminMemoLines.push(l);
    });

    // 관리자 메모: 신규 방식(마커) 우선, 없으면 구버전 파싱 결과 사용
    const finalAdminMemoLines = rawAdminMemoPart
      ? rawAdminMemoPart.trim().split('\n')
      : adminMemoLines;

    // 카드 결제 민감정보는 운영 화면에 표시하지 않음
    const cardWrap = document.getElementById('app-card-info-wrap');
    const cardDisplay = document.getElementById('app-card-info-display');
    if (cardWrap) cardWrap.style.display = 'none';
    if (cardDisplay) cardDisplay.textContent = '';

    // 설문 답변 표시 (편집 가능 textarea)
    const surveyWrap = document.getElementById('app-survey-display-wrap');
    const surveyDisplay = document.getElementById('app-survey-display');
    if (surveyLines.length) {
      surveyDisplay.value = surveyLines.join('\n');
      surveyWrap.style.display = 'block';
    } else {
      surveyDisplay.value = '';
      surveyWrap.style.display = 'none';
    }

    document.getElementById('app-e-memo').value = finalAdminMemoLines.join('\n').trim();
    document.getElementById('email-send-result').style.display = 'none';

    // 신청 시간 수정 필드: admin 계정에서만 표시
    const createdWrap = document.getElementById('app-e-created-wrap');
    const createdInput = document.getElementById('app-e-created-at');
    const createdDisplay = document.getElementById('app-e-created-at-display');
    const curSession = Auth.getSession ? Auth.getSession() : null;
    const isMainAdmin = curSession && curSession.username === 'admin';
    if (createdWrap) createdWrap.style.display = isMainAdmin ? 'block' : 'none';
    if (createdDisplay) createdDisplay.textContent = formatDateTime(appCreatedAt(a));
    if (createdInput && a.created_at) {
      // datetime-local 입력값은 "YYYY-MM-DDTHH:MM" 형식 필요
      const d = typeof a.created_at === 'number' || (typeof a.created_at === 'string' && !isNaN(Number(a.created_at)))
        ? new Date(Number(a.created_at))
        : new Date(a.created_at);
      if (!isNaN(d.getTime())) {
        // 로컬 시간 기준으로 변환 (timezone offset 반영)
        const offset = d.getTimezoneOffset() * 60000;
        const local = new Date(d.getTime() - offset);
        createdInput.value = local.toISOString().slice(0, 16);
      }
    }

    document.getElementById('app-detail-modal').classList.add('show');
  }

