  function editSeminar(id) { const s = allSeminars.find(x => x.id === id); if (s) openSeminarModal(s); }

  async function saveSeminar() {
    const id = (document.getElementById('sm-id').value || '').trim();
    // survey_fields는 항상 JSON 문자열로 저장 (API가 string으로 받아야 함)
    const rawSurvey = collectSurveyFields();
    const surveyFieldsJson = (rawSurvey && typeof rawSurvey !== 'string')
      ? JSON.stringify(rawSurvey)
      : (rawSurvey || '');
    const payload = {
      title: document.getElementById('sm-title').value.trim(),
      subtitle: document.getElementById('sm-subtitle').value.trim(),
      category: document.getElementById('sm-category').value.trim(),
      date: (() => {
        const isRange = document.querySelector('input[name="sm-date-type"]:checked')?.value === 'range';
        return isRange ? document.getElementById('sm-date-range-start').value.trim()
                       : document.getElementById('sm-date').value;
      })(),
      date_end: (() => {
        const isRange = document.querySelector('input[name="sm-date-type"]:checked')?.value === 'range';
        return isRange ? document.getElementById('sm-date-range-end').value.trim() : '';
      })(),
      time: document.getElementById('sm-time').value,
      location: document.getElementById('sm-location').value,
      organizer: document.getElementById('sm-organizer').value.trim(),
      form_title: document.getElementById('sm-form-title').value.trim(),
      form_subtitle: document.getElementById('sm-form-subtitle').value.trim(),
      apply_type: document.querySelector('input[name="sm-apply-type"]:checked')?.value || 'site',
      external_url: document.getElementById('sm-external-url').value.trim(),
      member_only: document.querySelector('input[name="sm-member-only"]:checked')?.value || 'open',
      price: parseInt(document.getElementById('sm-price').value) || 0,
      capacity: parseInt(document.getElementById('sm-capacity').value) || 0,
      current_applicants: parseInt(document.getElementById('sm-current-applicants').value) || 0,
      status: document.getElementById('sm-status').value,
      image_url: document.getElementById('sm-image').value.trim(),
      description: document.getElementById('sm-description').value.trim(),
      survey_fields: surveyFieldsJson,
    };
    if (!payload.title) { Toast.show('제목을 입력해주세요.', 'error'); return; }
    if (payload.apply_type === 'external' && !payload.external_url) {
      Toast.show('외부 신청 폼 URL을 입력해주세요.', 'error'); return;
    }
    console.log('[saveSeminar] id:', id, 'title:', payload.title);
    try {
      if (id) {
        await SB.update('seminars', id, payload);
        Toast.show('세미나가 수정되었습니다.', 'success');
      } else {
        await SB.insert('seminars', {...payload, current_applicants:0});
        Toast.show('세미나가 추가되었습니다.', 'success');
      }
      closeSeminarModal();
      loadSeminars();
    } catch(e) {
      console.error('[saveSeminar] 오류:', e);
      Toast.show('저장 중 오류: ' + e.message, 'error');
    }
  }

  /* ═══════════════════════════════════════════
     설문 필드 빌더 (세미나별 개별 설정)
  ═══════════════════════════════════════════ */
  let smSurveyFields = []; // 현재 편집 중인 설문 필드 배열

  const SURVEY_TYPE_LABELS = {
    text: '단답형', textarea: '장문형',
    radio: '객관식', checkbox: '체크박스',
    select: '드롭다운', date: '날짜', number: '숫자'
  };

  /* ── 신청 방식 UI 토글 (내장 / 외부 URL) ── */
  function toggleSmDateType() {
    const isRange = document.querySelector('input[name="sm-date-type"]:checked')?.value === 'range';
