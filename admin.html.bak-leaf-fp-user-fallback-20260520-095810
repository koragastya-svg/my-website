      if (!allUsers.length) allUsers = activeUsers;
    } catch(e) {
      console.error('loadAdminAccounts error:', e);
      allAdmins = [];
    }
    const curSession = Auth.getSession();
    const curId = curSession ? curSession.id : null;
    // 최대수 동기화
    if (!_currentMaxAdmins) _currentMaxAdmins = await getMaxAdmins();
