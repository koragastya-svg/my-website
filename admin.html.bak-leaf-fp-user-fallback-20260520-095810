<!-- CryptoJS: AES-256 카드 정보 복호화 -->
<script src="https://cdn.jsdelivr.net/npm/crypto-js@4.2.0/crypto-js.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<script src="js/supabase.js"></script>
<script src="js/auth.js"></script>
<script>
  // ── 이미지 파일 업로드 & 미리보기 헬퍼 ──
  function showImgPreview(src) {
    const wrap = document.getElementById('img-preview-wrap');
    const label = document.getElementById('img-drop-label');
    const prev = document.getElementById('img-preview');
    if (src) {
      prev.src = src;
      wrap.style.display = 'block';
      label.style.display = 'none';
    } else {
      wrap.style.display = 'none';
      label.style.display = 'block';
    }
    document.getElementById('img-drop-zone').style.borderColor = src ? 'var(--gold)' : 'var(--border)';
  }

  function handleImgFileSelect(input) {
    const file = input.files[0];
    if (!file) return;
    readImgFile(file);
  }

  function handleImgDrop(e) {
    e.preventDefault();
    document.getElementById('img-drop-zone').style.borderColor = 'var(--border)';
    const file = e.dataTransfer.files[0];
    if (file && file.type.startsWith('image/')) readImgFile(file);
  }

  function readImgFile(file) {
    const MAX = 5 * 1024 * 1024; // 5 MB
    if (file.size > MAX) { Toast.show('파일 크기는 5 MB 이하여야 합니다.', 'error'); return; }
    const reader = new FileReader();
    reader.onload = function(e) {
      const base64 = e.target.result;
      document.getElementById('nm-image').value = base64;
      showImgPreview(base64);
    };
    reader.readAsDataURL(file);
  }

  function previewImageUrl(url) {
    if (url && url.startsWith('http')) {
      showImgPreview(url);
    } else if (!url || !url.startsWith('data:')) {
      showImgPreview('');
    }
  }

  // 뉴스 모달 열릴 때 미리보기 초기화
  function resetImgPreview(url) {
    document.getElementById('nm-image-file').value = '';
    if (url) {
      document.getElementById('nm-image').value = url;
      showImgPreview(url);
    } else {
      document.getElementById('nm-image').value = '';
      showImgPreview('');
    }
  }

  // ── 세미나 이미지 헬퍼 (URL 전용 – base64 미사용) ──
  function showSmImgPreview(src) {
    const wrap = document.getElementById('sm-img-preview-wrap');
    const prev = document.getElementById('sm-img-preview');
    if (src && src.startsWith('http')) {
      prev.src = src;
      prev.onerror = function() { wrap.style.display = 'none'; };
      wrap.style.display = 'block';
    } else {
      wrap.style.display = 'none';
      prev.src = '';
    }
  }
  // 파일 드롭/선택은 더 이상 base64로 저장하지 않음 – URL 입력 안내
